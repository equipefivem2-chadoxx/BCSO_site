<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --bg-dark: #07090e;
        --bg-card: rgba(15, 23, 42, 0.4);
        --text-main: #e2e8f0;
        --text-muted: #94a3b8;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        font-family: 'Montserrat', sans-serif;
        color: var(--text-main);
    }

    #detail-container {
        margin-left: 280px;
        padding: 40px 60px;
        max-width: 1200px;
    }

    .header-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 20px;
        margin-bottom: 30px;
    }

    .btn-action {
        background: rgba(189, 165, 129, 0.1);
        color: var(--primary);
        border: 1px solid rgba(189, 165, 129, 0.3);
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        font-size: 13px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-action:hover { background: var(--primary); color: #000; }

    .btn-danger { color: #ef4444; border-color: rgba(239, 68, 68, 0.3); background: rgba(239, 68, 68, 0.1); }
    .btn-danger:hover { background: #ef4444; color: #fff; }

    .btn-success { color: #10b981; border-color: rgba(16, 185, 129, 0.3); background: rgba(16, 185, 129, 0.1); }
    .btn-success:hover { background: #10b981; color: #fff; }

    .report-card {
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 3px solid var(--primary);
        border-radius: 12px;
        padding: 40px;
    }

    .report-title {
        text-align: center;
        color: #fff;
        font-size: 24px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 30px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 40px;
    }

    .info-box {
        background: rgba(0,0,0,0.3);
        padding: 20px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .info-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; font-weight: bold; }
    .info-val { font-size: 16px; color: #fff; font-weight: bold; margin-top: 5px; }

    .table-eval { width: 100%; border-collapse: collapse; margin-bottom: 40px; }
    .table-eval th { background: rgba(0,0,0,0.4); padding: 15px; color: var(--primary); text-align: left; }
    .table-eval td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); }

    .badge { padding: 5px 10px; border-radius: 4px; font-size: 12px; font-weight: bold; }
    .b-acquis { background: rgba(16, 185, 129, 0.2); color: #34d399; border: 1px solid #10b981; }
    .b-partiel { background: rgba(245, 158, 11, 0.2); color: #fbbf24; border: 1px solid #f59e0b; }
    .b-nonacquis { background: rgba(239, 68, 68, 0.2); color: #f87171; border: 1px solid #ef4444; }
    .b-noneval { background: rgba(148, 163, 184, 0.2); color: #94a3b8; border: 1px solid #64748b; }

    .remarque-box {
        background: rgba(0,0,0,0.4);
        padding: 25px;
        border-left: 4px solid var(--primary);
        border-radius: 8px;
    }
</style>

<div id="detail-container">
    <div class="header-actions">
        <a href="/superviseur" class="btn-action"><i class="fas fa-arrow-left"></i> RETOUR</a>
        
        <div style="display: flex; gap: 15px;">
            <% if (rapport.statut === 'en_attente') { %>
                <form action="/superviseur/rapport/<%= rapport._id %>/valider" method="POST">
                    <button type="submit" class="btn-action btn-success"><i class="fas fa-check"></i> MARQUER TRAITÉ</button>
                </form>
            <% } %>

            <% if (isUserAdmin) { %>
                <form action="/superviseur/rapport/<%= rapport._id %>/supprimer" method="POST" onsubmit="return confirm('Supprimer définitivement ce rapport ?');">
                    <button type="submit" class="btn-action btn-danger"><i class="fas fa-trash"></i> SUPPRIMER</button>
                </form>
            <% } %>
        </div>
    </div>

    <div class="report-card">
        <div class="report-title">
            Évaluation : <span style="color: var(--primary);">[<%= rapport.matriculeJunior %>] <%= rapport.nomJunior %></span>
        </div>

        <div class="info-grid">
            <div class="info-box">
                <div class="info-label">Évaluateur</div>
                <div class="info-val"><%= rapport.gradeEvaluateur %> <%= rapport.nomEvaluateur %></div>
            </div>
            <div class="info-box">
                <div class="info-label">Avis Émis</div>
                <% 
                    // 🚀 CORRECTION : On définit la couleur en EJS pur avant la balise HTML pour éviter l'erreur de l'éditeur
                    let avisColor = '#f59e0b'; // Couleur pour 'Réservé' par défaut (Orange)
                    if (rapport.avis === 'Favorable') {
                        avisColor = '#10b981'; // Vert
                    } else if (rapport.avis === 'Défavorable') {
                        avisColor = '#ef4444'; // Rouge
                    }
                %>
                <div class="info-val" style="color: <%= avisColor %>;">
                    <%= rapport.avis %>
                </div>
            </div>
        </div>

        <table class="table-eval">
            <thead>
                <tr>
                    <th>Compétence Évaluée</th>
                    <th>Résultat</th>
                    <th>Remarques</th>
                </tr>
            </thead>
            <tbody>
                <% rapport.criteres.forEach(c => { 
                    let badgeClass = 'b-noneval';
                    if (c.etat === 'Acquis') badgeClass = 'b-acquis';
                    if (c.etat === 'Partiellement Acquis') badgeClass = 'b-partiel';
                    if (c.etat === 'Non Acquis') badgeClass = 'b-nonacquis';
                %>
                    <tr>
                        <td style="font-weight: 600;"><%= c.nom %></td>
                        <td><span class="badge <%= badgeClass %>"><%= c.etat %></span></td>
                        <td style="color: var(--text-muted); font-size: 13px;"><%= c.remarque || '-' %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <% if (rapport.remarqueGlobale) { %>
            <h4 style="color: var(--primary); text-transform: uppercase;">Observation Globale</h4>
            <div class="remarque-box">
                <%= rapport.remarqueGlobale %>
            </div>
        <% } %>
    </div>
</div>