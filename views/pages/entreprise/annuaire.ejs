<style>
    .header { border-bottom: 1px solid rgba(189, 165, 129, 0.3); padding-bottom: 20px; margin-bottom: 30px; }
    h1 { margin: 0; color: #bda581; font-size: 28px; text-transform: uppercase; font-weight: 900; }
    .desc { color: #94a3b8; font-size: 14px; margin-top: 5px; }
    
    .table-box { background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(255,255,255,0.05); border-top: 3px solid #bda581; border-radius: 12px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th { background: rgba(0,0,0,0.4); padding: 15px; color: #bda581; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    td { padding: 16px 15px; border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 14px; vertical-align: middle; }
    .matricule { font-weight: 900; color: #bda581; font-family: monospace; font-size: 15px; }
    .tel-badge { background: rgba(16, 185, 129, 0.15); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3); padding: 6px 12px; border-radius: 6px; font-family: monospace; font-weight: bold; font-size: 13px; }
    
    .btn-pass { background: rgba(189, 165, 129, 0.1); border: 1px solid #bda581; color: #bda581; width: 28px; height: 28px; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
    .btn-pass:hover { background: #bda581; color: #000; }
    .pass-count { font-weight: bold; font-size: 16px; min-width: 25px; text-align: center; color: #fff; }
</style>

<div class="header">
    <h1>Annuaire Téléphonique</h1>
    <p class="desc">Liste de contact officielle du Blaine County Sheriff's Office.</p>
</div>

<div class="table-box">
    <table>
        <thead>
            <tr>
                <th>Matricule</th>
                <th>Identité de l'Agent</th>
                <th>Grade</th>
                <th>Numéro De Téléphone</th>
                <% if (typeof isEntreprise !== 'undefined' && isEntreprise) { %>
                    <th style="text-align: center;">Passages</th>
                <% } %>
            </tr>
        </thead>
        <tbody>
            <% if (agents.length === 0) { %>
                <tr><td colspan="5" style="text-align: center; color: #94a3b8; padding: 40px;">Aucun agent répertorié.</td></tr>
            <% } else { %>
                <% agents.forEach(agent => { %>
                    <tr>
                        <td class="matricule">#<%= agent.matricule %></td>
                        <td style="font-weight: 700; color: #fff;"><%= agent.prenom %> <%= agent.nom %></td>
                        <td style="color: #cbd5e1;"><%= agent.grade %></td>
                        <td>
                            <% if (agent.telephone && agent.telephone.trim() !== '') { %>
                                <span class="tel-badge"><i class="fas fa-phone"></i> <%= agent.telephone %></span>
                            <% } else { %>
                                <span style="color: #64748b; font-size: 13px; font-style: italic;">Non attribué</span>
                            <% } %>
                        </td>
                        <% if (typeof isEntreprise !== 'undefined' && isEntreprise) { %>
                            <td>
                                <div style="display: flex; gap: 10px; align-items: center; justify-content: center;">
                                    <button class="btn-pass" onclick="updatePassage('<%= agent._id %>', 'minus')">-</button>
                                    <span class="pass-count" id="pass-<%= agent._id %>"><%= agent.passagesTotal || 0 %></span>
                                    <button class="btn-pass" onclick="updatePassage('<%= agent._id %>', 'plus')">+</button>
                                </div>
                            </td>
                        <% } %>
                    </tr>
                <% }); %>
            <% } %>
        </tbody>
    </table>
</div>

<% if (typeof isEntreprise !== 'undefined' && isEntreprise) { %>
<script>
async function updatePassage(agentId, action) {
    try {
        // 🚀 CORRECTION ICI : Remplacement de "/api/entreprise/..." par "/entreprise/..."
        const res = await fetch(`/entreprise/passage/${agentId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: action })
        });
        const data = await res.json();
        
        if(data.success) {
            document.getElementById(`pass-${agentId}`).innerText = data.nouvelAgentTotal;
        } else {
            alert(data.message || "Erreur lors de la mise à jour");
        }
    } catch (err) {
        console.error(err);
    }
}
</script>
<% } %>