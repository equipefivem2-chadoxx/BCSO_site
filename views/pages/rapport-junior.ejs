<%- include('../partials/sidebar') %>

<style>
    :root { --primary: #bda581; --primary-glow: rgba(189, 165, 129, 0.2); --bg-panel: rgba(11, 15, 25, 0.8); }
    body { margin: 0; background-color: #07090e; font-family: 'Montserrat', sans-serif; color: #e2e8f0; padding-left: 280px; background-image: radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%), radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%); min-height: 100vh; }
    .form-wrapper { max-width: 1000px; margin: 40px auto; padding: 0 20px; animation: fadeUp 0.5s ease-out forwards; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

    .form-panel { background: var(--bg-panel); border: 1px solid rgba(189, 165, 129, 0.2); border-radius: 16px; padding: 40px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); backdrop-filter: blur(15px); }
    .form-title { color: #fff; font-size: 26px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; margin-top: 0; margin-bottom: 30px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 15px; display: flex; align-items: center; gap: 15px; }
    .form-title i { color: var(--primary); font-size: 30px; }
    
    .form-group { margin-bottom: 35px; }
    .form-group label { display: block; color: var(--primary); font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; }
    
    .select-rookie { width: 100%; background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 18px; border-radius: 8px; font-size: 15px; font-family: inherit; font-weight: 600; cursor: pointer; transition: 0.3s; }
    .select-rookie:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 15px rgba(189, 165, 129, 0.2); }

    .eval-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; background: rgba(0,0,0,0.3); padding: 30px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); }
    .eval-box { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.03); padding: 15px; border-radius: 8px; display: flex; flex-direction: column; gap: 10px; }
    .eval-label { font-size: 13px; font-weight: 600; color: #e2e8f0; line-height: 1.4; }
    
    .eval-select { width: 100%; background: #1e293b; border: 1px solid #334155; color: #fff; padding: 12px; border-radius: 6px; font-size: 13px; font-weight: 800; cursor: pointer; transition: 0.3s; text-transform: uppercase; }
    .eval-select:focus { outline: none; border-color: var(--primary); }

    textarea { width: 100%; background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 18px; border-radius: 8px; font-family: inherit; font-size: 14px; min-height: 150px; resize: vertical; transition: 0.3s; }
    textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 15px rgba(189, 165, 129, 0.2); }

    .btn-submit { background: var(--primary); color: #000; border: none; width: 100%; padding: 20px; border-radius: 8px; font-weight: 900; font-size: 16px; text-transform: uppercase; letter-spacing: 2px; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px; }
    .btn-submit:hover { box-shadow: 0 0 25px rgba(189, 165, 129, 0.5); transform: translateY(-2px); }
</style>

<div class="form-wrapper">
    <div class="form-panel">
        <h2 class="form-title"><i class="fas fa-shield-alt"></i> Rapport d'Évaluation (Instructeur)</h2>
        
        <form action="/superviseur/nouveau-rapport" method="POST">
            
            <div class="form-group">
                <label><i class="fas fa-id-badge"></i> Agent Évalué (Deputy Junior uniquement) :</label>
                <select name="rookieId" class="select-rookie" required>
                    <option value="" disabled selected>-- Sélectionnez le Deputy Junior --</option>
                    <% if(rookies && rookies.length > 0) { %>
                        <% rookies.forEach(rookie => { %>
                            <option value="<%= rookie._id %>"><%= rookie.prenom %> <%= rookie.nom %> [<%= rookie.matricule %>]</option>
                        <% }) %>
                    <% } else { %>
                        <option value="" disabled>Aucun Deputy Junior trouvé dans la base de données</option>
                    <% } %>
                </select>
            </div>

            <div class="form-group">
                <label><i class="fas fa-list-check"></i> Grille de Compétences :</label>
                <div class="eval-grid">
                    <% 
                    const competences = [
                        { name: "evalMiseEnDanger", label: "Mise en danger de l'agent et d'autrui" },
                        { name: "analyseSituation", label: "Analyse d'une situation rapidement" },
                        { name: "fluiditeRadio", label: "Fluidité des Calls Radio" },
                        { name: "reponseSystematique", label: "Réponse Radio Systématique" },
                        { name: "reponseRapide", label: "Réponse Radio Rapide" },
                        { name: "tenirPoursuite", label: "Savoir tenir une poursuite" },
                        { name: "coherence1020", label: "Cohérence des 10-20 en poursuite" },
                        { name: "gestionDispatch", label: "Gestion de la Carte du Dispatch" },
                        { name: "respectCodeRoute", label: "Respect du Code de la Route" },
                        { name: "controleRoutier", label: "Réalisation d'un contrôle routier" },
                        { name: "gestionArrestation", label: "Gestion d'une Arrestation" },
                        { name: "redactionRapport", label: "Rédaction d'un Rapport" },
                        { name: "impartialite", label: "Impartialité et sang-froid" },
                        { name: "contactProximite", label: "Contact de proximité avec les civils" }
                    ];
                    %>

                    <% competences.forEach(comp => { %>
                        <div class="eval-box">
                            <div class="eval-label"><%= comp.label %></div>
                            <select name="<%= comp.name %>" class="eval-select">
                                <option value="Non Evalué" selected>Non Evalué</option>
                                <option value="Non Acquis">Non Acquis</option>
                                <option value="Partiellement Acquis">Partiellement Acquis</option>
                                <option value="Acquis">Acquis</option>
                            </select>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="form-group">
                <label><i class="fas fa-pen-to-square"></i> Remarques de l'Instructeur :</label>
                <textarea name="remarques" placeholder="Saisissez vos observations détaillées, les points forts et les points à améliorer du Deputy Junior..."></textarea>
            </div>

            <button type="submit" class="btn-submit"><i class="fas fa-paper-plane"></i> Transmettre au Commandement</button>
        </form>
    </div>
</div>

<script>
    document.querySelectorAll('.eval-select').forEach(select => {
        select.addEventListener('change', function() {
            if(this.value === 'Non Evalué') { this.style.color = '#94a3b8'; this.style.borderColor = '#334155'; }
            if(this.value === 'Non Acquis') { this.style.color = '#ef4444'; this.style.borderColor = '#ef4444'; }
            if(this.value === 'Partiellement Acquis') { this.style.color = '#f59e0b'; this.style.borderColor = '#f59e0b'; }
            if(this.value === 'Acquis') { this.style.color = '#10b981'; this.style.borderColor = '#10b981'; }
        });
    });
</script>