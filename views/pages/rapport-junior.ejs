<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --bg-darker: #05070a;
        --card-bg: #0d111a;
    }

    .main-content {
        margin-left: 280px;
        padding: 40px;
        min-height: 100vh;
        background-color: var(--bg-darker);
        color: #fff;
        font-family: 'Montserrat', sans-serif;
    }

    .page-header {
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 20px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-title h1 {
        font-size: 28px;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-title p {
        color: #94a3b8;
        margin: 5px 0 0 0;
        font-size: 14px;
    }

    .juniors-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .junior-card {
        background: var(--card-bg);
        border: 1px solid rgba(189, 165, 129, 0.15);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
        overflow: hidden;
    }

    .junior-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 4px;
        height: 100%;
        background: var(--primary);
        opacity: 0.7;
    }

    .junior-card:hover {
        transform: translateY(-5px);
        border-color: var(--primary);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5), 0 0 15px var(--primary-glow);
    }

    .junior-info {
        margin-bottom: 20px;
    }

    .junior-matricule {
        background: rgba(189, 165, 129, 0.1);
        color: var(--primary);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: bold;
        display: inline-block;
        margin-bottom: 10px;
        border: 1px solid rgba(189, 165, 129, 0.2);
    }

    .junior-name {
        font-size: 18px;
        font-weight: bold;
        color: #fff;
        margin: 0 0 5px 0;
    }

    .junior-grade {
        color: #64748b;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-evaluate {
        background: rgba(189, 165, 129, 0.1);
        color: var(--primary);
        border: 1px solid rgba(189, 165, 129, 0.3);
        padding: 10px 15px;
        border-radius: 8px;
        text-align: center;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-evaluate:hover {
        background: var(--primary);
        color: #000;
        box-shadow: 0 0 15px var(--primary-glow);
    }

    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
        background: var(--card-bg);
        border: 1px dashed rgba(189, 165, 129, 0.2);
        border-radius: 12px;
        color: #64748b;
    }
</style>

<div class="main-content">
    <div class="page-header">
        <div class="page-title">
            <h1><i class="fas fa-clipboard-list"></i> Évaluation des Juniors</h1>
            <p>Sélectionnez un Deputy Junior dans les effectifs pour initier une évaluation de terrain.</p>
        </div>
    </div>

    <div class="juniors-grid">
        <% if (juniors && juniors.length > 0) { %>
            <% juniors.forEach(junior => { %>
                <div class="junior-card">
                    <div class="junior-info">
                        <span class="junior-matricule">[ <%= junior.matricule %> ]</span>
                        <h3 class="junior-name"><%= junior.prenom %> <%= junior.nom %></h3>
                        <div class="junior-grade"><i class="fas fa-user-shield"></i> <%= junior.grade %></div>
                    </div>
                    <a href="/documents/evaluer-junior/formulaire/<%= junior._id %>" class="btn-evaluate">
                        <span>Évaluer l'agent</span> <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            <% }); %>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-user-slash" style="font-size: 40px; color: var(--primary); margin-bottom: 15px; opacity: 0.5;"></i>
                <p>Aucun Deputy Junior n'est actuellement répertorié dans les effectifs.</p>
            </div>
        <% } %>
    </div>
</div>