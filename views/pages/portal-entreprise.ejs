<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>BCSO - Annuaire Partenaire</title>
    <link rel="icon" type="image/png" href="/images/bcso.png">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --primary: #bda581; --bg-dark: #07090e; --bg-card: rgba(15, 23, 42, 0.6); }
        body { margin: 0; background-color: var(--bg-dark); font-family: 'Montserrat', sans-serif; color: #e2e8f0; padding: 40px 20px; }
        .container { max-width: 1100px; margin: 0 auto; }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(189, 165, 129, 0.3); padding-bottom: 20px; margin-bottom: 40px; }
        .header-left { display: flex; align-items: center; gap: 20px; }
        .logo { width: 70px; }
        h1 { margin: 0; color: #fff; font-size: 24px; text-transform: uppercase; font-weight: 900; }
        .badge-entreprise { background: rgba(189, 165, 129, 0.15); color: var(--primary); border: 1px solid var(--primary); padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 800; text-transform: uppercase; display: inline-block; margin-top: 5px; }
        .btn-logout { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 10px 18px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 13px; transition: 0.3s; }
        .btn-logout:hover { background: #ef4444; color: #fff; }
        .table-box { background: var(--bg-card); border: 1px solid rgba(255,255,255,0.05); border-top: 3px solid var(--primary); border-radius: 12px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        table { width: 100%; border-collapse: collapse; text-align: left; }
        th { background: rgba(0,0,0,0.4); padding: 15px; color: var(--primary); font-size: 12px; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        td { padding: 16px 15px; border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 14px; vertical-align: middle; }
        .matricule { font-weight: 900; color: var(--primary); font-family: monospace; font-size: 15px; }
        .tel-badge { background: rgba(16, 185, 129, 0.15); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3); padding: 6px 12px; border-radius: 6px; font-family: monospace; font-weight: bold; font-size: 13px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="header-left">
                <img src="/images/bcso.png" alt="BCSO" class="logo">
                <div>
                    <h1>Annuaire Téléphonique BCSO</h1>
                    <span class="badge-entreprise"><i class="fas fa-handshake"></i> Contrat Partenaire : <%= entreprise.nom %></span>
                </div>
            </div>
            <a href="/entreprise/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> Déconnexion</a>
        </div>

        <div class="table-box">
            <table>
                <thead>
                    <tr>
                        <th>Matricule</th>
                        <th>Identité de l'Agent</th>
                        <th>Grade</th>
                        <th>Téléphone de Service</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (agents.length === 0) { %>
                        <tr><td colspan="4" style="text-align: center; color: #94a3b8; padding: 40px;">Aucun agent répertorié.</td></tr>
                    <% } else { %>
                        <% agents.forEach(agent => { %>
                            <tr>
                                <td class="matricule">#<%= agent.matricule %></td>
                                <td style="font-weight: 700; color: #fff;"><%= agent.prenom %> <%= agent.nom %></td>
                                <td style="color: #cbd5e1;"><%= agent.grade %></td>
                                <td>
                                    <% if (agent.telephone && agent.telephone.trim() !== '') { %>
                                        <span class="tel-badge"><i class="fas fa-phone"></i> <%= agent.telephone %></span>
                                    <% } else { %>
                                        <span style="color: #64748b; font-size: 13px; font-style: italic;">Non attribué</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>