                </tbody>
            </table>
        </div>

        <!-- LÉGÈRES -->
        <div class="weapon-category cat-legeres">
            <div class="cat-header"><i class="fas fa-gun"></i> Légères</div>
            <table class="weapon-table">
                <thead><tr><th>Noms</th><th>Munitions</th></tr></thead>
                <tbody>
                    <tr><td>AUTO MAG AMP MODEL 180</td><td><span class="ammo-badge">44.MAGNUM</span></td></tr>
                    <tr><td>BERETTA 92FS</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>DESERT EAGLE</td><td><span class="ammo-badge">44.MAGNUM</span></td></tr>
                    <tr><td>GLOCK.18C</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>GLOCK.19</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>HK P30</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>PYTHON .357 MAGNUM CTG</td><td><span class="ammo-badge">44.MAGNUM</span></td></tr>
                </tbody>
            </table>
        </div>

        <!-- LOURDES -->
        <div class="weapon-category cat-lourdes">
            <div class="cat-header"><i class="fas fa-person-rifle"></i> Lourdes</div>
            <table class="weapon-table">
                <thead><tr><th>Noms</th><th>Munitions</th></tr></thead>
                <tbody>
                    <tr><td>HECKLER & KOCH MP5</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>IMI UZI</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>INTRATECH TEC-DC9</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>MILITARY.A CORPORATION MAC-10</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>MOSSBERG 500</td><td><span class="ammo-badge">CAL.12</span></td></tr>
                    <tr><td>MOSSBERG 590</td><td><span class="ammo-badge">CAL.12</span></td></tr>
                    <tr><td>REMINGTON 870 1.0</td><td><span class="ammo-badge">CAL.12</span></td></tr>
                    <tr><td>SKORPION VZ.61</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>THOMPSON M1928A1</td><td><span class="ammo-badge">45.ACP</span></td></tr>
                </tbody>
            </table>
        </div>

        <!-- GUERRES -->
        <div class="weapon-category cat-guerres">
            <div class="cat-header"><i class="fas fa-jet-fighter"></i> Guerres</div>
            <table class="weapon-table">
                <thead><tr><th>Noms</th><th>Munitions</th></tr></thead>
                <tbody>
                    <tr><td>AK-47</td><td><span class="ammo-badge">7,62mm</span></td></tr>
                    <tr><td>AK-74U</td><td><span class="ammo-badge">7,62mm</span></td></tr>
                    <tr><td>IMI GALIL</td><td><span class="ammo-badge">5,56mm</span></td></tr>
                    <tr><td>RPD</td><td><span class="ammo-badge">9mm</span></td></tr>
                    <tr><td>SAUER 101 HUNTING RIFLE</td><td><span class="ammo-badge">-</span></td></tr>
                </tbody>
            </table>
        </div>

        <!-- BLANCHES -->
        <div class="weapon-category cat-blanches">
            <div class="cat-header"><i class="fas fa-khanda"></i> Blanches</div>
            <table class="weapon-table">
                <thead><tr><th>Noms</th></tr></thead>
                <tbody>
                    <tr><td>Bouteille cassée</td></tr>
                    <tr><td>Couteau</td></tr>
                    <tr><td>Couteau à cran d'arrêt</td></tr>
                    <tr><td>Dague</td></tr>
                    <tr><td>Hache</td></tr>
                    <tr><td>Hache de guerre</td></tr>
                    <tr><td>Hache en pierre</td></tr>
                    <tr><td>Hachette</td></tr>
                    <tr><td>Machette</td></tr>
                    <tr><td>Poing Américain</td></tr>
                </tbody>
            </table>
        </div>

        <!-- CONTONDANTES -->
        <div class="weapon-category cat-contondantes">
            <div class="cat-header"><i class="fas fa-baseball-bat-ball"></i> Contondantes</div>
            <table class="weapon-table">
                <thead><tr><th>Noms</th></tr></thead>
                <tbody>
                    <tr><td>Batte de Baseball</td></tr>
                    <tr><td>Clé Anglaise</td></tr>
                    <tr><td>Flashlight</td></tr>
                    <tr><td>Golf Club</td></tr>
                    <tr><td>Marteau</td></tr>
                    <tr><td>Matraque</td></tr>
                    <tr><td>Pied de biche</td></tr>
                    <tr><td>Queue de Billard</td></tr>
                </tbody>
            </table>
        </div>

        <!-- INCENDIAIRES -->
        <div class="weapon-category cat-incendiaires">
            <div class="cat-header"><i class="fas fa-fire"></i> Incendiaires</div>
            <table class="weapon-table">
                <thead><tr><th>Noms</th></tr></thead>
                <tbody>
                    <tr><td>Bombe artisanale</td></tr>
                    <tr><td>C4</td></tr>
                    <tr><td>Cocktail Molotov</td></tr>
                    <tr><td>Grenade</td></tr>
                </tbody>
            </table>
        </div>

    </div>

</div>

</body>
</html>