<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --bg-card: rgba(15, 23, 42, 0.6);
        --bg-dark: #07090e;
        --text-main: #e2e8f0;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
            radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
        font-family: 'Montserrat', sans-serif;
        color: var(--text-main);
    }

    #form-container {
        margin-left: 280px;
        padding: 40px 60px 80px 60px;
        max-width: 1200px;
        animation: fadeIn 0.5s ease-out forwards;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 20px;
        margin-bottom: 40px;
    }

    .btn-back {
        background: rgba(189, 165, 129, 0.05);
        color: var(--primary);
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
        border: 1px solid rgba(189, 165, 129, 0.3);
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
    }

    .btn-back:hover { background: var(--primary); color: #000; }

    .eval-box {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 2px solid var(--primary);
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .eval-title {
        text-align: center;
        color: #fff;
        font-size: 22px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 30px;
    }

    .eval-title span { color: var(--primary); }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
        background: rgba(0,0,0,0.3);
        padding: 20px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .info-group { display: flex; flex-direction: column; gap: 8px; }
    .info-label { color: var(--primary); font-size: 13px; font-weight: 800; text-transform: uppercase; }

    .input-text, .select-agent {
        width: 100%;
        background: rgba(0,0,0,0.5);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        padding: 12px;
        border-radius: 6px;
        font-family: inherit;
        font-size: 14px;
    }

    .table-eval {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 30px;
    }

    .table-eval th {
        background: rgba(0,0,0,0.3);
        color: #94a3b8;
        padding: 15px;
        text-align: left;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .table-eval td {
        padding: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        vertical-align: middle;
    }

    .critere-name { font-weight: 600; font-size: 14px; }

    .select-etat {
        background: rgba(0,0,0,0.5);
        color: #fff;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 8px 12px;
        border-radius: 6px;
        font-weight: 700;
        font-size: 13px;
        width: 100%;
        cursor: pointer;
        outline: none;
    }

    .select-etat option[value="Acquis"] { background: #064e3b; color: #34d399; }
    .select-etat option[value="Partiellement acquis"] { background: #78350f; color: #fbbf24; }
    .select-etat option[value="Non acquis"] { background: #7f1d1d; color: #f87171; }
    .select-etat option[value="Non évalué"] { background: #1e293b; color: #94a3b8; }

    .input-remarque {
        width: 100%;
        background: rgba(0,0,0,0.2);
        border: 1px solid rgba(255,255,255,0.1);
        color: #e2e8f0;
        padding: 8px 12px;
        border-radius: 6px;
        font-family: inherit;
        font-size: 13px;
    }

    .global-section { margin-top: 40px; }
    .global-label { display: block; color: var(--primary); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; font-size: 14px; }
    
    .textarea-global {
        width: 100%;
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        padding: 15px;
        border-radius: 8px;
        min-height: 150px;
        font-family: inherit;
        font-size: 14px;
        resize: vertical;
        margin-bottom: 25px;
    }

    .decision-container { display: flex; gap: 20px; margin-bottom: 40px; }
    .radio-label { flex: 1; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); padding: 15px; border-radius: 8px; text-align: center; cursor: pointer; font-weight: 700; transition: 0.3s; }
    .radio-label input { display: none; }
    .radio-label:has(input[value="Apte"]:checked) { background: rgba(16, 185, 129, 0.15); border-color: #10b981; color: #10b981; }
    .radio-label:has(input[value="Inapte"]:checked) { background: rgba(239, 68, 68, 0.15); border-color: #ef4444; color: #ef4444; }

    .btn-submit {
        width: 100%;
        background: var(--primary);
        color: #000;
        border: none;
        padding: 15px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-submit:hover { box-shadow: 0 0 20px var(--primary-glow-strong); transform: translateY(-2px); }
</style>

<div id="form-container">
    <div class="header-section">
        <a href="/dashboard" class="btn-back"><i class="fas fa-arrow-left"></i> RETOUR</a>
    </div>

    <div class="eval-box">
        <div class="eval-title">Grille d'évaluation <span>de First Lincoln</span></div>
        
        <form action="/fl/sauvegarder" method="POST">
            <div class="info-grid">
                <div class="info-group">
                    <label class="info-label">Matricule + Prénom Nom :</label>
                    <select name="agentEvalueId" class="select-agent" required>
                        <option value="" disabled selected>Sélectionnez l'agent évalué...</option>
                        <% if (typeof agents !== 'undefined') { %>
                            <% agents.forEach(ag => { %>
                                <option value="<%= ag._id %>"><%= ag.matricule %> - <%= ag.prenom %> <%= ag.nom %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>

                <div class="info-group">
                    <label class="info-label">Date et heures de passage :</label>
                    <input type="text" name="datePassage" class="input-text" placeholder="Ex: 21/07/2026 à 21h30 jusqu'à 23h30" required>
                </div>
            </div>

            <% 
            const criteresList = [
                "Evaluation de la mise en danger de l'agent et d'autrui",
                "Savoir analyser une situation rapidement",
                "Fluidité des Calls Radio",
                "Réponse Radio Systématique",
                "Réponse Radio Rapide",
                "Savoir tenir une poursuite",
                "Effectuer des 10-20 cohérents et réguliers en poursuite",
                "Gestion de la Carte du Dispatch",
                "Respect du Code de la Route",
                "Réalisation d'un contrôle routier",
                "Gestion d'une Arrestation",
                "Rédaction d'un Rapport d'Arrestation",
                "Evaluation de l'impartialité et du sang-froid",
                "Evaluation du contact de proximité"
            ];
            %>

            <table class="table-eval">
                <thead>
                    <tr>
                        <th style="width: 45%;">Compétence évaluée</th>
                        <th style="width: 20%;">État</th>
                        <th style="width: 35%;">Remarques</th>
                    </tr>
                </thead>
                <tbody>
                    <% criteresList.forEach((critere, index) => { %>
                        <tr>
                            <td class="critere-name">
                                <input type="hidden" name="criteres[<%= index %>][nom]" value="<%= critere %>">
                                <%= critere %>
                            </td>
                            <td>
                                <select name="criteres[<%= index %>][etat]" class="select-etat" onchange="updateSelectColor(this)">
                                    <option value="Non évalué" selected>Non évalué</option>
                                    <option value="Acquis">Acquis</option>
                                    <option value="Partiellement acquis">Partiellement acquis</option>
                                    <option value="Non acquis">Non acquis</option>
                                </select>
                            </td>
                            <td>
                                <input type="text" name="criteres[<%= index %>][remarque]" class="input-remarque" placeholder="Observation...">
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>

            <div class="global-section">
                <label class="global-label"><i class="fas fa-comment-dots"></i> Commentaire de l'agent évaluateur :</label>
                <textarea name="commentaireEvaluateur" class="textarea-global" placeholder="Rédigez ici le bilan détaillé, les points forts et les lacunes constatées..." required></textarea>
                
                <label class="global-label"><i class="fas fa-gavel"></i> Décision de passage à Deputy I :</label>
                <div class="decision-container">
                    <label class="radio-label">
                        <input type="radio" name="decision" value="Apte" required> Apte à passer Deputy I
                    </label>
                    <label class="radio-label">
                        <input type="radio" name="decision" value="Inapte"> Inapte à passer Deputy I
                    </label>
                </div>

                <button type="submit" class="btn-submit"><i class="fas fa-paper-plane" style="margin-right: 8px;"></i> TRANSMETTRE LA GRILLE</button>
            </div>
        </form>
    </div>
</div>

<script>
    function updateSelectColor(select) {
        const val = select.value;
        select.style.color = '#fff';
        if (val === 'Acquis') select.style.backgroundColor = '#064e3b';
        else if (val === 'Partiellement acquis') select.style.backgroundColor = '#78350f';
        else if (val === 'Non acquis') select.style.backgroundColor = '#7f1d1d';
        else select.style.backgroundColor = '#1e293b';
    }
</script>