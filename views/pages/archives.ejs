<style>
    :root {
        --primary: #bda581;
        --bg-card: rgba(15, 23, 42, 0.4);
        --bg-dark: #07090e; 
    }
    
    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
            radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
        color: #e2e8f0;
        min-height: 100vh;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    
    #archives-container { 
        max-width: 1400px; 
        margin: 0 auto; 
        padding-top: 40px; 
        padding-bottom: 60px; 
        animation: fadeIn 0.4s ease-out forwards; 
    }
    
    .archive-header { 
        background: linear-gradient(90deg, rgba(189, 165, 129, 0.1) 0%, transparent 100%); 
        padding: 25px 30px; border-left: 4px solid var(--primary); border-radius: 12px; margin-bottom: 35px; 
    }
    .archive-header h2 { margin: 0; font-size: 24px; color: #fff; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
    .archive-header p { margin: 5px 0 0 0; color: #94a3b8; font-size: 14px; }

    .search-panel { 
        background: var(--bg-card); border: 1px solid rgba(255, 255, 255, 0.03); border-top: 1px solid rgba(189, 165, 129, 0.1);
        border-radius: 16px; padding: 25px 30px; margin-bottom: 30px; backdrop-filter: blur(10px); 
    }
    .search-form { display: flex; gap: 20px; align-items: flex-end; flex-wrap: wrap; }
    .search-group { display: flex; flex-direction: column; gap: 8px; }
    .search-label { color: #94a3b8; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; }
    
    .search-input { background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 12px 15px; border-radius: 8px; font-size: 14px; min-width: 200px; transition: all 0.3s; }
    .search-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 10px rgba(189, 165, 129, 0.2); background: rgba(0,0,0,0.5); }
    
    .btn-search { background: rgba(189, 165, 129, 0.1); border: 1px solid var(--primary); color: var(--primary); padding: 12px 25px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: all 0.3s; height: 45px; text-transform: uppercase; letter-spacing: 1px; display: inline-flex; align-items: center; justify-content: center; text-decoration: none; }
    .btn-search:hover { background: var(--primary); color: #000; box-shadow: 0 0 15px rgba(189, 165, 129, 0.3); }

    .table-panel { 
        background: var(--bg-card); border: 1px solid rgba(255, 255, 255, 0.03); border-top: 1px solid rgba(189, 165, 129, 0.1);
        border-radius: 16px; padding: 25px; backdrop-filter: blur(10px); transition: all 0.3s;
    }
    .archive-table { width: 100%; border-collapse: collapse; }
    .archive-table th { text-align: left; padding: 15px; color: #94a3b8; font-size: 12px; font-weight: 700; text-transform: uppercase; border-bottom: 1px solid rgba(255,255,255,0.05); letter-spacing: 1px; }
    .archive-table td { padding: 18px 15px; border-bottom: 1px solid rgba(255,255,255,0.02); color: #e2e8f0; font-size: 14px; }
    
    .badge-motif { background: rgba(189, 165, 129, 0.1); border: 1px solid rgba(189, 165, 129, 0.3); color: var(--primary); padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: 700; }
    .btn-view { background: rgba(189, 165, 129, 0.05); border: 1px solid rgba(189, 165, 129, 0.3); color: var(--primary); cursor: pointer; font-weight: 600; font-size: 13px; display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s; padding: 8px 15px; border-radius: 6px; text-decoration: none; }
    .btn-view:hover { background: var(--primary); color: #000; }
</style>

<div id="archives-container">
    <div class="archive-header">
        <h2><i class="fas fa-folder-open" style="margin-right: 10px;"></i> Archives Centrales</h2>
        <p>Indexation automatisée des transcriptions de dossiers et d'interventions.</p>
    </div>

    <div class="search-panel">
        <form action="/archives" method="GET" class="search-form">
            <div class="search-group">
                <label class="search-label">Recherche</label>
                <input type="text" name="search" class="search-input" placeholder="Matricule, nom, salon..." value="<%= (typeof filters !== 'undefined' && filters.search) ? filters.search : '' %>">
            </div>
            <div class="search-group">
                <label class="search-label">Filtrer par</label>
                <select name="filterType" class="search-input" style="min-width: 150px;">
                    <option value="global" <%= (typeof filters !== 'undefined' && filters.filterType === 'global') ? 'selected' : '' %>>Recherche Globale</option>
                    <option value="agent" <%= (typeof filters !== 'undefined' && filters.filterType === 'agent') ? 'selected' : '' %>>Agent en charge</option>
                    <option value="motif" <%= (typeof filters !== 'undefined' && filters.filterType === 'motif') ? 'selected' : '' %>>Motif du dossier</option>
                </select>
            </div>
            <div class="search-group">
                <label class="search-label">Date précise</label>
                <input type="date" name="date" class="search-input" value="<%= (typeof filters !== 'undefined' && filters.date) ? filters.date : '' %>">
            </div>
            <button type="submit" class="btn-search"><i class="fas fa-filter"></i> Filtrer</button>
            <% if (typeof filters !== 'undefined' && Object.keys(filters).length > 0) { %>
                <a href="/archives" class="btn-search" style="background: none; border-color: rgba(255,255,255,0.1); color: #94a3b8;">Réinitialiser</a>
            <% } %>
        </form>
    </div>

    <div class="table-panel" id="live-table-panel">
        <% if (typeof tickets !== 'undefined' && tickets.length > 0) { %>
            <table class="archive-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Dossier</th>
                        <th>Motif</th>
                        <th>Clôturé par</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% tickets.forEach(function(ticket) { %>
                        <tr>
                            <td style="color: #94a3b8; font-weight: 600;"><%= new Date(ticket.dateCreation).toLocaleDateString('fr-FR') %></td>
                            <td style="font-weight: 800; color: #fff; letter-spacing: 1px;">#<%= ticket.channelName %></td>
                            <td><span class="badge-motif"><%= ticket.motif %></span></td>
                            <td style="color: #10b981; font-weight: 600;"><i class="fas fa-user-shield" style="font-size: 12px; margin-right: 5px;"></i> <%= ticket.closedBy %></td>
                            <td style="display: flex; gap: 8px; align-items: center;">
                                <a href="/archives/<%= ticket.channelName %>" class="btn-view">
                                    <i class="fas fa-external-link-alt"></i> Ouvrir le rapport
                                </a>
                                
                                <% if (typeof agentConnecte !== 'undefined' && (agentConnecte.canDeleteArchives || agentConnecte.isAdmin)) { %>
                                    <form action="/archives/supprimer/<%= ticket._id %>" method="POST" style="margin:0;" onsubmit="return confirm('Voulez-vous vraiment supprimer ce rapport définitivement ?');">
                                        <button type="submit" class="btn-view" style="color: #ef4444; border-color: rgba(239, 68, 68, 0.3); background: rgba(239, 68, 68, 0.05); padding: 8px 12px;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <div style="text-align: center; color: #6b7280; padding: 50px 0;">
                <i class="fas fa-database" style="font-size: 35px; margin-bottom: 15px; opacity: 0.4;"></i>
                <p>Aucune transcription ne correspond à vos critères de recherche.</p>
            </div>
        <% } %>
    </div>
</div>

<!-- 🚀 SCRIPT D'ACTUALISATION SANS CLIGNOTEMENT -->
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const fetchLiveArchives = async () => {
            try {
                const response = await fetch(window.location.href);
                const html = await response.text();
                
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const newTablePanel = doc.getElementById('live-table-panel');
                const currentTablePanel = document.getElementById('live-table-panel');
                
                if (newTablePanel && currentTablePanel) {
                    // 🚀 CONDITIONS DE MISE À JOUR :
                    // On ne remplace le HTML que s'il y a un réel changement (nouveau ticket ou suppression)
                    if (currentTablePanel.innerHTML !== newTablePanel.innerHTML) {
                        currentTablePanel.innerHTML = newTablePanel.innerHTML;
                        
                        // Petit effet visuel optionnel pour confirmer la mise à jour
                        currentTablePanel.style.boxShadow = "0 0 20px rgba(189, 165, 129, 0.3)";
                        setTimeout(() => currentTablePanel.style.boxShadow = "none", 800);
                    }
                }
            } catch (error) {
                console.error("Erreur actualisation archives:", error);
            }
        };

        // Actualisation en fond toutes les 5 secondes
        setInterval(fetchLiveArchives, 5000);
    });
</script>