<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>BCSO - Dossiers, Arrestations & Procédures</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #bda581;
            --primary-glow: rgba(189, 165, 129, 0.2);
            --bg-dark: #05070b;
            --bg-panel: rgba(11, 15, 25, 0.75);
            --text-main: #e2e8f0;
            --border-glow: rgba(189, 165, 129, 0.25);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --forest-green: #1b2e1e;
        }

        body {
            margin: 0; background-color: var(--bg-dark);
            background-image: 
                linear-gradient(rgba(189, 165, 129, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(189, 165, 129, 0.02) 1px, transparent 1px);
            background-size: 30px 30px;
            font-family: 'Montserrat', sans-serif; color: var(--text-main); min-height: 100vh;
            overflow-x: hidden;
        }

        * { box-sizing: border-box; }

        @keyframes slideInRight { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes zoomIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }

        .manual-layout {
            display: flex;
            max-width: 1650px;
            margin: 25px auto;
            height: calc(100vh - 50px);
            gap: 25px;
            padding: 0 20px;
            justify-content: center;
        }

        /* SIDEBAR DE NAVIGATION */
        .manual-sidebar {
            width: 350px;
            background: rgba(6, 9, 15, 0.85);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.02);
            border-right: 1px solid var(--border-glow);
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0,0,0,0.6);
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 25px;
            background: linear-gradient(180deg, rgba(27, 46, 30, 0.3) 0%, transparent 100%);
            border-bottom: 1px solid rgba(255,255,255,0.02);
            position: relative;
        }

        .sidebar-header::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
        }

        .btn-back-hub {
            display: inline-flex;
            align-items: center; gap: 8px;
            color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;
            text-decoration: none; margin-bottom: 15px; transition: 0.3s;
            letter-spacing: 1px;
        }
        .btn-back-hub:hover { color: var(--primary); transform: translateX(-3px); }

        .manual-title { font-size: 20px; font-weight: 900; margin: 0; color: #fff; text-transform: uppercase; letter-spacing: 1px; line-height: 1.2; }
        .manual-title span { color: var(--primary); display: block; font-size: 11px; letter-spacing: 2px; margin-top: 4px; font-weight: 600; }

        .nav-list { padding: 20px 15px; display: flex; flex-direction: column; gap: 6px; overflow-y: auto; flex-grow: 1; }

        .nav-item {
            background: transparent; border: 1px solid transparent; color: #94a3b8;
            padding: 14px 18px; border-radius: 10px; text-align: left; font-family: 'Montserrat', sans-serif;
            font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; transition: all 0.25s ease; display: flex; align-items: center; justify-content: space-between;
        }
        .nav-item-meta { display: flex; align-items: center; gap: 12px; }
        .nav-item i { font-size: 1rem; color: #475569; transition: 0.3s; width: 20px; text-align: center; }
        .nav-item .page-badge { font-size: 0.7rem; color: #475569; font-weight: 800; }
        .nav-item:hover { background: rgba(255,255,255,0.02); color: #fff; transform: translateX(4px); }
        .nav-item:hover i { color: #94a3b8; }
        
        .nav-item.active {
            background: linear-gradient(90deg, rgba(189, 165, 129, 0.12) 0%, rgba(189,165,129,0.01) 100%);
            color: var(--primary); border-left: 4px solid var(--primary); border-radius: 4px 10px 10px 4px; padding-left: 14px;
        }
        .nav-item.active i { color: var(--primary); filter: drop-shadow(0 0 6px var(--primary)); }
        .nav-item.active .page-badge { color: var(--primary); }

        /* ZONE DE CONTENU PRINCIPALE */
        .manual-content {
            flex-grow: 1; background: var(--bg-panel); backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.02); border-top: 1px solid var(--border-glow);
            border-radius: 16px; padding: 45px; overflow-y: auto; box-shadow: 0 25px 60px rgba(0,0,0,0.5);
            position: relative;
        }

        .manual-content::-webkit-scrollbar { width: 6px; }
        .manual-content::-webkit-scrollbar-thumb { background: rgba(189, 165, 129, 0.25); border-radius: 10px; }

        .pane { display: none; animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .pane.active { display: block; }

        .pane-header { margin-bottom: 35px; padding-bottom: 20px; border-bottom: 1px solid rgba(189, 165, 129, 0.1); }
        .pane-title { font-size: 28px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 1.5px; margin: 0; display: flex; align-items: center; gap: 15px; }
        .pane-title i { color: var(--primary); filter: drop-shadow(0 2px 8px rgba(189,165,129,0.3)); }
        .pane-desc { color: #94a3b8; font-size: 0.95rem; margin-top: 8px; font-weight: 500; }

        /* BLOCS DE DEBRIEF ET TEXTES */
        .text-block-card {
            background: rgba(10, 15, 25, 0.6); border-left: 4px solid var(--primary);
            padding: 25px; border-radius: 4px 12px 12px 4px; border: 1px solid rgba(255,255,255,0.02);
            border-left: 4px solid var(--primary); margin-bottom: 30px; line-height: 1.6; font-size: 0.95rem; color: #cbd5e1;
        }
        .text-block-card strong { color: #fff; font-weight: 700; }

        /* MENU SOMMAIRE */
        .sommaire-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-top: 25px; }
        .sommaire-btn {
            background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255, 255, 255, 0.04);
            border-left: 4px solid var(--primary); color: #fff; padding: 25px 20px;
            text-align: left; font-family: 'Montserrat', sans-serif; font-size: 1.2rem;
            font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px;
            border-radius: 8px; cursor: pointer; transition: all 0.3s ease;
            display: flex; align-items: center; justify-content: space-between;
        }
        .sommaire-btn:hover { background: rgba(189, 165, 129, 0.1); border-color: var(--primary); transform: translateX(5px); }
        .sommaire-btn i { color: var(--primary); font-size: 1.5rem; opacity: 0.5; transition: 0.3s; }
        .sommaire-btn:hover i { opacity: 1; transform: scale(1.1); }

        /* GRID LOGIC STRIPS */
        .workflow-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 20px; }
        
        .workflow-card {
            background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; transition: 0.3s ease;
        }
        .workflow-card:hover { border-color: var(--primary); transform: translateY(-3px); }
        
        .workflow-img-wrapper { width: 100%; height: 160px; background: #000; position: relative; overflow: hidden; }
        .workflow-img-wrapper img { width: 100%; height: 100%; object-fit: cover; opacity: 0.6; transition: 0.3s; }
        .workflow-card:hover .workflow-img-wrapper img { opacity: 0.9; }
        
        .workflow-info { padding: 15px; text-align: center; background: rgba(6, 9, 15, 0.8); flex-grow: 1; display: flex; flex-direction: column; justify-content: center; }
        .workflow-step-num { font-size: 0.7rem; font-weight: 900; color: var(--primary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
        .workflow-title { font-size: 0.88rem; font-weight: 800; color: #fff; text-transform: uppercase; margin: 0; }
        .workflow-sub { font-size: 0.75rem; color: #94a3b8; margin-top: 2px; }

        /* DOUBLE COLUMN LAYOUT */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; }
        .tactical-side-card {
            background: rgba(5, 7, 11, 0.5); border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 12px; padding: 30px; position: relative; overflow: hidden;
            display: flex; flex-direction: column;
        }
        .tactical-side-card.lead { border-top: 3px solid var(--primary); }
        .tactical-side-card.agents { border-top: 3px solid #475569; }
        
        .card-badge-header { font-size: 1.4rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 15px 0; color: #fff; }
        .tactical-side-card.lead .card-badge-header { color: var(--primary); }
        
        .inner-desc { color: #cbd5e1; font-size: 0.92rem; line-height: 1.6; margin-bottom: 25px; }
        .inner-desc strong { color: #fff; }

        .bullet-list { list-style: none; padding: 0; margin: 0 0 25px 0; }
        .bullet-list li { padding: 8px 0; border-bottom: 1px dashed rgba(255,255,255,0.04); font-size: 0.88rem; color: #cbd5e1; display: flex; align-items: center; gap: 10px; }
        .bullet-list li i { color: var(--primary); font-size: 0.8rem; }

        /* BOUTON MODAL */
        .btn-tactical-link {
            display: inline-flex; align-items: center; justify-content: center; width: 100%; padding: 12px;
            background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px;
            color: #fff; font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;
            text-decoration: none; transition: 0.2s; gap: 8px; margin-top: auto; cursor: pointer;
            font-family: 'Montserrat', sans-serif;
        }
        .btn-tactical-link:hover { background: var(--primary); color: #000; border-color: transparent; box-shadow: 0 4px 15px var(--primary-glow); }

        /* DROITS MIRANDA CARD DESIGN */
        .miranda-box {
            background: radial-gradient(circle at top left, rgba(27, 46, 30, 0.15) 0%, rgba(5, 7, 11, 0.9) 100%);
            border: 1px solid rgba(189, 165, 129, 0.15); border-radius: 12px; padding: 35px; text-align: center; position: relative;
        }
        .miranda-text { font-size: 1.05rem; line-height: 1.8; color: #e2e8f0; font-weight: 500; max-width: 850px; margin: 0 auto 25px auto; text-align: justify; text-justify: inter-word; }
        .miranda-text strong { color: var(--primary); font-weight: 700; }
        
        .miranda-footer-alert {
            background: rgba(239, 68, 68, 0.06); border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 15px; border-radius: 8px; color: #fca5a5; font-size: 0.8rem; font-weight: 800;
            letter-spacing: 0.5px; text-transform: uppercase; display: flex; align-items: center; justify-content: center; gap: 10px;
        }

        .copy-btn {
            background: var(--primary); color: #000; border: none; padding: 12px 25px; border-radius: 8px;
            font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 0.8rem; text-transform: uppercase;
            letter-spacing: 1px; cursor: pointer; transition: 0.2s; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 25px;
        }
        .copy-btn:hover { background: #fff; transform: scale(1.02); }

        /* MATRIX LAYOUT */
        .matrix-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        .matrix-item {
            background: rgba(0, 0, 0, 0.3); border: 1px solid rgba(255,255,255,0.03);
            border-left: 3px solid var(--primary); padding: 16px 20px; border-radius: 4px 8px 8px 4px;
            font-size: 0.9rem; font-weight: 700; color: #fff; display: flex; align-items: center; gap: 12px;
        }
        .matrix-item i { color: var(--primary); font-size: 0.85rem; background: rgba(189,165,129,0.06); padding: 8px; border-radius: 6px; }

        /* LAW DASHBOARD */
        .law-grid { display: flex; flex-direction: column; gap: 12px; }
        .law-card {
            background: rgba(0, 0, 0, 0.25); border: 1px solid rgba(255,255,255,0.03);
            padding: 16px 22px; border-radius: 10px; display: grid; grid-template-columns: 40px 1fr; align-items: center; transition: 0.2s;
        }
        .law-card:hover { background: rgba(255,255,255,0.01); border-color: rgba(189,165,129,0.1); }
        .law-icon-holder { font-size: 1.1rem; color: var(--primary); display: flex; align-items: center; }
        .law-content-text { font-size: 0.9rem; line-height: 1.5; color: #cbd5e1; font-weight: 500; }
        .law-content-text strong { color: #fff; font-weight: 700; }

        /* BANNER POUR L'INDEX COVER */
        .cover-banner {
            background: linear-gradient(135deg, var(--forest-green) 0%, rgba(5,7,11,0.95) 100%);
            border-radius: 12px; padding: 45px; border: 1px solid rgba(255,255,255,0.03);
            display: flex; align-items: center; justify-content: space-between; margin-bottom: 30px;
        }
        .cover-txt h3 { font-size: 2.2rem; font-weight: 900; color: #fff; margin: 0; text-transform: uppercase; letter-spacing: 1px; }
        .cover-txt p { font-size: 1rem; color: var(--primary); margin: 6px 0 0 0; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; }

        /* MODAL IMAGE CSS (Lightbox - Mise à jour Flexbox pour centrage) */
        .img-modal {
            display: none; /* Remplacé par flex en JS */
            position: fixed; z-index: 9999;
            left: 0; top: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.85); backdrop-filter: blur(10px);
            align-items: center; justify-content: center;
        }
        .img-modal-content {
            display: block; max-width: 95vw; max-height: 95vh; width: auto; height: auto;
            border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.8);
            border: 1px solid rgba(189,165,129,0.3); animation: zoomIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            object-fit: contain;
        }
        .close-modal {
            position: absolute; top: 20px; right: 40px; color: #cbd5e1;
            font-size: 45px; font-weight: 300; transition: 0.3s; cursor: pointer;
            z-index: 10000;
        }
        .close-modal:hover, .close-modal:focus { color: var(--primary); text-decoration: none; }

        @media (max-width: 1200px) {
            .manual-layout { flex-direction: column; height: auto; }
            .manual-sidebar { width: 100%; height: auto; }
            .workflow-grid { grid-template-columns: repeat(2, 1fr); }
            .grid-2, .matrix-grid { grid-template-columns: 1fr; }
            .sommaire-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 768px) {
            .workflow-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<div class="manual-layout">
    
    <!-- NAVIGATION SIDEBAR -->
    <aside class="manual-sidebar">
        <div class="sidebar-header">
            <!-- LIEN RETOUR LIVRET CORRIGÉ SUR /documents/livret -->
            <a href="/documents/livret" class="btn-back-hub"><i class="fas fa-chevron-left"></i> Retour au Livret</a>
            <h1 class="manual-title">Procédures<span>Dossiers & Interpellations</span></h1>
        </div>
        <nav class="nav-list">
            <button id="nav-index" class="nav-item active" onclick="openPane('index-cover', this)"><div class="nav-item-meta"><i class="fas fa-gavel"></i> <span>Sommaire Général</span></div><span class="page-badge">-</span></button>
            <button id="nav-arrestations" class="nav-item" onclick="openPane('arrestations', this)"><div class="nav-item-meta"><i class="fas fa-handcuffs"></i> <span>Arrestations</span></div><span class="page-badge">P.3</span></button>
            <button id="nav-procedures" class="nav-item" onclick="openPane('procedures-poste', this)"><div class="nav-item-meta"><i class="fas fa-building-shield"></i> <span>Procédures au Poste</span></div><span class="page-badge">P.4</span></button>
            <button id="nav-miranda" class="nav-item" onclick="openPane('miranda', this)"><div class="nav-item-meta"><i class="fas fa-scale-balanced"></i> <span>Droits Miranda</span></div><span class="page-badge">P.5</span></button>
            <button id="nav-dossier" class="nav-item" onclick="openPane('dossier-op', this)"><div class="nav-item-meta"><i class="fas fa-folder-open"></i> <span>Dossier d'Opération</span></div><span class="page-badge">P.6</span></button>
            <button id="nav-rapport" class="nav-item" onclick="openPane('rapport-op', this)"><div class="nav-item-meta"><i class="fas fa-file-signature"></i> <span>Rapport d'Opération</span></div><span class="page-badge">P.7</span></button>
            <button id="nav-savoir" class="nav-item" onclick="openPane('savoir', this)"><div class="nav-item-meta"><i class="fas fa-circle-info"></i> <span>À Savoir</span></div><span class="page-badge">P.8</span></button>
        </nav>
    </aside>

    <!-- CONTENT PANES CONTAINER -->
    <main class="manual-content">
        
        <!-- PANE: INDEX COVER -->
        <div id="index-cover" class="pane active">
            <div class="cover-banner">
                <div class="cover-txt">
                    <h3>Dossiers, Arrestations & Procédures</h3>
                    <p>Blaine County Sheriff's Office</p>
                </div>
                <i class="fas fa-shield-halved" style="font-size: 4.5rem; color: rgba(189,165,129,0.15);"></i>
            </div>
            
            <div class="text-block-card">
                <strong>Bienvenue dans le module réglementaire de traitement judiciaire.</strong> Ce livret regroupe l'intégralité des obligations légales, des structures de rapports et des cadres d'interpellations applicables sur l'ensemble de la juridiction de Blaine County. Tout manquement aux procédures énumérées ici est passible de sanctions administratives et de vices de procédure.
            </div>

            <!-- SOMMAIRE VISUEL -->
            <div class="sommaire-grid">
                <button class="sommaire-btn" onclick="document.getElementById('nav-arrestations').click()">
                    Arrestations <i class="fas fa-handcuffs"></i>
                </button>
                <button class="sommaire-btn" onclick="document.getElementById('nav-procedures').click()">
                    Procédures <i class="fas fa-building-shield"></i>
                </button>
                <button class="sommaire-btn" onclick="document.getElementById('nav-miranda').click()">
                    Droits Miranda <i class="fas fa-scale-balanced"></i>
                </button>
                <button class="sommaire-btn" onclick="document.getElementById('nav-dossier').click()">
                    Dossier d'Opération <i class="fas fa-folder-open"></i>
                </button>
                <button class="sommaire-btn" onclick="document.getElementById('nav-rapport').click()">
                    Rapport d'Opération <i class="fas fa-file-signature"></i>
                </button>
                <button class="sommaire-btn" onclick="document.getElementById('nav-savoir').click()">
                    A Savoir <i class="fas fa-circle-info"></i>
                </button>
            </div>
        </div>

        <!-- PANE: ARRESTATIONS -->
        <div id="arrestations" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-handcuffs"></i> Arrestation</h2>
                <p class="pane-desc">Protocole impératif sur le terrain, applicable avant l'arrivée au poste de police.</p>
            </div>

            <div class="text-block-card">
                Une fois que vous avez l'individu en face de vous, <strong>prêt pour l'arrestation</strong>, vous devez vous assurer qu'il n'est <strong>pas armé</strong>. Si tel est le cas, demandez-lui de jeter son arme immédiatement.<br><br>
                Ensuite, si la personne se montre coopérative, demandez-lui d'enlever <strong>son masque</strong> et procédez à la <strong>PALPATION (MOTIF VALABLE)</strong> ; mettez-lui ensuite <strong>les menottes</strong>.<br><br>
                Si la personne n'est pas coopérative, menottez-la, enlevez-lui de force son masque, effectuez la palpation et placez-la dans le véhicule. Pendant la palpation, saisissez <strong>son(es) arme(s)</strong>.
            </div>

            <div class="workflow-grid">
                <div class="workflow-card">
                    <div class="workflow-img-wrapper"><img src="images/arrest1.png" alt="Étape 1" onerror="this.src='https://images.unsplash.com/photo-1557597774-9d273605dfa9?q=80&w=600'"></div>
                    <div class="workflow-info">
                        <span class="workflow-step-num">Étape 1</span>
                        <h4 class="workflow-title">Jeter l'arme</h4>
                    </div>
                </div>
                <div class="workflow-card">
                    <div class="workflow-img-wrapper"><img src="images/arrest2.png" alt="Étape 2" onerror="this.src='https://images.unsplash.com/photo-1621528643929-d58894109401?q=80&w=600'"></div>
                    <div class="workflow-info">
                        <span class="workflow-step-num">Étape 2</span>
                        <h4 class="workflow-title">Enlever le masque</h4>
                    </div>
                </div>
                <div class="workflow-card">
                    <div class="workflow-img-wrapper"><img src="images/arrest3.png" alt="Étape 3" onerror="this.src='https://images.unsplash.com/photo-1453847668862-487637052f8a?q=80&w=600'"></div>
                    <div class="workflow-info">
                        <span class="workflow-step-num">Étape 3</span>
                        <h4 class="workflow-title">Palper l'individu</h4>
                        <span class="workflow-sub">Prise d'identité</span>
                    </div>
                </div>
                <div class="workflow-card">
                    <div class="workflow-img-wrapper"><img src="images/arrest4.png" alt="Étape 4" onerror="this.src='https://images.unsplash.com/photo-1604147706283-d7119b5b822c?q=80&w=600'"></div>
                    <div class="workflow-info">
                        <span class="workflow-step-num">Étape 4</span>
                        <h4 class="workflow-title">Menotter</h4>
                    </div>
                </div>
            </div>
        </div>

        <!-- PANE: PROCEDURES AU POSTE DE POLICE -->
        <div id="procedures-poste" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-building-shield"></i> Procédures</h2>
                <p class="pane-desc">Traitement légal obligatoire lors du transfert de l'interpellé au poste de police.</p>
            </div>

            <div class="text-block-card">
                Une fois au poste, enlevez les menottes de l'individu et demandez-lui sa carte d'identité, lisez-lui <strong>ses droits</strong> (maximum 3 fois, il est déconseillé d'interrompre la lecture).<br><br>
                Effectuez ensuite une FOUILLE. Si vous trouvez des drogues ou de l'argent (plus de 3500$), saisissez-les. En fonction de la fouille vous devrez peut-être également rajouter des faits d'inculpations.<br><br>
                Dans le poste faites-lui déposer <strong>ses affaires</strong> telles que lacets, accessoires, téléphone, ceinture, couvre-chef, lunettes (sauf les lunettes de vue), ou autre.<br><br>
                Enfin, mettez-le <strong>en cellule</strong> (n'oubliez pas de fermer la porte) et interdisez l'accès sauf pour déposer l'amende. <strong>Rédigez ensuite son rapport d'arrestation</strong> dans un endroit calme et faites-le sortir en temps voulu.
            </div>

            <div class="workflow-grid">
                <div class="workflow-card">
                    <div class="workflow-img-wrapper"><img src="images/proc1.png" alt="Proc 1" onerror="this.src='https://images.unsplash.com/photo-1589829545856-d10d557cf95f?q=80&w=600'"></div>
                    <div class="workflow-info">
                        <span class="workflow-step-num">Étape 1</span>
                        <h4 class="workflow-title">Démenotter</h4>
                    </div>
                </div>
                <div class="workflow-card">
                    <div class="workflow-img-wrapper"><img src="images/proc2.png" alt="Proc 2" onerror="this.src='https://images.unsplash.com/photo-1505664194779-8beaceb93744?q=80&w=600'"></div>
                    <div class="workflow-info">
                        <span class="workflow-step-num">Étape 2</span>
                        <h4 class="workflow-title">Carte d'identité</h4>
                        <span class="workflow-sub">Droits Miranda</span>
                    </div>
                </div>
                <div class="workflow-card">
                    <div class="workflow-img-wrapper"><img src="images/proc3.png" alt="Proc 3" onerror="this.src='https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=600'"></div>
                    <div class="workflow-info">
                        <span class="workflow-step-num">Étape 3</span>
                        <h4 class="workflow-title">Fouille</h4>
                    </div>
                </div>
                <div class="workflow-card">
                    <div class="workflow-img-wrapper"><img src="images/proc4.png" alt="Proc 4" onerror="this.src='https://images.unsplash.com/photo-1595246140625-573b715d11dc?q=80&w=600'"></div>
                    <div class="workflow-info">
                        <span class="workflow-step-num">Étape 4</span>
                        <h4 class="workflow-title">Déposer ses affaires</h4>
                    </div>
                </div>
            </div>
        </div>

        <!-- PANE: DROITS MIRANDA -->
        <div id="miranda" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-scale-balanced"></i> Droits Miranda</h2>
                <p class="pane-desc">Énoncé légal obligatoire à réciter pour valider la mise en état d'arrestation.</p>
            </div>

            <div class="miranda-box">
                <button class="copy-btn" onclick="copyMiranda()"><i class="far fa-copy"></i> Copier la déclaration officielle</button>
                
                <div class="miranda-text" id="mirandaTxt">
                    « Prénom Nom, nous sommes le --/--/---- , il est actuellement --h--.<br><br>
                    Vous êtes placé en état d'arrestation pour le(s) fait(s) suivant(s): <strong>FAIT(S)</strong>.<br><br>
                    Vous avez le droit de garder le silence. Si vous renoncez à ce droit, tout ce que vous direz pourra être, et sera utilisé contre vous devant une cour de justice.<br>
                    Vous avez le droit à un avocat. Si vous n'en avez pas les moyens, un avocat vous sera commis d'office.<br>
                    Vous avez également le droit à boire et à manger, à des soins lors de votre garde à vue.<br><br>
                    Avez-vous compris vos droits ? Les droits sont considérés comme compris au bout de 3 fois, les faits énoncés sont non exhaustifs. Souhaitez-vous en faire usage ? »
                </div>

                <div class="miranda-footer-alert">
                    <i class="fas fa-triangle-exclamation"></i>
                    <span>À partir du moment où vous lisez les droits Miranda vous êtes responsable de la procédure jusqu'à la fin de celle-ci.</span>
                </div>
            </div>
        </div>

        <!-- PANE: DOSSIER D'OPERATION -->
        <div id="dossier-op" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-folder-open"></i> Dossier d'Opération</h2>
                <p class="pane-desc">Méthode stricte de répartition des tâches lors de la constitution d'un dossier judiciaire.</p>
            </div>

            <div class="grid-2">
                <!-- LEAD TERRAIN -->
                <div class="tactical-side-card lead">
                    <h3 class="card-badge-header"><i class="fas fa-user-tie"></i> Lead Terrain</h3>
                    <div class="inner-desc">
                        Le lead terrain désigné s'occupe de l'ouverture du dossier d'opération, <strong>il en a la gestion</strong> jusqu'à la fermeture de celui-ci.<br><br>
                        Une fois les procédures terminées il doit s'occuper de remplir un <strong>rapport d'opération</strong>, celui-ci servira d'archive pour le bureau d'enquête (si enquête).<br><br>
                        Pensez également au travail du Procureur qui a accès à celui-ci, veillez à ce qu'il soit organisé proprement et que l'on ait pas besoin de 5 minutes pour trouver une information.
                    </div>
                    <!-- BOUTON DÉCLENCHEUR DE LA MODAL -->
                    <button onclick="openImageModal('images/exempledossier.png')" class="btn-tactical-link"><i class="fas fa-file-pdf"></i> Exemple d'un dossier d'arrestation</button>
                </div>

                <!-- AGENTS -->
                <div class="tactical-side-card agents">
                    <h3 class="card-badge-header" style="color:#94a3b8;"><i class="fas fa-person-military-pointing"></i> Agents</h3>
                    <div class="inner-desc">
                        Vous êtes tenus pour chaque arrestation (en plus du rapport d'arrestation) de prendre en photo :
                    </div>
                    <ul class="bullet-list">
                        <li><i class="fas fa-check"></i> Pièce d'identité</li>
                        <li><i class="fas fa-check"></i> Fouille (Si objets confisqués)</li>
                        <li><i class="fas fa-check"></i> L'individu</li>
                    </ul>
                    <div class="inner-desc">
                        Rassemblez tout en un seul message. De prendre également son numéro de téléphone (modifier sa fiche MDT). De tenir au courant le lead terrain dans le dossier de l'avancement des procédures (si convocation ou report).
                    </div>
                    <!-- BOUTON DÉCLENCHEUR DE LA MODAL -->
                    <button onclick="openImageModal('images/exemplemessage.png')" class="btn-tactical-link"><i class="fas fa-comment-alt"></i> Exemple message suite arrestation</button>
                </div>
            </div>
        </div>

        <!-- PANE: RAPPORT D'OPERATION -->
        <div id="rapport-op" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-file-signature"></i> Rapport d'Opération</h2>
                <p class="pane-desc">Directives de rédaction du compte-rendu pour le Lead Terrain (Délai maximum : 48h).</p>
            </div>

            <div class="text-block-card">
                C'est au lead terrain de remplir un rapport d'opération dans un <strong>délai de 48h maximum</strong> après la fin de celle-ci. Le but du rapport est que n'importe quel individu ne connaissant rien à l'opération (procureur par exemple) comprenne le contexte après lecture.
            </div>

            <h3 style="color:#fff; font-weight:800; text-transform:uppercase; font-size:1rem; margin-bottom:15px; letter-spacing:0.5px;"><i class="fas fa-list-check" style="color:var(--primary); margin-right:8px;"></i> Éléments obligatoires à stipuler :</h3>
            
            <div class="matrix-grid">
                <div class="matrix-item"><i class="far fa-calendar-days"></i> La date / Heure</div>
                <div class="matrix-item"><i class="fas fa-circle-exclamation"></i> Le type d'incident</div>
                <div class="matrix-item"><i class="fas fa-map-pin"></i> Le lieu / Rue</div>
                <div class="matrix-item"><i class="fas fa-user-ninja"></i> Noms / prénoms des ravisseurs</div>
                <div class="matrix-item"><i class="fas fa-comments"></i> Lead négociations</div>
                <div class="matrix-item"><i class="fas fa-star"></i> Lead terrain</div>
                <div class="matrix-item"><i class="fas fa-users"></i> Agents présents</div>
                <div class="matrix-item"><i class="fas fa-user-injured"></i> Noms / prénoms des otages</div>
                <div class="matrix-item"><i class="fas fa-car"></i> Modèle et plaques véhicules</div>
                <div class="matrix-item"><i class="fas fa-comments-dollar"></i> Résumé négociations</div>
                <div class="matrix-item"><i class="fas fa-paste"></i> Résumé de l'opération</div>
                <div class="matrix-item"><i class="fas fa-road-barrier"></i> Résumé des poursuites</div>
            </div>
        </div>

        <!-- PANE: A SAVOIR -->
        <div id="savoir" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-circle-info"></i> À Savoir</h2>
                <p class="pane-desc">Réglementations juridiques fondamentales and rappels de sécurité indispensables.</p>
            </div>

            <div class="law-grid">
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-user-injured"></i></div>
                    <div class="law-content-text">Une personne peut faire semblant d'être blessée afin de <strong>tenter ensuite une prise d'otage</strong>.</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-fingerprint"></i></div>
                    <div class="law-content-text">En tant qu'agent assermenté, vous avez le droit de procéder à <strong>une palpation ou une fouille</strong> sur un individu, qu'il soit un homme ou une femme.</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-gavel"></i></div>
                    <div class="law-content-text">Une fouille peut être effectuée <strong>sous ces trois conditions</strong> : Au poste suite à un délit, en DEFCON 1, 2, 3, ou sous mandat officiel.</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-money-bill-wave"></i></div>
                    <div class="law-content-text">La <strong>somme maximale</strong> d'argent liquide tolérée sur soi est de <strong>3500$</strong>.</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-lock"></i></div>
                    <div class="law-content-text">N'oubliez pas de mettre <strong>les menottes</strong> à l'individu <strong>avant qu'il monte dans votre véhicule</strong> afin d'éviter toute tentative de prise d'otage.</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-bullhorn"></i></div>
                    <div class="law-content-text">Maximum <strong>3 fois</strong> autorisées pour la <strong>lecture des droits Miranda</strong>.</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-gavel" style="color: var(--success)"></i></div>
                    <div class="law-content-text"><strong>Délit Mineur</strong> = Un simple <strong>Rapport d'Arrestation (R.A)</strong> est nécessaire, aucun besoin de faire appel à un procureur ou un juge.</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-scale-unbalanced" style="color: var(--danger)"></i></div>
                    <div class="law-content-text"><strong>Délit Majeur</strong> = <strong>Rapport d'Arrestation (R.A)</strong>, Procureur + Juge obligatoire (surtout pour comparution immédiate, besoin d'un juge absolument).</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-folder-closed"></i></div>
                    <div class="law-content-text"><strong>Dossier d'opération</strong> = un <strong>Rapport d'opération (R.O)</strong> est strictement obligatoire (doit être écrit par le Lead terrain).</div>
                </div>
                <div class="law-card">
                    <div class="law-icon-holder"><i class="fas fa-clipboard-list"></i></div>
                    <div class="law-content-text"><strong>Rapport d'incident</strong> = À rédiger obligatoirement si vous subissez un événement important dans l'exercice de vos fonctions.</div>
                </div>
            </div>
        </div>

    </main>
</div>

<!-- L'ÉCRAN MODAL POUR AFFICHER LES IMAGES EN GRAND -->
<div id="fullImageModal" class="img-modal">
    <span class="close-modal" onclick="closeImageModal()">&times;</span>
    <img class="img-modal-content" id="displayedImage">
</div>

<script>
    // Moteur d'onglets
    function openPane(paneId, button) {
        document.querySelectorAll('.nav-item').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.pane').forEach(pane => pane.classList.remove('active'));
        
        button.classList.add('active');
        document.getElementById(paneId).classList.add('active');
    }

    // GESTION DU MODAL IMAGE (AFFICHER EN GRAND)
    function openImageModal(imgSrc) {
        // Changement important ici : on utilise "flex" pour que l'image se centre automatiquement
        document.getElementById("fullImageModal").style.display = "flex";
        document.getElementById("displayedImage").src = imgSrc;
    }

    function closeImageModal() {
        document.getElementById("fullImageModal").style.display = "none";
        document.getElementById("displayedImage").src = ""; // Vide la source à la fermeture
    }

    // Fermer le modal si on clique à l'extérieur de l'image
    window.onclick = function(event) {
        var modal = document.getElementById("fullImageModal");
        if (event.target == modal) {
            closeImageModal();
        }
    }

    // Copie rapide du texte Miranda
    function copyMiranda() {
        const textToCopy = "Prénom Nom, nous sommes le --/--/---- , il est actuellement --h-- . Vous êtes placé en état d'arrestation pour le(s) fait(s) suivant(s): FAIT(S). Vous avez le droit de garder le silence. Si vous renoncez à ce droit, tout ce que vous direz pourra être, et sera utilisé contre vous devant une cour de justice. Vous avez le droit à un avocat. Si vous n'en avez pas les moyens, un avocat vous sera commis d'office. Vous avez également le droit à boire et à manger, à des soins lors de votre garde à vue. Avez vous compris vos droits ? Les droits sont considéres comme compris au bout de 3 fois, les faits énoncés sont non exhaustifs. Souhaitez vous en faire usage ?";
        
        navigator.clipboard.writeText(textToCopy).then(() => {
            const btn = document.querySelector('.copy-btn');
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check"></i> Texte copié !';
            btn.style.background = '#10b981';
            btn.style.color = '#fff';
            
            setTimeout(() => {
                btn.innerHTML = originalHTML;
                btn.style.background = 'var(--primary)';
                btn.style.color = '#000';
            }, 2000);
        });
    }
</script>

</body>
</html>