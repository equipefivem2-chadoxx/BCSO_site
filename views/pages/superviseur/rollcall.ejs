<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<!-- Actualisation automatique toutes les 30 secondes (optionnel, enlève le commentaire si tu veux) -->
<!-- <meta http-equiv="refresh" content="30"> -->

<style>
    :root {
        --bg-dark: #07090e;
        --bg-card: rgba(15, 23, 42, 0.4);
        --primary: #bda581;
    }
    body { background-color: var(--bg-dark); color: #e2e8f0; font-family: 'Montserrat', sans-serif; margin: 0; }
    #rollcall-container { margin-left: 280px; padding: 40px 60px; max-width: 1200px; animation: fadeUp 0.4s; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(15px); } to { opacity:1; transform:translateY(0); } }

    .header-flex { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 1px solid rgba(189,165,129,0.2); padding-bottom: 20px; margin-bottom: 30px; }
    .header-flex h1 { color: var(--primary); margin: 0; text-transform: uppercase; font-weight: 900; }
    
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px; }
    .stat-box { background: var(--bg-card); padding: 20px; border-radius: 8px; text-align: center; border: 1px solid rgba(255,255,255,0.05); }
    .stat-box.present { border-top: 3px solid #10b981; }
    .stat-box.retard { border-top: 3px solid #f59e0b; }
    .stat-box.absent { border-top: 3px solid #ef4444; }
    .stat-box.non-repondu { border-top: 3px solid #64748b; }
    .stat-number { font-size: 24px; font-weight: bold; margin-bottom: 5px; }

    table { width: 100%; border-collapse: collapse; background: var(--bg-card); border-radius: 8px; overflow: hidden; }
    th, td { padding: 15px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.05); }
    th { background: rgba(0,0,0,0.3); color: var(--primary); text-transform: uppercase; font-size: 13px; }
    tr:hover { background: rgba(255,255,255,0.02); }

    .badge { padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: bold; display: inline-block; }
    .badge.present { background: rgba(16, 185, 129, 0.1); color: #10b981; }
    .badge.retard { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
    .badge.absent { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
    .badge.non_repondu { background: rgba(100, 116, 139, 0.1); color: #94a3b8; }
</style>

<div id="rollcall-container">
    <div class="header-flex">
        <div>
            <h1>Suivi Roll Call</h1>
            <p style="color:#94a3b8; margin-top:5px;">Date ciblée : <%= searchDate %></p>
        </div>
        <div>
            <form action="/superviseur/rollcall" method="GET" style="display: flex; gap: 10px;">
                <input type="text" name="date" value="<%= searchDate %>" placeholder="JJ/MM/AA" style="padding: 10px; border-radius: 6px; border: none; background: rgba(0,0,0,0.5); color: #fff;">
                <button type="submit" style="padding: 10px 20px; background: var(--primary); color: #000; border: none; border-radius: 6px; font-weight: bold; cursor: pointer;">Chercher</button>
            </form>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-box present">
            <div class="stat-number" style="color: #10b981;"><%= stats.present %></div>
            <div style="color: #94a3b8; font-size: 12px; text-transform: uppercase;">Présents</div>
        </div>
        <div class="stat-box retard">
            <div class="stat-number" style="color: #f59e0b;"><%= stats.retard %></div>
            <div style="color: #94a3b8; font-size: 12px; text-transform: uppercase;">Retards</div>
        </div>
        <div class="stat-box absent">
            <div class="stat-number" style="color: #ef4444;"><%= stats.absent %></div>
            <div style="color: #94a3b8; font-size: 12px; text-transform: uppercase;">Absents</div>
        </div>
        <div class="stat-box non-repondu">
            <div class="stat-number" style="color: #94a3b8;"><%= stats.non_repondu %></div>
            <div style="color: #94a3b8; font-size: 12px; text-transform: uppercase;">Sans Réponse</div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Agent</th>
                <th>Matricule</th>
                <th>Grade</th>
                <th>Statut Roll Call</th>
            </tr>
        </thead>
        <tbody>
            <% listeSuivi.forEach(function(agent) { %>
                <tr>
                    <td style="font-weight: bold;"><%= agent.nom %></td>
                    <td style="color: #94a3b8;">[<%= agent.matricule %>]</td>
                    <td><%= agent.grade %></td>
                    <td>
                        <% if(agent.status === 'present') { %>
                            <span class="badge present"><i class="fas fa-check"></i> Présent</span>
                        <% } else if(agent.status === 'retard') { %>
                            <span class="badge retard"><i class="fas fa-hourglass-half"></i> Retard</span>
                        <% } else if(agent.status === 'absent') { %>
                            <span class="badge absent"><i class="fas fa-times"></i> Absent</span>
                        <% } else { %>
                            <span class="badge non_repondu"><i class="fas fa-question"></i> En attente</span>
                        <% } %>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>