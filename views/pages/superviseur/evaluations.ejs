<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --bg-card: rgba(15, 23, 42, 0.4);
        --bg-dark: #07090e;
        --text-main: #e2e8f0;
    }

    body { margin: 0; background-color: var(--bg-dark); font-family: 'Montserrat', sans-serif; color: var(--text-main); }
    #evaluations-container { margin-left: 280px; padding: 50px 60px; max-width: 1400px; animation: fadeUp 0.4s ease-out; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

    .header-actions { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(189, 165, 129, 0.2); padding-bottom: 20px; margin-bottom: 30px; }
    .btn-action { background: rgba(189, 165, 129, 0.1); color: var(--primary); border: 1px solid rgba(189, 165, 129, 0.3); padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 13px; display: inline-flex; align-items: center; gap: 8px; cursor: pointer; }
    .btn-action:hover { background: var(--primary); color: #000; }

    /* Bouton spécifique suppression */
    .btn-danger { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }
    .btn-danger:hover { background: #ef4444; color: #fff; border-color: #ef4444; }

    .panel-box { background: var(--bg-card); border: 1px solid rgba(255,255,255,0.05); border-top: 2px solid var(--primary); border-radius: 12px; padding: 30px; }
    .table-eval { width: 100%; border-collapse: collapse; text-align: left; }
    .table-eval th { background: rgba(0,0,0,0.3); padding: 15px; color: #94a3b8; font-size: 12px; text-transform: uppercase; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .table-eval td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 14px; vertical-align: middle; }
    
    .badge { padding: 5px 10px; border-radius: 6px; font-size: 11px; font-weight: 800; text-transform: uppercase; }
    .b-fav { background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16,185,129,0.3); }
    .b-res { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); }
    .b-def { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }

    /* Style du modal de confirmation */
    #deleteModal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 9999; justify-content: center; align-items: center; backdrop-filter: blur(5px); }
    .modal-content { background: var(--bg-dark); border: 1px solid rgba(239, 68, 68, 0.4); border-top: 4px solid #ef4444; padding: 40px; border-radius: 12px; text-align: center; max-width: 450px; animation: fadeUp 0.3s ease-out; }
</style>

<div id="evaluations-container">
    <div class="header-actions">
        <div>
            <h1 style="color: var(--primary); margin: 0; text-transform: uppercase; font-weight: 900;">Archives Évaluations</h1>
        </div>
        
        <div style="display: flex; gap: 15px;">
            <% if (user.isAdmin) { %>
                <button onclick="ouvrirModalSuppression()" class="btn-action btn-danger">
                    <i class="fas fa-trash-alt"></i> TOUT SUPPRIMER
                </button>
            <% } %>
            <a href="/superviseur" class="btn-action"><i class="fas fa-arrow-left"></i> RETOUR HUB</a>
        </div>
    </div>

    <div class="panel-box">
        <table class="table-eval">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Junior Évalué</th>
                    <th>Évaluateur</th>
                    <th>Avis</th>
                    <th>Statut</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (!rapports || rapports.length === 0) { %>
                    <tr><td colspan="6" style="text-align: center; color: #94a3b8; padding: 40px;">Aucun rapport d'évaluation trouvé.</td></tr>
                <% } else { %>
                    <% rapports.forEach(rapport => { %>
                        <tr>
                            <td style="color: #cbd5e1; font-family: monospace;"><%= new Date(rapport.dateCreation).toLocaleDateString('fr-FR') %></td>
                            <td style="font-weight: bold; color: #fff;">[<%= rapport.matriculeJunior %>] <%= rapport.nomJunior %></td>
                            <td style="color: var(--primary);"><%= rapport.nomEvaluateur %></td>
                            <td>
                                <% 
                                let bClass = 'b-res'; 
                                if(rapport.avis === 'Favorable') bClass = 'b-fav'; 
                                if(rapport.avis === 'Défavorable') bClass = 'b-def'; 
                                %>
                                <span class="badge <%= bClass %>"><%= rapport.avis || 'Réservé' %></span>
                            </td>
                            <td style="color: #94a3b8; font-size: 13px;"><%= rapport.statut === 'valide' ? '✅ Traité' : '⏳ Attente' %></td>
                            <td><a href="/superviseur/rapport/<%= rapport._id %>" class="btn-action" style="padding: 6px 12px; font-size: 11px;"><i class="fas fa-eye"></i> Lire</a></td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal de confirmation de suppression globale -->
<div id="deleteModal">
    <div class="modal-content">
        <i class="fas fa-exclamation-triangle" style="font-size: 50px; color: #ef4444; margin-bottom: 20px;"></i>
        <h2 style="color: #fff; margin-top: 0;">Danger Zone</h2>
        <p style="color: #94a3b8; font-size: 15px; margin-bottom: 30px; line-height: 1.5;">
            Vous êtes sur le point de supprimer définitivement <strong>toutes les évaluations</strong> enregistrées. Cette action est irréversible. Êtes-vous sûr ?
        </p>
        
        <form action="/superviseur/evaluations/supprimer-tout" method="POST" style="display: flex; gap: 15px; justify-content: center;">
            <button type="button" onclick="fermerModalSuppression()" class="btn-action">Annuler</button>
            <button type="submit" class="btn-action btn-danger">Oui, tout supprimer</button>
        </form>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();

    // Gestion du modal
    function ouvrirModalSuppression() {
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function fermerModalSuppression() {
        document.getElementById('deleteModal').style.display = 'none';
    }

    // On écoute le signal "nouvelle-evaluation" venant du serveur
    socket.on('nouvelle-evaluation', (rapport) => {
        const tbody = document.querySelector('.table-eval tbody');
        
        if (tbody.innerHTML.includes('Aucun rapport')) {
            tbody.innerHTML = '';
        }

        const dateFr = new Date(rapport.dateCreation).toLocaleDateString('fr-FR');
        
        let bClass = 'b-res';
        if(rapport.avis === 'Favorable') bClass = 'b-fav';
        if(rapport.avis === 'Défavorable') bClass = 'b-def';
        
        const statutTxt = rapport.statut === 'valide' ? '✅ Traité' : '⏳ Attente';

        const tr = document.createElement('tr');
        tr.style.animation = 'fadeUp 0.4s ease-out';
        tr.innerHTML = `
            <td style="color: #cbd5e1; font-family: monospace;">${dateFr}</td>
            <td style="font-weight: bold; color: #fff;">[${rapport.matriculeJunior}] ${rapport.nomJunior}</td>
            <td style="color: var(--primary);">${rapport.nomEvaluateur}</td>
            <td><span class="badge ${bClass}">${rapport.avis || 'Réservé'}</span></td>
            <td style="color: #94a3b8; font-size: 13px;">${statutTxt}</td>
            <td><a href="/superviseur/rapport/${rapport._id}" class="btn-action" style="padding: 6px 12px; font-size: 11px;"><i class="fas fa-eye"></i> Lire</a></td>
        `;
        
        tbody.insertBefore(tr, tbody.firstChild);
    });
</script>