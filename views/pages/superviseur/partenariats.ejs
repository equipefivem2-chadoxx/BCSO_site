<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<style>
    body { background-color: #07090e; font-family: 'Montserrat', sans-serif; color: #e2e8f0; margin: 0; }
    .page-container { margin-left: 280px; padding: 50px 60px; max-width: 1400px; animation: fadeUp 0.4s ease-out; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

    .header-section { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(189, 165, 129, 0.2); padding-bottom: 20px; margin-bottom: 35px; }
    h1 { color: #bda581; margin: 0; text-transform: uppercase; font-weight: 900; font-size: 28px; }
    .btn-back { background: rgba(255,255,255,0.05); color: #fff; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-size: 14px; border: 1px solid rgba(255,255,255,0.1); transition: 0.3s; }
    .btn-back:hover { background: rgba(255,255,255,0.1); }

    .grid-ent { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 25px; }
    
    /* Design amélioré pour les cartes */
    .ent-card { 
        background: linear-gradient(145deg, rgba(15, 23, 42, 0.6) 0%, rgba(15, 23, 42, 0.2) 100%);
        border: 1px solid rgba(255,255,255,0.05); 
        border-top: 4px solid #bda581; 
        padding: 30px 25px; 
        border-radius: 12px; 
        text-decoration: none; 
        color: #fff; 
        transition: all 0.3s ease; 
        display: flex; 
        flex-direction: column; 
        gap: 15px; 
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    .ent-card:hover { 
        background: linear-gradient(145deg, rgba(15, 23, 42, 0.9) 0%, rgba(15, 23, 42, 0.4) 100%);
        transform: translateY(-5px); 
        border-color: rgba(189, 165, 129, 0.5); 
        box-shadow: 0 10px 15px rgba(0, 0, 0, 0.2);
    }
    
    .ent-header { display: flex; align-items: center; gap: 15px; }
    .ent-icon { background: rgba(189, 165, 129, 0.1); color: #bda581; padding: 15px; border-radius: 10px; font-size: 20px; }
    .ent-nom { font-size: 20px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: #fff; margin: 0; }
    
    .ent-passages { background: rgba(0, 0, 0, 0.3); padding: 10px 15px; border-radius: 8px; font-family: monospace; color: #94a3b8; font-size: 14px; border: 1px solid rgba(255,255,255,0.02); }
    .ent-passages strong { color: #bda581; font-size: 16px; }
    
    .ent-footer { margin-top: auto; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.05); font-size: 13px; color: #bda581; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; }
    .ent-card:hover .ent-footer i { transform: translateX(5px); transition: 0.3s; }
</style>

<div class="page-container">
    <div class="header-section">
        <div>
            <h1>Partenariats Entreprises</h1>
            <p style="color: #94a3b8; margin-top: 5px;">Suivi des contrats et des patrouilles</p>
        </div>
        <a href="/superviseur" class="btn-back"><i class="fas fa-arrow-left"></i> Retour Dashboard</a>
    </div>

    <div class="grid-ent">
        <% if (entreprises.length === 0) { %>
            <p style="color: #64748b; font-style: italic; grid-column: 1 / -1; text-align: center; padding: 40px; background: rgba(15,23,42,0.4); border-radius: 10px;">Aucun partenariat enregistré pour le moment.</p>
        <% } else { %>
            <% entreprises.forEach(ent => { %>
                <!-- Création d'une variable pour savoir si c'est un garage -->
                <% const isGarage = ent.identifiant.toLowerCase().includes('manono') || ent.identifiant.toLowerCase().includes('garage'); %>
                
                <a href="/superviseur/partenariats/<%= ent._id %>" class="ent-card">
                    <div class="ent-header">
                        <!-- Icône dynamique selon si c'est un garage ou autre -->
                        <div class="ent-icon">
                            <i class="fas <%= isGarage ? 'fa-wrench' : 'fa-building' %>"></i>
                        </div>
                        <h2 class="ent-nom"><%= ent.nom %></h2>
                    </div>
                    
                    <!-- Affichage du compteur UNIQUEMENT pour les garages -->
                    <% if (isGarage) { %>
                        <div class="ent-passages">Passages comptabilisés : <strong><%= ent.totalPassages || 0 %></strong></div>
                    <% } %>

                    <div class="ent-footer">
                        Ouvrir le dossier <i class="fas fa-arrow-right"></i>
                    </div>
                </a>
            <% }) %>
        <% } %>
    </div>
</div>