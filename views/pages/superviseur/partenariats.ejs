<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<style>
    body { background-color: #07090e; font-family: 'Montserrat', sans-serif; color: #e2e8f0; margin: 0; }
    .page-container { margin-left: 280px; padding: 50px 60px; max-width: 1400px; animation: fadeUp 0.4s ease-out; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

    .header-section { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(189, 165, 129, 0.2); padding-bottom: 20px; margin-bottom: 35px; }
    h1 { color: #bda581; margin: 0; text-transform: uppercase; font-weight: 900; font-size: 28px; }
    .btn-back { background: rgba(255,255,255,0.05); color: #fff; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-size: 14px; border: 1px solid rgba(255,255,255,0.1); transition: 0.3s; }
    .btn-back:hover { background: rgba(255,255,255,0.1); }

    .grid-ent { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
    .ent-card { background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(255,255,255,0.05); border-left: 4px solid #bda581; padding: 25px; border-radius: 10px; text-decoration: none; color: #fff; transition: 0.3s; display: flex; flex-direction: column; gap: 10px; }
    .ent-card:hover { background: rgba(15, 23, 42, 0.8); transform: translateX(5px); border-color: rgba(189, 165, 129, 0.3); }
    
    .ent-nom { font-size: 20px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; color: #bda581; }
    .ent-passages { font-family: monospace; color: #94a3b8; font-size: 14px; }
</style>

<div class="page-container">
    <div class="header-section">
        <div>
            <h1>Partenariats Entreprises</h1>
            <p style="color: #94a3b8; margin-top: 5px;">Suivi des contrats et des patrouilles</p>
        </div>
        <a href="/superviseur" class="btn-back"><i class="fas fa-arrow-left"></i> Retour Dashboard</a>
    </div>

    <div class="grid-ent">
        <% if (entreprises.length === 0) { %>
            <p style="color: #64748b; font-style: italic;">Aucun partenariat enregistré pour le moment.</p>
        <% } else { %>
            <% entreprises.forEach(ent => { %>
                <a href="/superviseur/partenariats/<%= ent._id %>" class="ent-card">
                    <div class="ent-nom"><i class="fas fa-building"></i> <%= ent.nom %></div>
                    <div class="ent-passages">Passages comptabilisés : <strong><%= ent.totalPassages || 0 %></strong></div>
                    <div style="margin-top: 10px; font-size: 12px; color: #34d399;"><i class="fas fa-eye"></i> Voir le dossier complet</div>
                </a>
            <% }) %>
        <% } %>
    </div>
</div>