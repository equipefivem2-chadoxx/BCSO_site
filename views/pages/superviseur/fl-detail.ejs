<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --bg-card: rgba(15, 23, 42, 0.6);
        --bg-dark: #07090e;
        --text-main: #e2e8f0;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        font-family: 'Montserrat', sans-serif;
        color: var(--text-main);
    }

    #detail-container {
        margin-left: 280px;
        padding: 40px 60px 80px 60px;
        max-width: 1200px;
        animation: fadeIn 0.4s ease-out forwards;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 20px;
        margin-bottom: 40px;
    }

    .btn-back {
        background: rgba(189, 165, 129, 0.05);
        color: var(--primary);
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
        border: 1px solid rgba(189, 165, 129, 0.3);
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
    }

    .btn-back:hover { background: var(--primary); color: #000; }

    .content-box {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-top: 2px solid var(--primary);
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        margin-bottom: 30px;
    }

    .fl-title {
        color: #fff;
        font-size: 24px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 25px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 15px;
    }

    .meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
        background: rgba(0,0,0,0.3);
        padding: 20px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .meta-item { display: flex; flex-direction: column; gap: 5px; }
    .meta-label { color: var(--primary); font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
    .meta-value { color: #fff; font-size: 15px; font-weight: 600; }

    .table-eval {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 30px;
    }

    .table-eval th {
        background: rgba(0,0,0,0.3);
        color: #94a3b8;
        padding: 15px;
        text-align: left;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .table-eval td {
        padding: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        vertical-align: middle;
        font-size: 14px;
    }

    .badge-etat {
        padding: 6px 12px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 12px;
        display: inline-block;
    }

    .acquis { background: rgba(16, 185, 129, 0.2); color: #10b981; border: 1px solid #10b981; }
    .partiel { background: rgba(245, 158, 11, 0.2); color: #f59e0b; border: 1px solid #f59e0b; }
    .non-acquis { background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid #ef4444; }
    .neutre { background: rgba(148, 163, 184, 0.1); color: #94a3b8; border: 1px solid #94a3b8; }

    .desc-box {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 25px;
        border-radius: 8px;
        color: #e2e8f0;
        font-size: 15px;
        line-height: 1.6;
        white-space: pre-wrap;
        margin-bottom: 30px;
    }

    .actions-bar {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
    }

    .btn-action {
        padding: 12px 25px;
        border-radius: 8px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-validate { background: #10b981; color: #000; }
    .btn-validate:hover { background: #059669; box-shadow: 0 0 15px rgba(16, 185, 129, 0.4); }

    .btn-delete { background: #ef4444; color: #fff; }
    .btn-delete:hover { background: #dc2626; box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); }
</style>

<div id="detail-container">
    <div class="header-section">
        <a href="/superviseur" class="btn-back"><i class="fas fa-arrow-left"></i> RETOUR AU DASHBOARD</a>
    </div>

    <div class="content-box">
        <div class="fl-title">Grille d'évaluation : <%= fiche.matriculeAgentEvalue %> - <%= fiche.nomAgentEvalue %></div>

        <div class="meta-grid">
            <div class="meta-item">
                <span class="meta-label">Matricule + Prénom Nom :</span>
                <span class="meta-value"><%= fiche.matriculeAgentEvalue %> - <%= fiche.nomAgentEvalue %></span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Agent évaluateur :</span>
                <span class="meta-value"><%= fiche.nomEvaluateur %></span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Date passage :</span>
                <span class="meta-value"><%= fiche.datePassage %></span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Décision finale :</span>
                <% if (fiche.decision === 'Apte') { %>
                    <span class="meta-value" style="color: #10b981;">APTE À PASSER DEPUTY I</span>
                <% } else { %>
                    <span class="meta-value" style="color: #ef4444;">INAPTE</span>
                <% } %>
            </div>
        </div>

        <table class="table-eval">
            <thead>
                <tr>
                    <th style="width: 45%;">Compétence évaluée</th>
                    <th style="width: 20%;">État</th>
                    <th style="width: 35%;">Remarques</th>
                </tr>
            </thead>
            <tbody>
                <% if (fiche.criteres && fiche.criteres.length > 0) { %>
                    <% fiche.criteres.forEach(c => { %>
                        <tr>
                            <td style="font-weight: 600;"><%= c.nom %></td>
                            <td>
                                <% let badgeClass = 'neutre'; %>
                                <% if (c.etat === 'Acquis') badgeClass = 'acquis'; %>
                                <% if (c.etat === 'Partiellement acquis') badgeClass = 'partiel'; %>
                                <% if (c.etat === 'Non acquis') badgeClass = 'non-acquis'; %>
                                <span class="badge-etat <%= badgeClass %>"><%= c.etat %></span>
                            </td>
                            <td style="color: #cbd5e1;"><%= c.remarque || '-' %></td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>

        <span class="meta-label" style="display: block; margin-bottom: 10px;">Commentaire de l'agent évaluateur :</span>
        <div class="desc-box"><%= fiche.commentaireEvaluateur %></div>
    </div>

    <div class="actions-bar">
        <% if (fiche.statut === 'en_attente') { %>
            <form action="/superviseur/fl/<%= fiche._id %>/valider" method="POST">
                <button type="submit" class="btn-action btn-validate"><i class="fas fa-check"></i> MARQUER COMME TRAITÉE</button>
            </form>
        <% } %>

        <form action="/superviseur/fl/<%= fiche._id %>/supprimer" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement cette grille ?');">
            <button type="submit" class="btn-action btn-delete"><i class="fas fa-trash-alt"></i> SUPPRIMER</button>
        </form>
    </div>
</div>