<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --bg-card: rgba(15, 23, 42, 0.4);
        --bg-dark: #07090e;
        --text-main: #e2e8f0;
    }

    body { margin: 0; background-color: var(--bg-dark); font-family: 'Montserrat', sans-serif; color: var(--text-main); }
    #supervision-hub { margin-left: 280px; padding: 50px 60px; max-width: 1400px; animation: fadeUp 0.4s ease-out; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

    .page-header { border-bottom: 1px solid rgba(189, 165, 129, 0.2); padding-bottom: 20px; margin-bottom: 35px; }
    .page-header h1 { color: var(--primary); margin: 0; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 900; font-size: 28px; }

    .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 25px; margin-bottom: 40px;}
    
    .tool-card {
        background: var(--bg-card); border: 1px solid rgba(255,255,255,0.05); border-top: 3px solid var(--primary);
        border-radius: 12px; padding: 30px; text-decoration: none; color: #fff; transition: 0.3s;
        display: flex; flex-direction: column; align-items: flex-start; gap: 15px;
    }
    .tool-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(189, 165, 129, 0.15); border-color: rgba(189, 165, 129, 0.4); }
    .tool-icon { font-size: 35px; color: var(--primary); }
    .tool-title { font-size: 18px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
    .tool-desc { color: #94a3b8; font-size: 13px; line-height: 1.5; }

    .fl-list-container {
        background: var(--bg-card);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 30px;
        margin-top: 40px;
    }

    .fl-list-title {
        color: #fff;
        font-size: 20px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 20px;
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 10px;
    }

    .table-fl {
        width: 100%;
        border-collapse: collapse;
    }

    .table-fl th {
        background: rgba(0,0,0,0.3);
        color: #94a3b8;
        padding: 15px;
        text-align: left;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .table-fl td {
        padding: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        font-size: 14px;
        vertical-align: middle;
    }

    .btn-read {
        background: rgba(189, 165, 129, 0.1);
        color: var(--primary);
        padding: 6px 12px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 700;
        font-size: 12px;
        border: 1px solid rgba(189, 165, 129, 0.3);
        transition: 0.3s;
    }

    .btn-read:hover { background: var(--primary); color: #000; }
</style>

<div id="supervision-hub">
    <div class="page-header">
        <h1>Dashboard Superviseur</h1>
        <p style="color: #94a3b8; margin-top: 5px;">Outils de gestion et de suivi des effectifs</p>
    </div>

    <div class="tools-grid">
        <a href="/superviseur/evaluations" class="tool-card">
            <i class="fas fa-clipboard-check tool-icon"></i>
            <div class="tool-title">Évaluations Juniors</div>
            <div class="tool-desc">Consultez les rapports de période probatoire, validez les acquis et analysez les remarques des évaluateurs.</div>
            <div style="background: rgba(189,165,129,0.1); color: var(--primary); padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: bold; margin-top: 10px;">
                <%= typeof rapports !== 'undefined' && rapports ? rapports.filter(r => r.statut === 'en_attente').length : 0 %> en attente de lecture
            </div>
        </a>

        <a href="#section-recu-fl" class="tool-card" style="border-top-color: #3b82f6;">
            <i class="fas fa-file-signature tool-icon" style="color: #3b82f6;"></i>
            <div class="tool-title" style="color: #3b82f6;">Reçu FL</div>
            <div class="tool-desc">Consultez et validez les grilles d'évaluation de simulation (Simulation de Lincoln).</div>
            <div style="background: rgba(59, 130, 246, 0.1); color: #3b82f6; padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: bold; margin-top: 10px;">
                <%= typeof fichesLiaison !== 'undefined' ? fichesLiaison.length : 0 %> grilles reçues
            </div>
        </a>

        <a href="/superviseur/partenariats" class="tool-card">
            <i class="fas fa-handshake tool-icon"></i>
            <div class="tool-title">Partenariats Entreprises</div>
            <div class="tool-desc">Gérez les contrats externes (Manono, etc.).</div>
        </a>

        <a href="/superviseur/bannis" class="tool-card" style="border-top-color: #ef4444;">
            <i class="fas fa-ban tool-icon" style="color: #ef4444;"></i>
            <div class="tool-title" style="color: #ef4444;">Bannis du Nord</div>
            <div class="tool-desc">Gérez la liste noire du comté de Blaine (Ajout, modification, révocation d'interdiction de territoire).</div>
        </a>
    </div>

    <div class="fl-list-container" id="section-recu-fl">
        <div class="fl-list-title"><i class="fas fa-file-alt" style="color: var(--primary); margin-right: 10px;"></i> Reçu FL - Grilles en attente (<%= typeof fichesLiaison !== 'undefined' ? fichesLiaison.length : 0 %>)</div>
        
        <% if (typeof fichesLiaison !== 'undefined' && fichesLiaison.length > 0) { %>
            <table class="table-fl">
                <thead>
                    <tr>
                        <th>Date de soumission</th>
                        <th>Agent Évalué</th>
                        <th>Évaluateur</th>
                        <th>Décision</th>
                        <th style="text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% fichesLiaison.forEach(fl => { %>
                        <tr>
                            <td><%= new Date(fl.dateCreation).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' }) %></td>
                            <td style="font-weight: bold; color: var(--primary);"><%= fl.matriculeAgentEvalue %> - <%= fl.nomAgentEvalue %></td>
                            <td><%= fl.nomEvaluateur %></td>
                            <td>
                                <% if (fl.decision === 'Apte') { %>
                                    <span style="background: rgba(16, 185, 129, 0.2); color: #10b981; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold;">APTE</span>
                                <% } else { %>
                                    <span style="background: rgba(239, 68, 68, 0.2); color: #ef4444; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold;">INAPTE</span>
                                <% } %>
                            </td>
                            <td style="text-align: right;">
                                <a href="/superviseur/fl/<%= fl._id %>" class="btn-read"><i class="fas fa-eye"></i> CONSULTER</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <p style="color: #94a3b8; font-style: italic;">Aucune grille "Reçu FL" en attente de traitement.</p>
        <% } %>
    </div>
</div>