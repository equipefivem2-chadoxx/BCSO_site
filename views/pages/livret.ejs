                        </div>
                    </div>
                </div>

                <!-- ALERTE ROUGE -->
                <div class="alert-master-card theme-rouge">
                    <div class="alert-header">
                        <h3>Code Rouge</h3>
                        <p>Sécurité Publique Perturbée</p>
                    </div>
                    <div class="alert-details">
                        <div class="alert-data"><span>Durée Initiale</span><strong>01H00 à 48H00</strong></div>
                        <div class="alert-data"><span>Renouvellement</span><strong>01H00 à 48H00</strong></div>
                        <div class="alert-data"><span>Secteur / Zone</span><strong>Blaine County (Global)</strong></div>
                        <div class="alert-data"><span>Droits Policiers</span><strong>Palpation + Contrôle d'identité</strong></div>
                        <div class="alert-data full-width">
                            <span>Armement Autorisé</span>
                            <strong>Gilet Lourd sur soi, Armes lourdes dans le coffre</strong>
                            <span style="font-size: 0.65rem; margin-top:4px; opacity:0.7;">(Utilisation uniquement dans la zone concernée)</span>
                        </div>
                    </div>
                </div>

                <!-- ALERTE NOIRE -->
                <div class="alert-master-card theme-noir">
                    <div class="alert-header">
                        <h3>Code Noir</h3>
                        <p>Confinement Total</p>
                    </div>
                    <div class="alert-details">
                        <div class="alert-data"><span>Durée Initiale</span><strong>01H00 à 48H00</strong></div>
                        <div class="alert-data"><span>Renouvellement</span><strong>01H00 à 48H00</strong></div>
                        <div class="alert-data"><span>Secteur / Zone</span><strong>Blaine County (Global)</strong></div>
                        <div class="alert-data"><span>Droits Policiers</span><strong>Palpation + Contrôle Systématique</strong></div>
                        <div class="alert-data full-width">
                            <span>Armement Autorisé</span>
                            <strong>Gilet Lourd sur soi, Armes lourdes dans le coffre (Déploiement MAX)</strong>
                            <span style="font-size: 0.65rem; margin-top:4px; opacity:0.7;">(Utilisation active autorisée selon les règles d'engagement)</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </main>
</div>

<script>
    function openTab(tabId, buttonElement) {
        document.querySelectorAll('.nav-item').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.pane').forEach(pane => pane.classList.remove('active'));
        
        buttonElement.classList.add('active');
        document.getElementById(tabId).classList.add('active');
    }
</script>

