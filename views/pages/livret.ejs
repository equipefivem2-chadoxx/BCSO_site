                        <div class="alert-data"><span>Secteur / Zone</span><strong>Blaine County (Global)</strong></div>
                        <div class="alert-data"><span>Droits Policiers</span><strong>Palpation + Contrôle Systématique Global</strong></div>
                        <div class="alert-data full-width">
                            <span>Armement Autorisé</span>
                            <strong>Gilet Lourd équipé, Armes lourdes en main (Déploiement MAX)</strong>
                            <span style="font-size: 0.7rem; margin-top:6px; opacity:0.8; display:block; font-weight: 500;">(Utilisation active autorisée selon les règles strictes d'engagement)</span>
                        </div>
                    </div>
                </div>
            </section>
        </article>

    </main>
</div>

<!-- LIGHTBOX MODAL (ZOOM MAP) -->
<div id="highwayModal" class="zoom-modal" onclick="closeZoomModal(event)">
    <button class="modal-close" onclick="closeZoomModal(event)" aria-label="Fermer"><i class="fas fa-times"></i></button>
    <div class="modal-container">
        <img id="zoomableHighwayImg" src="/images/roads.png" alt="Detailed Highways Map" onclick="event.stopPropagation()">
        <div class="zoom-instructions"><i class="fas fa-mouse"></i> Molette pour zoomer / Cliquez et glissez pour déplacer</div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // --- GESTION DES ONGLETS ---
        const navItems = document.querySelectorAll('.nav-item');
        const panes = document.querySelectorAll('.pane');
        const searchInput = document.getElementById('radioSearch');

        navItems.forEach(btn => {
            btn.addEventListener('click', () => {
                // Remove active classes
                navItems.forEach(nav => nav.classList.remove('active'));
                panes.forEach(pane => pane.classList.remove('active'));
                
                // Add active class to clicked
                btn.classList.add('active');
                const targetId = btn.getAttribute('data-target');
                document.getElementById(targetId).classList.add('active');
                
                // Reset search if leaving/entering codes pane
                if(searchInput) {
                    searchInput.value = '';
                    searchInput.dispatchEvent(new Event('input'));
                }
            });
        });

        // --- MOTEUR DE RECHERCHE ---
        if(searchInput) {
            searchInput.addEventListener('input', (e) => {
                const query = e.target.value.toLowerCase().trim();
                const listItems = document.querySelectorAll('.search-list li');
                
                listItems.forEach(item => {
                    const text = item.textContent.toLowerCase();
                    item.classList.toggle('hidden', query !== '' && !text.includes(query));
                });
            });
        }
    });

    // --- LOGIQUE DE ZOOM MODAL ---
    const modal = document.getElementById('highwayModal');
    const img = document.getElementById('zoomableHighwayImg');
    let scale = 1;
    let isDragging = false;
    let startX, startY, translateX = 0, translateY = 0;

    function openZoomModal() {
        if(modal) {
            modal.classList.add('active');
            scale = 1; translateX = 0; translateY = 0;
            updateTransform();
        }
    }

    function closeZoomModal(e) {
        if (e && e.target !== modal && e.target.closest('.modal-close') === null) return;
        if(modal) modal.classList.remove('active');
    }

    function updateTransform() {
        if(img) img.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
    }

    if(img) {
        // Zoom avec la molette
        img.addEventListener('wheel', (e) => {
            e.preventDefault();
            const zoomFactor = 0.15;
            scale = e.deltaY < 0 ? Math.min(scale + zoomFactor, 4) : Math.max(scale - zoomFactor, 0.8);
            updateTransform();
        });

        // Drag & Drop
        img.addEventListener('mousedown', (e) => {
            isDragging = true;
            startX = e.clientX - translateX;
            startY = e.clientY - translateY;
            img.style.cursor = 'grabbing';
            img.style.transition = 'none'; // Désactive la transition fluide pendant le drag
        });

        window.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            translateX = e.clientX - startX;
            translateY = e.clientY - startY;
            updateTransform();
        });

        window.addEventListener('mouseup', () => {
            if (isDragging) {
                isDragging = false;
                img.style.cursor = 'grab';
                img.style.transition = 'transform 0.1s ease-out'; // Remet la transition
            }
        });
    }
</script>

</body>
</html>