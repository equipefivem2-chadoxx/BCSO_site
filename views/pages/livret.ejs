<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>BCSO - Livret d'informations</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;800;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #bda581;
            --primary-glow: rgba(189, 165, 129, 0.2);
            --bg-dark: #05070b;
            --bg-panel: rgba(11, 15, 25, 0.7);
            --text-main: #e2e8f0;
        }

        /* FOND IMMERSIF AVEC GRILLE TECHNOLOGIQUE */
        body {
            margin: 0; background-color: var(--bg-dark);
            background-image: 
                linear-gradient(rgba(189, 165, 129, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(189, 165, 129, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
            font-family: 'Montserrat', sans-serif; color: var(--text-main); min-height: 100vh;
            overflow-x: hidden;
        }

        * { box-sizing: border-box; }

        @keyframes slideInRight { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* STRUCTURE GLOBALE DU MANUEL */
        .manual-layout {
            display: flex;
            max-width: 1600px;
            margin: 30px auto;
            height: calc(100vh - 60px);
            gap: 30px;
            padding: 0 20px;
        }

        /* SIDEBAR DU LIVRET (SOMMAIRE) */
        .manual-sidebar {
            width: 320px;
            background: rgba(7, 9, 14, 0.85);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-right: 1px solid rgba(189, 165, 129, 0.2);
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

        .sidebar-header {
            padding: 30px 25px;
            background: linear-gradient(180deg, rgba(189, 165, 129, 0.1) 0%, transparent 100%);
            border-bottom: 1px solid rgba(255,255,255,0.02);
            position: relative;
        }

        .sidebar-header::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
        }

        .btn-back-hub {
            display: inline-flex; align-items: center; gap: 8px;
            color: #94a3b8; font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
            text-decoration: none; margin-bottom: 15px; transition: 0.3s;
        }
        .btn-back-hub:hover { color: var(--primary); }

        .manual-title { font-size: 22px; font-weight: 900; margin: 0; color: #fff; text-transform: uppercase; letter-spacing: 1px; line-height: 1.2; }
        .manual-title span { color: var(--primary); display: block; font-size: 14px; letter-spacing: 3px; margin-top: 5px; }

        .nav-list {
            padding: 20px 15px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .nav-item {
            background: transparent; border: 1px solid transparent; color: #94a3b8;
            padding: 15px 20px; border-radius: 12px; text-align: left; font-family: 'Montserrat', sans-serif;
            font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex; align-items: center; gap: 15px;
        }

        .nav-item i { font-size: 1.1rem; transition: 0.3s; }
        .nav-item:hover { background: rgba(255,255,255,0.02); color: #fff; transform: translateX(5px); }
        .nav-item.active {
            background: linear-gradient(90deg, rgba(189, 165, 129, 0.15) 0%, transparent 100%);
            color: var(--primary);
            border-left: 4px solid var(--primary);
            border-radius: 4px 12px 12px 4px;
        }
        .nav-item.active i { filter: drop-shadow(0 0 8px var(--primary)); }

        /* ZONE DE CONTENU PRINCIPALE */
        .manual-content {
            flex-grow: 1;
            background: var(--bg-panel);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-top: 1px solid rgba(189, 165, 129, 0.15);
            border-radius: 20px;
            padding: 50px;
            overflow-y: auto;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            position: relative;
        }

        /* Scrollbar custom pour le contenu */
        .manual-content::-webkit-scrollbar { width: 8px; }
        .manual-content::-webkit-scrollbar-thumb { background: rgba(189, 165, 129, 0.3); border-radius: 10px; }

        .pane { display: none; animation: slideInRight 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .pane.active { display: block; }

        .pane-header { margin-bottom: 40px; padding-bottom: 20px; border-bottom: 1px solid rgba(189, 165, 129, 0.1); }
        .pane-title { font-size: 32px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 2px; margin: 0; }
        .pane-title i { color: var(--primary); margin-right: 15px; }
        .pane-desc { color: #94a3b8; font-size: 1rem; margin-top: 10px; font-weight: 500; }

        /* UTILITAIRES DE GRILLES */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; }
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
        @media (max-width: 1200px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 900px) { .grid-3 { grid-template-columns: 1fr; } .grid-2 { grid-template-columns: 1fr; } .manual-layout { flex-direction: column; } .manual-sidebar { width: 100%; height: auto; flex-shrink: 0; } }

        /* =========================================
           DESIGN SPECIFIQUE DES SECTIONS
        ========================================= */

        /* Hiérarchie & Infos basiques */
        .info-card { background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 25px; transition: 0.3s; position: relative; overflow: hidden; }
        .info-card:hover { border-color: rgba(189, 165, 129, 0.3); transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.3); }
        .info-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--primary); }
        
        .styled-list { list-style: none; padding: 0; margin: 0; }
        .styled-list li { padding: 12px 0; border-bottom: 1px dashed rgba(255,255,255,0.05); font-size: 0.9rem; color: #cbd5e1; display: flex; align-items: flex-start; gap: 15px; }
        .styled-list li:last-child { border: none; padding-bottom: 0; }
        .code-badge { background: rgba(189, 165, 129, 0.1); color: var(--primary); font-weight: 800; padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; text-transform: uppercase; white-space: nowrap; border: 1px solid rgba(189, 165, 129, 0.2); }

        /* Spécialisations */
        .spec-box { text-align: center; padding: 30px 20px; background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, transparent 100%); border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); transition: 0.4s; }
        .spec-box:hover { background: linear-gradient(180deg, rgba(189,165,129,0.08) 0%, transparent 100%); border-color: var(--primary); transform: scale(1.02); }
        .spec-title { font-weight: 900; color: #fff; font-size: 1.1rem; text-transform: uppercase; margin-bottom: 5px; }
        .spec-sub { color: var(--primary); font-size: 0.7rem; font-weight: 800; letter-spacing: 2px; margin-bottom: 15px; }
        .spec-desc { font-size: 0.85rem; color: #94a3b8; line-height: 1.6; }

        /* CEVITAL */
        .cevital-item { display: flex; gap: 20px; background: rgba(0,0,0,0.3); padding: 20px; border-radius: 12px; margin-bottom: 15px; border-left: 1px solid rgba(255,255,255,0.05); transition: 0.3s; }
        .cevital-item:hover { border-left: 3px solid #ef4444; background: rgba(239, 68, 68, 0.05); transform: translateX(10px); }
        .cevital-letter { font-size: 2.5rem; font-weight: 900; color: #ef4444; line-height: 1; text-shadow: 0 0 15px rgba(239, 68, 68, 0.4); }
        .cevital-content h4 { margin: 0 0 5px 0; color: #fff; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
        .cevital-content p { margin: 0; color: #94a3b8; font-size: 0.9rem; line-height: 1.5; }

        /* Encadrés Images (10-20 & Protocoles) */
        .image-card { position: relative; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); height: 300px; display: flex; align-items: flex-end; background: #000; }
        .image-card img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.6; transition: 0.5s; }
        .image-card:hover img { opacity: 0.9; transform: scale(1.05); }
        .image-overlay { position: relative; z-index: 2; width: 100%; padding: 30px; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%); }
        .image-overlay h3 { margin: 0; color: #fff; font-size: 1.5rem; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; text-shadow: 0 2px 10px #000; }

        /* LES NIVEAUX D'ALERTES MASTERCLASS */
        .alerts-grid { display: flex; flex-direction: column; gap: 30px; }
        
        .alert-master-card {
            border-radius: 20px;
            padding: 40px;
            display: grid;
            grid-template-columns: 250px 1fr;
            gap: 40px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .alert-master-card::after {
            content: ''; position: absolute; top: -50%; right: -20%; width: 400px; height: 200%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
            transform: rotate(35deg);
        }

        .alert-header { display: flex; flex-direction: column; justify-content: center; border-right: 1px solid rgba(255,255,255,0.1); padding-right: 30px; }
        .alert-header h3 { font-size: 2.5rem; font-weight: 900; margin: 0; line-height: 1; text-transform: uppercase; }
        .alert-header p { margin: 10px 0 0 0; font-weight: 700; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }

        .alert-details { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .alert-data { background: rgba(0,0,0,0.3); padding: 15px 20px; border-radius: 12px; }
        .alert-data span { display: block; color: rgba(255,255,255,0.5); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 5px; letter-spacing: 1px; }
        .alert-data strong { display: block; color: #fff; font-size: 1rem; font-weight: 700; }
        .alert-data.full-width { grid-column: 1 / -1; }

        /* THEMES DES ALERTES */
        .theme-orange { background: radial-gradient(circle at 100% 0%, rgba(234, 88, 12, 0.2) 0%, rgba(15, 23, 42, 0.9) 100%); border-color: rgba(234, 88, 12, 0.3); }
        .theme-orange .alert-header h3 { color: #ea580c; text-shadow: 0 0 20px rgba(234, 88, 12, 0.4); }
        .theme-orange .alert-header p { color: #fdba74; }

        .theme-rouge { background: radial-gradient(circle at 100% 0%, rgba(220, 38, 38, 0.2) 0%, rgba(15, 23, 42, 0.9) 100%); border-color: rgba(220, 38, 38, 0.3); }
        .theme-rouge .alert-header h3 { color: #dc2626; text-shadow: 0 0 20px rgba(220, 38, 38, 0.4); }
        .theme-rouge .alert-header p { color: #fca5a5; }

        .theme-noir { background: radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.1) 0%, rgba(5, 7, 11, 0.95) 100%); border-color: rgba(255, 255, 255, 0.15); }
        .theme-noir .alert-header h3 { color: #f8fafc; text-shadow: 0 0 20px rgba(255, 255, 255, 0.2); }
        .theme-noir .alert-header p { color: #94a3b8; }
        
        @media (max-width: 900px) { .alert-master-card { grid-template-columns: 1fr; } .alert-header { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); padding-right: 0; padding-bottom: 20px; text-align: center; } .alert-details { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

<div class="manual-layout">
    
    <!-- MENU LATÉRAL -->
    <aside class="manual-sidebar">
        <div class="sidebar-header">
            <a href="/documents" class="btn-back-hub"><i class="fas fa-chevron-left"></i> Hub Documentaire</a>
            <h1 class="manual-title">Livret<span>BCSO V2.0</span></h1>
        </div>
        <nav class="nav-list">
            <button class="nav-item active" onclick="openTab('hierarchie', this)"><i class="fas fa-sitemap"></i> Hiérarchie & Grades</button>
            <button class="nav-item" onclick="openTab('anciennete', this)"><i class="fas fa-medal"></i> Ancienneté</button>
            <button class="nav-item" onclick="openTab('specialisations', this)"><i class="fas fa-star"></i> Spécialisations</button>
            <button class="nav-item" onclick="openTab('codes', this)"><i class="fas fa-walkie-talkie"></i> Transmissions Radio</button>
            <button class="nav-item" onclick="openTab('positions', this)"><i class="fas fa-map-location-dot"></i> 10-20 & Positions</button>
            <button class="nav-item" onclick="openTab('protocoles', this)"><i class="fas fa-handcuffs"></i> Protocoles d'Action</button>
            <button class="nav-item" onclick="openTab('cevital', this)"><i class="fas fa-crosshairs"></i> ISTC & CEVITAL</button>
            <button class="nav-item" onclick="openTab('alertes', this)"><i class="fas fa-triangle-exclamation"></i> Niveaux d'Alertes</button>
        </nav>
    </aside>

    <!-- CONTENU DYNAMIQUE -->
    <main class="manual-content">
        
        <!-- PANE: HIERARCHIE -->
        <div id="hierarchie" class="pane active">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-sitemap"></i> Hiérarchie du Département</h2>
                <p class="pane-desc">Chaîne de commandement officielle du Blaine County Sheriff's Office.</p>
            </div>
            <div class="grid-3">
                <div class="info-card" style="border-left-color: #f59e0b;">
                    <h3 style="color: #f59e0b; margin-top:0; font-weight:800;"><i class="fas fa-crown"></i> Command Staff</h3>
                    <ul class="styled-list">
                        <li><span class="code-badge">Sheriff</span> Responsable absolu du département</li>
                        <li><span class="code-badge">Lieutenant</span> Bras droit, gestion globale</li>
                    </ul>
                </div>
                <div class="info-card" style="border-left-color: #38bdf8;">
                    <h3 style="color: #38bdf8; margin-top:0; font-weight:800;"><i class="fas fa-user-shield"></i> Supervision</h3>
                    <ul class="styled-list">
                        <li><span class="code-badge">Sergeant II</span> Superviseur senior</li>
                        <li><span class="code-badge">Sergeant I</span> Superviseur d'équipe</li>
                    </ul>
                </div>
                <div class="info-card" style="border-left-color: #10b981;">
                    <h3 style="color: #10b981; margin-top:0; font-weight:800;"><i class="fas fa-users"></i> Corps d'Application</h3>
                    <ul class="styled-list">
                        <li><span class="code-badge">Dep III+1</span> Senior Lead Officer (SLO)</li>
                        <li><span class="code-badge">Deputy III</span> Agent Expérimenté</li>
                        <li><span class="code-badge">Deputy II</span> Agent Titulaire</li>
                        <li><span class="code-badge">Deputy I</span> Agent Confirmé</li>
                        <li><span class="code-badge">Dep. Junior</span> Période probatoire</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- PANE: ANCIENNETE -->
        <div id="anciennete" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-medal"></i> Distinctions d'Ancienneté</h2>
                <p class="pane-desc">Lecture des barrettes présentes sur les manches de l'uniforme Classe A.</p>
            </div>
            <div class="info-card" style="max-width: 600px;">
                <ul class="styled-list" style="font-size: 1.1rem;">
                    <li><span class="code-badge" style="width:100px; text-align:center;">1 Barrette</span> 2 Mois de service ininterrompu</li>
                    <li><span class="code-badge" style="width:100px; text-align:center;">2 Barrettes</span> 4 Mois de service ininterrompu</li>
                    <li><span class="code-badge" style="width:100px; text-align:center;">3 Barrettes</span> 6 Mois de service ininterrompu</li>
                    <li><span class="code-badge" style="width:100px; text-align:center;">4 Barrettes</span> 8 Mois de service ininterrompu</li>
                    <li><span class="code-badge" style="width:100px; text-align:center;">5 Barrettes</span> 10 Mois de service ininterrompu</li>
                    <li><span class="code-badge" style="width:100px; text-align:center;">6 Barrettes</span> 1 An de service et plus</li>
                </ul>
            </div>
        </div>

        <!-- PANE: SPECIALISATIONS -->
        <div id="specialisations" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-star"></i> Spécialisations & Divisions</h2>
                <p class="pane-desc">Les différentes unités spécialisées composant les forces du BCSO.</p>
            </div>
            <div class="grid-4">
                <div class="spec-box"><div class="spec-title">Academy</div><div class="spec-sub">Sheriff Dept.</div><div class="spec-desc">Recrutement, formation et suivi des effectifs.</div></div>
                <div class="spec-box"><div class="spec-title">M.R.D</div><div class="spec-sub">Media Relations</div><div class="spec-desc">Promotion de l'image de la police via réseaux et presse.</div></div>
                <div class="spec-box" style="border-color: #fcd34d;"><div class="spec-title" style="color: #fcd34d;">Traffic</div><div class="spec-sub">Division</div><div class="spec-desc">Unités spéciales terrestre, maritime et aérienne.</div></div>
                <div class="spec-box"><div class="spec-title">Highway Patrol</div><div class="spec-sub">Unité Autoroutière</div><div class="spec-desc">Surveillance du réseau rapide et gestion des accidents.</div></div>
                
                <div class="spec-box"><div class="spec-title">Air Support</div><div class="spec-sub">A.S.D</div><div class="spec-desc">Soutien aérien, poursuites, vols et surveillance de masse.</div></div>
                <div class="spec-box"><div class="spec-title">Mary</div><div class="spec-sub">Moto Patrol</div><div class="spec-desc">Interventions rapides et précises. Deux roues, une mission.</div></div>
                <div class="spec-box" style="border-color: #fcd34d;"><div class="spec-title" style="color: #fcd34d;">Major Crime</div><div class="spec-sub">Division</div><div class="spec-desc">Lutte anti-terroriste, blanchiment et grand banditisme.</div></div>
                <div class="spec-box"><div class="spec-title">Detective</div><div class="spec-sub">Bureau</div><div class="spec-desc">Enquêtes criminelles complexes et dossiers approfondis.</div></div>
                
                <div class="spec-box"><div class="spec-title">Gang Unit</div><div class="spec-sub">Unité Spéciale</div><div class="spec-desc">Démantèlement des réseaux criminels urbains.</div></div>
                <div class="spec-box"><div class="spec-title">Scientifique</div><div class="spec-sub">Investigation</div><div class="spec-desc">Analyse balistique, ADN, et investigations numériques.</div></div>
                <div class="spec-box" style="border-color: #fcd34d;"><div class="spec-title" style="color: #fcd34d;">Metropolitan</div><div class="spec-sub">Division</div><div class="spec-desc">Section d'élite pour la haute criminalité.</div></div>
                <div class="spec-box"><div class="spec-title">S.W.A.T</div><div class="spec-sub">Tactical Unit</div><div class="spec-desc">Interventions à très haut risque, otages, forcenés.</div></div>
                
                <div class="spec-box"><div class="spec-title">K-9</div><div class="spec-sub">Unité Canine</div><div class="spec-desc">Déploiement de maîtres-chiens pour pistage et neutralisation.</div></div>
                <div class="spec-box"><div class="spec-title">Bombsquad</div><div class="spec-sub">Démineurs</div><div class="spec-desc">Neutralisation d'explosifs et sécurisation de périmètres.</div></div>
            </div>
        </div>

        <!-- PANE: CODES RADIO -->
        <div id="codes" class="pane">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-walkie-talkie"></i> Transmissions & Codes</h2>
                <p class="pane-desc">Lexique obligatoire pour toute communication sur la fréquence interne.</p>
            </div>
            <div class="grid-3">
                <div class="info-card">
                    <h3 style="color:#fff; margin-top:0; font-weight:800; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:10px;">Codes Spécifiques</h3>
                    <ul class="styled-list">
                        <li><span class="code-badge">Code 2</span> Prioritaire (Gyro sans sirène)</li>
                        <li><span class="code-badge">Code 3</span> Urgent (Gyro + Sirène)</li>
                        <li><span class="code-badge">Code 4</span> Situation Stable</li>
                        <li><span class="code-badge">C-4 Adam</span> Perte de visuel</li>
                        <li><span class="code-badge">Code 5</span> Surveillance (Éviter la zone)</li>
                        <li><span class="code-badge">Code 6</span> Arrivée sur scène</li>
                        <li><span class="code-badge">Code 7</span> Retour en patrouille</li>
                        <li><span class="code-badge" style="background:#ef4444; color:#fff; border:none;">Code 99</span> Officier en danger !</li>
                        <li><span class="code-badge">Robert</span> Requête arme lourde</li>
                        <li><span class="code-badge">Sam</span> Requête fusil Beanbag</li>
                        <li><span class="code-badge">Sitrep</span> Rapport de situation</li>
                    </ul>
                </div>
                <div class="info-card">
                    <h3 style="color:#fff; margin-top:0; font-weight:800; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:10px;">Indicatifs d'Unités</h3>
                    <ul class="styled-list">
                        <li><span class="code-badge">Lincoln</span> Agent seul</li>
                        <li><span class="code-badge">Adam</span> Deux agents</li>
                        <li><span class="code">Tango</span> Trois agents</li>
                        <li><span class="code">X-Ray</span> Quatre agents</li>
                        <li><span class="code">K-9</span> Patrouille canine</li>
                        <li><span class="code">Queen</span> Escorte VIP</li>
                        <li><span class="code">Sierra</span> Highway Patrol</li>
                        <li><span class="code">Henry</span> A.S.D (Hélico)</li>
                        <li><span class="code">Bravo</span> Unité nautique</li>
                        <li><span class="code">Mary</span> Unité moto</li>
                        <li><span class="code">Victor</span> Unité vélo</li>
                        <li><span class="code">Oscar</span> Unité banalisée</li>
                        <li><span class="code">Echo</span> Unité S.R.T</li>
                    </ul>
                </div>
                <div class="info-card">
                    <h3 style="color:#fff; margin-top:0; font-weight:800; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:10px;">Codes 10 (Ten)</h3>
