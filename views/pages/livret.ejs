<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>BCSO - Livret d'informations</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;800;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #bda581;
            --primary-glow: rgba(189, 165, 129, 0.2);
            --bg-dark: #05070b;
            --bg-panel: rgba(11, 15, 25, 0.75);
            --text-main: #e2e8f0;
            --border-glow: rgba(189, 165, 129, 0.25);
            --success: #10b981;
            --info: #38bdf8;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        /* FOND IMMERSIF AVEC GRILLE TECHNOLOGIQUE */
        body {
            margin: 0;
            background-color: var(--bg-dark);
            background-image: 
                linear-gradient(rgba(189, 165, 129, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(189, 165, 129, 0.02) 1px, transparent 1px);
            background-size: 30px 30px;
            font-family: 'Montserrat', sans-serif; color: var(--text-main); min-height: 100vh;
            overflow-x: hidden;
        }

        * { box-sizing: border-box; }

        @keyframes slideInRight { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* STRUCTURE GLOBALE DU MANUEL CENTRÉE */
        .manual-layout {
            display: flex;
            max-width: 1650px;
            margin: 25px auto;
            height: calc(100vh - 50px);
            gap: 25px;
            padding: 0 20px;
            justify-content: center;
        }

        /* SIDEBAR DU LIVRET */
        .manual-sidebar {
            width: 340px;
            background: rgba(6, 9, 15, 0.85);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.02);
            border-right: 1px solid var(--border-glow);
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0,0,0,0.6);
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 25px;
            background: linear-gradient(180deg, rgba(189, 165, 129, 0.08) 0%, transparent 100%);
            border-bottom: 1px solid rgba(255,255,255,0.02);
            position: relative;
        }

        .sidebar-header::before {
            content: '';
            position: absolute; top: 0; left: 0; width: 100%; height: 3px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
        }

        .btn-back-hub {
            display: inline-flex;
            align-items: center; gap: 8px;
            color: #64748b; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;
            text-decoration: none; margin-bottom: 15px; transition: 0.3s;
            letter-spacing: 1px;
        }
        .btn-back-hub:hover { color: var(--primary); transform: translateX(-3px); }

        .manual-title { font-size: 24px; font-weight: 900; margin: 0; color: #fff; text-transform: uppercase;
            letter-spacing: 1px; line-height: 1.2; }
        .manual-title span { color: var(--primary); display: block;
            font-size: 13px; letter-spacing: 4px; margin-top: 4px; font-weight: 600; }

        .nav-list {
            padding: 20px 15px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            overflow-y: auto;
            flex-grow: 1;
        }

        .nav-item {
            background: transparent;
            border: 1px solid transparent; color: #94a3b8;
            padding: 14px 18px; border-radius: 10px; text-align: left; font-family: 'Montserrat', sans-serif;
            font-weight: 700; font-size: 0.8rem;
            text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; transition: all 0.25s ease;
            display: flex; align-items: center; gap: 12px;
        }

        .nav-item i { font-size: 1rem; color: #475569; transition: 0.3s; width: 20px; text-align: center; }
        .nav-item:hover { background: rgba(255,255,255,0.02); color: #fff; transform: translateX(4px); }
        .nav-item:hover i { color: #94a3b8; }
        
        .nav-item.active {
            background: linear-gradient(90deg, rgba(189, 165, 129, 0.12) 0%, rgba(189,165,129,0.01) 100%);
            color: var(--primary);
            border-left: 4px solid var(--primary);
            border-radius: 4px 10px 10px 4px;
            padding-left: 14px;
        }
        .nav-item.active i { color: var(--primary); filter: drop-shadow(0 0 6px var(--primary)); }

        /* ZONE DE CONTENU PRINCIPALE */
        .manual-content {
            flex-grow: 1;
            background: var(--bg-panel);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.02);
            border-top: 1px solid var(--border-glow);
            border-radius: 16px;
            padding: 45px;
            overflow-y: auto;
            box-shadow: 0 25px 60px rgba(0,0,0,0.5);
        }

        .manual-content::-webkit-scrollbar { width: 6px; }
        .manual-content::-webkit-scrollbar-thumb { background: rgba(189, 165, 129, 0.25); border-radius: 10px; }

        .pane { display: none; animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .pane.active { display: block; }

        .pane-header { margin-bottom: 35px; padding-bottom: 20px; border-bottom: 1px solid rgba(189, 165, 129, 0.1); }
        .pane-title { font-size: 28px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 1.5px; margin: 0; display: flex; align-items: center; gap: 15px; }
        .pane-title i { color: var(--primary); filter: drop-shadow(0 2px 8px rgba(189,165,129,0.3)); }
        .pane-desc { color: #94a3b8; font-size: 0.95rem; margin-top: 8px; font-weight: 500; }

        /* RECHERCHE RADIO */
        .search-wrapper {
            position: relative;
            margin-bottom: 25px;
            max-width: 500px;
        }
        .search-wrapper i {
            position: absolute;
            left: 16px; top: 50%; transform: translateY(-50%);
            color: #475569; font-size: 1rem; transition: 0.3s;
        }
        .search-input {
            width: 100%;
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 10px;
            padding: 14px 16px 14px 45px;
            color: #fff;
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.3s;
        }
        .search-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 15px rgba(189,165,129,0.15);
            background: rgba(0, 0, 0, 0.6);
        }
        .search-input:focus + i { color: var(--primary); }

        /* UTILITAIRES DE GRILLES */
        .grid-1 { display: grid; grid-template-columns: 1fr; gap: 25px; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; }
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }

        /* RE-DESIGN TRANSMISSIONS : CODES 10 EN DESSOUS SUR DEUX COLONNES */
        .codes-blocks-container {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }
        .ten-codes-grid-list {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0 40px;
        }

        /* HIERARCHIE */
        .tactical-hierarchy {
            display: flex;
            flex-direction: column;
            gap: 30px;
            width: 100%;
        }
        .hierarchy-section {
            background: rgba(10, 15, 30, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            padding: 25px;
            position: relative;
        }
        .hierarchy-section::before {
            content: '';
            position: absolute; left: 0; top: 25px; bottom: 25px; width: 4px; border-radius: 0 4px 4px 0;
        }
        .hierarchy-section.command::before { background: var(--warning); box-shadow: 0 0 15px var(--warning); }
        .hierarchy-section.supervision::before { background: var(--info); box-shadow: 0 0 15px var(--info); }
        .hierarchy-section.application::before { background: var(--success); box-shadow: 0 0 15px var(--success); }

        .section-class-title {
            font-size: 1.1rem;
            font-weight: 900; text-transform: uppercase; letter-spacing: 2px; margin: 0 0 20px 15px; display: flex; align-items: center; gap: 10px;
        }
        .hierarchy-section.command .section-class-title { color: var(--warning); }
        .hierarchy-section.supervision .section-class-title { color: var(--info); }
        .hierarchy-section.application .section-class-title { color: var(--success); }

        .ranks-grid-fluid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 15px;
            padding-left: 15px;
        }
        .rank-tactical-card {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255,255,255,0.02);
            border-radius: 8px;
            padding: 16px 20px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            transition: all 0.25s ease;
        }
        .rank-tactical-card:hover {
            background: rgba(255,255,255,0.02);
            border-color: rgba(189, 165, 129, 0.15);
            transform: translateY(-2px);
        }
        .rank-meta {
            display: flex;
            align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px; margin-bottom: 4px;
        }
        .rank-name { font-weight: 800; font-size: 0.95rem; color: #fff; letter-spacing: 0.5px; text-transform: uppercase; }
        .rank-label { font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;
            padding: 3px 8px; border-radius: 4px; background: rgba(255,255,255,0.05); color: #94a3b8; }
        
        .hierarchy-section.command .rank-label { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
        .hierarchy-section.supervision .rank-label { background: rgba(56, 189, 248, 0.1); color: var(--info); }
        .hierarchy-section.application .rank-label { background: rgba(16, 185, 129, 0.1); color: var(--success); }
        
        .rank-mission { font-size: 0.82rem; color: #94a3b8; line-height: 1.4; font-weight: 500; }

        /* ANCIENNETÉ */
        .medal-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 20px;
            width: 100%;
        }
        .medal-card {
            background: rgba(0,0,0,0.35);
            border: 1px solid rgba(255,255,255,0.04);
            border-radius: 12px;
            padding: 25px;
            text-align: center;
            transition: 0.3s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 180px;
        }
        .medal-card:hover {
            border-color: var(--primary);
            background: rgba(189, 165, 129, 0.03);
            transform: translateY(-3px);
        }
        .stripes-container {
            display: flex;
            gap: 5px;
            margin-bottom: 15px;
            background: rgba(0,0,0,0.5);
            padding: 8px 16px;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.03);
        }
        .stripe-bar {
            width: 6px;
            height: 22px;
            background: linear-gradient(180deg, #d4af37, #bfa030);
            border-radius: 1px;
            box-shadow: 0 0 8px rgba(212,175,55,0.4);
            transform: skewX(-15deg);
        }
        .medal-card h4 { margin: 0 0 6px 0; font-size: 1.05rem; font-weight: 800; color: #fff; text-transform: uppercase; }
        .medal-card p { margin: 0; font-size: 0.85rem; color: #94a3b8; font-weight: 500; }

        /* LISTES DE CODES & BADGES */
        .info-card { background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.04); border-radius: 12px; padding: 25px; transition: 0.3s; position: relative; overflow: hidden; }
        .info-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--primary); }
        
        .styled-list { list-style: none; padding: 0; margin: 0; }
        .styled-list li { padding: 12px 0; border-bottom: 1px dashed rgba(255,255,255,0.04); font-size: 0.88rem; color: #cbd5e1; display: flex; align-items: center; gap: 15px; transition: 0.2s; }
        .styled-list li:last-child { border: none; padding-bottom: 0; }
        .styled-list li.hidden { display: none !important; }
        .styled-list li:hover { background: rgba(255,255,255,0.01); padding-left: 5px; }

        .code-badge { background: rgba(189, 165, 129, 0.08); color: var(--primary); font-weight: 800; padding: 5px 12px; border-radius: 6px; font-size: 0.75rem; text-transform: uppercase; white-shadow: none; border: 1px solid rgba(189, 165, 129, 0.2); min-width: 85px; text-align: center; display: inline-block; }

        /* SPÉCIALISATIONS */
        .spec-box { text-align: center; padding: 25px 20px; background: rgba(0,0,0,0.2); border-radius: 12px; border: 1px solid rgba(255,255,255,0.04); transition: 0.3s; }
        .spec-box:hover { background: linear-gradient(180deg, rgba(189,165,129,0.06) 0%, transparent 100%); border-color: var(--primary); transform: translateY(-3px); }
        .spec-title { font-weight: 800; color: #fff; font-size: 1.05rem; text-transform: uppercase; margin-bottom: 4px; }
        .spec-sub { color: var(--primary); font-size: 0.7rem; font-weight: 800; letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; }
        .spec-desc { font-size: 0.82rem; color: #94a3b8; line-height: 1.5; font-weight: 500; }

        /* CEVITAL */
        .cevital-item { display: flex; gap: 20px; background: rgba(0,0,0,0.3); padding: 18px; border-radius: 10px; margin-bottom: 12px; border-left: 2px solid rgba(255,255,255,0.03); transition: 0.3s; }
        .cevital-item:hover { border-left-color: #ef4444; background: rgba(239, 68, 68, 0.04); transform: translateX(6px); }
        .cevital-letter { font-size: 2.2rem; font-weight: 900; color: #ef4444; line-height: 1; text-shadow: 0 0 15px rgba(239, 68, 68, 0.3); width: 30px; text-align: center; }
        .cevital-content h4 { margin: 0 0 4px 0; color: #fff; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.95rem; }
        .cevital-content p { margin: 0; color: #94a3b8; font-size: 0.85rem; line-height: 1.4; font-weight: 500; }

        /* IMAGES / CARTES MÉDIAS */
        .image-card { position: relative; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); height: 260px; display: flex; align-items: flex-end; background: #000; box-shadow: 0 15px 30px rgba(0,0,0,0.4); cursor: pointer; }
        .image-card img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5; transition: 0.5s ease; }
        .image-card:hover img { opacity: 0.8; transform: scale(1.03); }
        .image-overlay { position: relative; z-index: 2; width: 100%; padding: 25px; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 60%, transparent 100%); }
        .image-overlay h3 { margin: 0; color: #fff; font-size: 1.3rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1.5px; display: flex; align-items: center; justify-content: space-between; }
        .image-overlay h3 i { font-size: 1rem; color: var(--primary); opacity: 0.7; }

        /* MODAL DE ZOOM INTERACTIF POUR LES AUTOROUTES */
        .zoom-modal {
            display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(3, 5, 8, 0.95); backdrop-filter: blur(10px);
            justify-content: center; align-items: center; opacity: 0; transition: opacity 0.3s ease;
        }
        .zoom-modal.active { display: flex; opacity: 1; }
        .modal-container { position: relative; width: 90%; height: 90%; display: flex; justify-content: center; align-items: center; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; background: rgba(0,0,0,0.4); }
        .modal-container img { max-width: 100%; max-height: 100%; object-fit: contain; transition: transform 0.2s ease; cursor: grab; transform-origin: center center; }
        .modal-container img:active { cursor: grabbing; }
        .modal-close { position: absolute; top: 20px; right: 20px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; width: 45px; height: 45px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; justify-content: center; align-items: center; transition: 0.2s; z-index: 10; }
        .modal-close:hover { background: var(--danger); border-color: transparent; transform: scale(1.05); }
        .zoom-instructions { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.7); padding: 8px 18px; border-radius: 20px; font-size: 0.8rem; color: #94a3b8; font-weight: 600; letter-spacing: 0.5px; border: 1px solid rgba(255,255,255,0.05); pointer-events: none; }

        /* ALERTES */
        .alerts-grid { display: flex; flex-direction: column; gap: 25px; }
        .alert-master-card { border-radius: 16px; padding: 35px; display: grid; grid-template-columns: 240px 1fr; gap: 35px; position: relative; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05); }
        .alert-header { display: flex; flex-direction: column; justify-content: center; border-right: 1px solid rgba(255,255,255,0.08); padding-right: 25px; }
        .alert-header h3 { font-size: 2.2rem; font-weight: 900; margin: 0; line-height: 1; text-transform: uppercase; }
        .alert-header p { margin: 10px 0 0 0; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .alert-details { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .alert-data { background: rgba(0,0,0,0.35); padding: 12px 18px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.02); }
        .alert-data span { display: block; color: rgba(255,255,255,0.4); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-bottom: 4px; letter-spacing: 0.5px; }
        .alert-data strong { display: block; color: #fff; font-size: 0.95rem; font-weight: 700; }
        .alert-data.full-width { grid-column: 1 / -1; }

        .theme-orange { background: radial-gradient(circle at 100% 0%, rgba(234, 88, 12, 0.15) 0%, rgba(10, 15, 26, 0.95) 100%); border-color: rgba(234, 88, 12, 0.25); }
        .theme-orange .alert-header h3 { color: #ea580c; text-shadow: 0 0 20px rgba(234, 88, 12, 0.3); }
        .theme-orange .alert-header p { color: #fdba74; }
        .theme-rouge { background: radial-gradient(circle at 100% 0%, rgba(220, 38, 38, 0.15) 0%, rgba(10, 15, 26, 0.95) 100%); border-color: rgba(220, 38, 38, 0.25); }
        .theme-rouge .alert-header h3 { color: #dc2626; text-shadow: 0 0 20px rgba(220, 38, 38, 0.3); }
        .theme-rouge .alert-header p { color: #fca5a5; }
        .theme-noir { background: radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.08) 0%, rgba(5, 7, 11, 0.98) 100%); border-color: rgba(255, 255, 255, 0.1); }
        .theme-noir .alert-header h3 { color: #f8fafc; text-shadow: 0 0 20px rgba(255, 255, 255, 0.15); }
        .theme-noir .alert-header p { color: #94a3b8; }
        
        /* RESPONSIVE DESIGN */
        @media (max-width: 1200px) {
            .manual-layout { flex-direction: column; height: auto; }
            .manual-sidebar { width: 100%; height: auto; }
            .manual-content { height: auto; padding: 25px; }
            .alert-master-card { grid-template-columns: 1fr; gap: 20px; padding: 25px; }
            .alert-header { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); padding-right: 0; padding-bottom: 15px; text-align: center; }
            .grid-4 { grid-template-columns: repeat(2, 1fr); }
            .ten-codes-grid-list { grid-template-columns: 1fr; }
        }
        @media (max-width: 768px) {
            .grid-2, .grid-4, .alert-details { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<div class="manual-layout">
    
    <aside class="manual-sidebar">
        <div class="sidebar-header">
            <a href="/documents" class="btn-back-hub"><i class="fas fa-chevron-left"></i> Hub Documentaire</a>
            <h1 class="manual-title">Livret<span>BCSO V2.0</span></h1>
        </div>
        <nav class="nav-list">
            <button class="nav-item active" onclick="openTab('hierarchie', this)"><i class="fas fa-sitemap"></i> Hiérarchie & Grades</button>
            <button class="nav-item" onclick="openTab('anciennete', this)"><i class="fas fa-medal"></i> Ancienneté</button>
            <button class="nav-item" onclick="openTab('specialisations', this)"><i class="fas fa-star"></i> Spécialisations</button>
            <button class="nav-item" onclick="openTab('codes', this)"><i class="fas fa-walkie-talkie"></i> Transmissions Radio</button>
            <button class="nav-item" onclick="openTab('positions', this)"><i class="fas fa-map-location-dot"></i> 10-20 & Positions</button>
            <button class="nav-item" onclick="openTab('protocoles', this)"><i class="fas fa-handcuffs"></i> Protocoles d'Action</button>
            <button class="nav-item" onclick="openTab('cevital', this)"><i class="fas fa-crosshairs"></i> ISTC & CEVITAL</button>
            <button class="nav-item" onclick="openTab('alertes', this)"><i class="fas fa-triangle-exclamation"></i> Niveaux d'Alertes</button>
        </nav>
    </aside>

    <main class="manual-content">
        
        <div id="hierarchie" class="pane active">
            <div class="pane-header">
                <h2 class="pane-title"><i class="fas fa-sitemap"></i> Chaîne de Commandement</h2>
                <p class="pane-desc">Structure d'autorité opérationnelle et administrative officielle du Blaine County Sheriff's Office.</p>
            </div>
            
            <div class="tactical-hierarchy">
                <div class="hierarchy-section command">
                    <h3 class="section-class-title"><i class="fas fa-crown"></i> Command Staff</h3>
                    <div class="ranks-grid-fluid">
                        <div class="rank-tactical-card">
                            <div class="rank-meta"><span class="rank-name">Sheriff</span><span class="rank-label">Direction</span></div>
                            <span class="rank-mission">Responsable absolu, autorité suprême du département.</span>
                        </div>
                        <div class="rank-tactical-card">
                            <div class="rank-meta"><span class="rank-name">Lieutenant</span><span class="rank-label">Commandement</span></div>
                            <span class="rank-mission">Bras droit du Sheriff, superviseur de la gestion globale et opérationnelle.</span>
                        </div>
                    </div>
                </div>

                <div class="hierarchy-section supervision">
                    <h3 class="section-class-title"><i class="fas fa-user-shield"></i> Supervision Staff</h3>
