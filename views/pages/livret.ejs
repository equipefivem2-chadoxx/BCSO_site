<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BCSO - Livret d'informations Tactiques</title>
    <!-- Fonts & Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        /* =========================================
           VARIABLES GLOBALES
        ========================================= */
        :root {
            --primary: #bda581;
            --primary-glow: rgba(189, 165, 129, 0.2);
            --primary-hover: #cbb698;
            --bg-dark: #05070b;
            --bg-panel: rgba(11, 15, 25, 0.75);
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
            --border-glow: rgba(189, 165, 129, 0.25);
            --success: #10b981;
            --info: #38bdf8;
            --warning: #f59e0b;
            --danger: #ef4444;
            --transition-speed: 0.3s;
        }

        /* =========================================
           RESET & BASE
        ========================================= */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-dark);
            background-image: 
                linear-gradient(rgba(189, 165, 129, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(189, 165, 129, 0.02) 1px, transparent 1px);
            background-size: 30px 30px;
            font-family: 'Montserrat', sans-serif;
            color: var(--text-main);
            min-height: 100vh;
            overflow-x: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Animations */
        @keyframes slideInRight { 
            from { opacity: 0; transform: translateX(20px); } 
            to { opacity: 1; transform: translateX(0); } 
        }

        /* Scrollbar personnalisée */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.2); }
        ::-webkit-scrollbar-thumb { background: rgba(189, 165, 129, 0.3); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(189, 165, 129, 0.5); }

        /* =========================================
           LAYOUT PRINCIPAL
        ========================================= */
        .manual-layout {
            display: flex;
            width: 100%;
            max-width: 1650px;
            height: calc(100vh - 40px);
            gap: 25px;
            padding: 20px;
        }

        /* Sidebar */
        .manual-sidebar {
            width: 320px;
            background: rgba(6, 9, 15, 0.85);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-right: 1px solid var(--border-glow);
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 25px 50px rgba(0,0,0,0.6);
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 25px;
            background: linear-gradient(180deg, rgba(189, 165, 129, 0.08) 0%, transparent 100%);
            border-bottom: 1px solid rgba(255,255,255,0.02);
            border-radius: 16px 16px 0 0;
            position: relative;
        }

        .sidebar-header::before {
            content: '';
            position: absolute; top: 0; left: 0; width: 100%; height: 3px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
        }

        .btn-back-hub {
            display: inline-flex;
            align-items: center; gap: 8px;
            color: var(--text-muted); font-size: 0.75rem; font-weight: 800; 
            text-transform: uppercase; text-decoration: none; 
            margin-bottom: 15px; transition: var(--transition-speed);
            letter-spacing: 1px;
        }
        
        .btn-back-hub:hover { color: var(--primary); transform: translateX(-3px); }

        .manual-title { font-size: 24px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 1px; line-height: 1.2; }
        .manual-title span { color: var(--primary); display: block; font-size: 13px; letter-spacing: 4px; margin-top: 4px; font-weight: 600; }

        .nav-list {
            padding: 20px 15px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .nav-item {
            background: transparent;
            border: none; color: var(--text-muted);
            padding: 14px 18px; border-radius: 10px; text-align: left; 
            font-family: inherit; font-weight: 700; font-size: 0.85rem;
            text-transform: uppercase; letter-spacing: 1px;
            cursor: pointer; transition: all 0.25s ease;
            display: flex; align-items: center; gap: 12px;
        }

        .nav-item i { font-size: 1.1rem; color: #475569; transition: var(--transition-speed); width: 20px; text-align: center; }
        .nav-item:hover { background: rgba(255,255,255,0.02); color: #fff; transform: translateX(4px); }
        .nav-item:hover i { color: var(--text-muted); }
        
        .nav-item.active {
            background: linear-gradient(90deg, rgba(189, 165, 129, 0.12) 0%, transparent 100%);
            color: var(--primary);
            border-left: 4px solid var(--primary);
            border-radius: 4px 10px 10px 4px;
        }
        .nav-item.active i { color: var(--primary); filter: drop-shadow(0 0 6px var(--primary)); }

        /* Contenu principal */
        .manual-content {
            flex-grow: 1;
            background: var(--bg-panel);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-top: 1px solid var(--border-glow);
            border-radius: 16px;
            padding: 40px 45px;
            overflow-y: auto;
            box-shadow: 0 25px 60px rgba(0,0,0,0.5);
            position: relative;
        }

        .pane { display: none; animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .pane.active { display: block; }

        .pane-header { margin-bottom: 35px; padding-bottom: 20px; border-bottom: 1px solid rgba(189, 165, 129, 0.1); }
        .pane-title { font-size: 28px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 1.5px; display: flex; align-items: center; gap: 15px; }
        .pane-title i { color: var(--primary); filter: drop-shadow(0 2px 8px rgba(189,165,129,0.3)); }
        .pane-desc { color: var(--text-muted); font-size: 0.95rem; margin-top: 8px; font-weight: 500; }

        /* =========================================
           COMPOSANTS UI
        ========================================= */
        /* Grilles */
        .grid-1 { display: grid; grid-template-columns: 1fr; gap: 25px; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; }
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }

        /* Barre de recherche */
        .search-wrapper { position: relative; margin-bottom: 25px; max-width: 500px; }
        .search-wrapper i { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #475569; font-size: 1rem; transition: 0.3s; }
        .search-input {
            width: 100%; background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255,255,255,0.05);
            border-radius: 10px; padding: 14px 16px 14px 45px; color: #fff; font-family: inherit;
            font-weight: 600; font-size: 0.9rem; transition: 0.3s;
        }
        .search-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 15px rgba(189,165,129,0.15); background: rgba(0, 0, 0, 0.6); }
        .search-input:focus + i { color: var(--primary); }

        /* Cartes Hiérarchie */
        .tactical-hierarchy { display: flex; flex-direction: column; gap: 30px; }
        .hierarchy-section { background: rgba(10, 15, 30, 0.4); border: 1px solid rgba(255, 255, 255, 0.03); border-radius: 12px; padding: 25px; position: relative; }
        .hierarchy-section::before { content: ''; position: absolute; left: 0; top: 25px; bottom: 25px; width: 4px; border-radius: 0 4px 4px 0; }
        .hierarchy-section.command::before { background: var(--warning); box-shadow: 0 0 15px var(--warning); }
        .hierarchy-section.supervision::before { background: var(--info); box-shadow: 0 0 15px var(--info); }
        .hierarchy-section.application::before { background: var(--success); box-shadow: 0 0 15px var(--success); }

        .section-class-title { font-size: 1.1rem; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px; margin-left: 15px; display: flex; align-items: center; gap: 10px; }
        .hierarchy-section.command .section-class-title { color: var(--warning); }
        .hierarchy-section.supervision .section-class-title { color: var(--info); }
        .hierarchy-section.application .section-class-title { color: var(--success); }

        .ranks-grid-fluid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 15px; padding-left: 15px; }
        .rank-tactical-card {
            background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255,255,255,0.02);
            border-radius: 8px; padding: 16px 20px; display: flex; flex-direction: column; gap: 6px; transition: all 0.25s ease;
        }
        .rank-tactical-card:hover { background: rgba(255,255,255,0.02); border-color: rgba(189, 165, 129, 0.15); transform: translateY(-2px); }
        
        .rank-meta { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px; margin-bottom: 4px; }
        .rank-name { font-weight: 800; font-size: 0.95rem; color: #fff; text-transform: uppercase; }
        .rank-label { font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; padding: 3px 8px; border-radius: 4px; }
        
        .hierarchy-section.command .rank-label { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
        .hierarchy-section.supervision .rank-label { background: rgba(56, 189, 248, 0.1); color: var(--info); }
        .hierarchy-section.application .rank-label { background: rgba(16, 185, 129, 0.1); color: var(--success); }
        .rank-mission { font-size: 0.82rem; color: var(--text-muted); line-height: 1.4; font-weight: 500; }

        /* Ancienneté */
        .medal-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
        .medal-card {
            background: rgba(0,0,0,0.35); border: 1px solid rgba(255,255,255,0.04);
            border-radius: 12px; padding: 25px; text-align: center; transition: 0.3s ease;
            display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 180px;
        }
        .medal-card:hover { border-color: var(--primary); background: rgba(189, 165, 129, 0.03); transform: translateY(-3px); }
        .stripes-container { display: flex; gap: 5px; margin-bottom: 15px; background: rgba(0,0,0,0.5); padding: 8px 16px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.03); }
        .stripe-bar { width: 6px; height: 22px; background: linear-gradient(180deg, #d4af37, #bfa030); border-radius: 1px; box-shadow: 0 0 8px rgba(212,175,55,0.4); transform: skewX(-15deg); }
        .medal-card h4 { margin-bottom: 6px; font-size: 1.05rem; font-weight: 800; color: #fff; text-transform: uppercase; }
        .medal-card p { font-size: 0.85rem; color: var(--text-muted); font-weight: 500; }

        /* Spécialisations */
        .spec-box {
            text-align: center; padding: 25px 20px; background: rgba(0,0,0,0.2); 
            border-radius: 12px; border: 1px solid rgba(255,255,255,0.04); transition: var(--transition-speed); 
        }
        .spec-box:hover { background: linear-gradient(180deg, rgba(189,165,129,0.06) 0%, transparent 100%); border-color: var(--primary); transform: translateY(-3px); }
        .spec-title { font-weight: 800; color: #fff; font-size: 1.05rem; text-transform: uppercase; margin-bottom: 4px; }
        .spec-sub { color: var(--primary); font-size: 0.7rem; font-weight: 800; letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; }
        .spec-desc { font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; font-weight: 500; }
        
        .spec-highlight { border-color: rgba(252, 211, 77, 0.4); }
        .spec-highlight .spec-title { color: #fcd34d; }

        /* Listes de codes radio */
        .info-card { background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.04); border-radius: 12px; padding: 25px; transition: 0.3s; position: relative; overflow: hidden; }
        .info-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--primary); }
        .info-card-header { color: #fff; font-weight: 800; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 15px; margin-bottom: 15px; font-size: 1.1rem; }
        .info-card-header i { color: var(--primary); margin-right: 8px; }
        
        .styled-list { list-style: none; }
        .styled-list li { padding: 12px 0; border-bottom: 1px dashed rgba(255,255,255,0.04); font-size: 0.88rem; color: #cbd5e1; display: flex; align-items: center; gap: 15px; transition: 0.2s; }
        .styled-list li:last-child { border: none; padding-bottom: 0; }
        .styled-list li.hidden { display: none !important; }
        .styled-list li:hover { background: rgba(255,255,255,0.02); padding-left: 8px; border-radius: 4px;}
        
        .code-badge { background: rgba(189, 165, 129, 0.08); color: var(--primary); font-weight: 800; padding: 5px 12px; border-radius: 6px; font-size: 0.75rem; text-transform: uppercase; border: 1px solid rgba(189, 165, 129, 0.2); min-width: 85px; text-align: center; display: inline-block; }
        .code-critical { background: #ef4444; color: #fff; border: none; box-shadow: 0 0 10px rgba(239,68,68,0.3); }
        .code-warning { background: #ea580c; color: #fff; border: none; }

        /* Cartes d'images */
        .image-card { position: relative; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); height: 260px; display: flex; align-items: flex-end; background: #000; box-shadow: 0 15px 30px rgba(0,0,0,0.4); cursor: pointer; }
        .image-card img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5; transition: 0.5s ease; }
        .image-card:hover img { opacity: 0.8; transform: scale(1.03); }
        .image-overlay { position: relative; z-index: 2; width: 100%; padding: 25px; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 60%, transparent 100%); }
        .image-overlay h3 { margin: 0; color: #fff; font-size: 1.3rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1.5px; display: flex; align-items: center; justify-content: space-between; }
        .image-overlay h3 i { font-size: 1.1rem; color: var(--primary); opacity: 0.8; }

        /* CEVITAL */
        .cevital-item { display: flex; gap: 20px; background: rgba(0,0,0,0.3); padding: 18px; border-radius: 10px; margin-bottom: 12px; border-left: 2px solid rgba(255,255,255,0.03); transition: var(--transition-speed); }
        .cevital-item:hover { border-left-color: var(--danger); background: rgba(239, 68, 68, 0.05); transform: translateX(6px); }
        .cevital-letter { font-size: 2.2rem; font-weight: 900; color: var(--danger); line-height: 1; text-shadow: 0 0 15px rgba(239, 68, 68, 0.3); width: 30px; text-align: center; }
        .cevital-content h4 { margin-bottom: 4px; color: #fff; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.95rem; }
        .cevital-content p { color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; font-weight: 500; }

        /* Niveaux d'Alertes */
        .alerts-grid { display: flex; flex-direction: column; gap: 25px; }
        .alert-master-card { border-radius: 16px; padding: 35px; display: grid; grid-template-columns: 240px 1fr; gap: 35px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05); }
        .alert-header { display: flex; flex-direction: column; justify-content: center; border-right: 1px solid rgba(255,255,255,0.08); padding-right: 25px; }
        .alert-header h3 { font-size: 2.2rem; font-weight: 900; line-height: 1; text-transform: uppercase; }
        .alert-header p { margin-top: 10px; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .alert-details { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .alert-data { background: rgba(0,0,0,0.35); padding: 12px 18px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.02); }
        .alert-data span { display: block; color: rgba(255,255,255,0.4); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-bottom: 4px; letter-spacing: 0.5px; }
        .alert-data strong { display: block; color: #fff; font-size: 0.95rem; font-weight: 700; line-height: 1.3;}
        .alert-data.full-width { grid-column: 1 / -1; }

        .theme-orange { background: radial-gradient(circle at 100% 0%, rgba(234, 88, 12, 0.15) 0%, rgba(10, 15, 26, 0.95) 100%); border-color: rgba(234, 88, 12, 0.25); }
        .theme-orange .alert-header h3 { color: #ea580c; text-shadow: 0 0 20px rgba(234, 88, 12, 0.3); }
        .theme-orange .alert-header p { color: #fdba74; }
        
        .theme-rouge { background: radial-gradient(circle at 100% 0%, rgba(220, 38, 38, 0.15) 0%, rgba(10, 15, 26, 0.95) 100%); border-color: rgba(220, 38, 38, 0.25); }
        .theme-rouge .alert-header h3 { color: #dc2626; text-shadow: 0 0 20px rgba(220, 38, 38, 0.3); }
        .theme-rouge .alert-header p { color: #fca5a5; }
        
        .theme-noir { background: radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.08) 0%, rgba(5, 7, 11, 0.98) 100%); border-color: rgba(255, 255, 255, 0.1); }
        .theme-noir .alert-header h3 { color: #f8fafc; text-shadow: 0 0 20px rgba(255, 255, 255, 0.15); }
        .theme-noir .alert-header p { color: var(--text-muted); }

        /* Modal de zoom */
        .zoom-modal {
            display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; 
            background: rgba(3, 5, 8, 0.95); backdrop-filter: blur(10px); justify-content: center; 
            align-items: center; opacity: 0; transition: opacity 0.3s ease;
        }
        .zoom-modal.active { display: flex; opacity: 1; }
        .modal-container { position: relative; width: 90%; height: 90%; display: flex; justify-content: center; align-items: center; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; background: rgba(0,0,0,0.4); }
        .modal-container img { max-width: 100%; max-height: 100%; object-fit: contain; transition: transform 0.1s ease-out; cursor: grab; transform-origin: center center; }
        .modal-container img:active { cursor: grabbing; }
        .modal-close { position: absolute; top: 20px; right: 20px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; width: 45px; height: 45px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; justify-content: center; align-items: center; transition: 0.2s; z-index: 10; }
        .modal-close:hover { background: var(--danger); border-color: transparent; transform: scale(1.05); }
        .zoom-instructions { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.7); padding: 8px 18px; border-radius: 20px; font-size: 0.8rem; color: var(--text-muted); font-weight: 600; letter-spacing: 0.5px; border: 1px solid rgba(255,255,255,0.05); pointer-events: none; }

        /* =========================================
           RESPONSIVE DESIGN
        ========================================= */
        @media (max-width: 1100px) {
            .manual-layout { flex-direction: column; height: auto; padding: 10px; }
            .manual-sidebar { width: 100%; flex-direction: row; flex-wrap: wrap; }
            .sidebar-header { width: 100%; border-radius: 16px 16px 0 0; }
            .nav-list { flex-direction: row; flex-wrap: wrap; justify-content: center; width: 100%; padding: 15px; }
            .nav-item { flex: 1 1 auto; min-width: 180px; justify-content: center; }
            .manual-content { padding: 25px; height: auto; border-radius: 0 0 16px 16px; }
            .alert-master-card { grid-template-columns: 1fr; gap: 20px; padding: 25px; }
            .alert-header { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); padding-right: 0; padding-bottom: 15px; text-align: center; }
            .grid-4, .grid-3 { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 768px) {
            .grid-4, .grid-3, .grid-2, .alert-details { grid-template-columns: 1fr; }
            .pane-title { font-size: 22px; }
        }
    </style>
</head>
<body>

<div class="manual-layout">
    
    <!-- NAVIGATION LATERALE -->
    <aside class="manual-sidebar">
        <div class="sidebar-header">
            <a href="/documents" class="btn-back-hub"><i class="fas fa-chevron-left"></i> Hub Documentaire</a>
            <h1 class="manual-title">Livret<span>BCSO V2.0</span></h1>
        </div>
        <nav class="nav-list">
            <button class="nav-item active" data-target="hierarchie"><i class="fas fa-sitemap"></i> Hiérarchie & Grades</button>
            <button class="nav-item" data-target="anciennete"><i class="fas fa-medal"></i> Ancienneté</button>
            <button class="nav-item" data-target="specialisations"><i class="fas fa-star"></i> Spécialisations</button>
            <button class="nav-item" data-target="codes"><i class="fas fa-walkie-talkie"></i> Transmissions</button>
            <button class="nav-item" data-target="positions"><i class="fas fa-map-location-dot"></i> Positions & Cartes</button>
            <button class="nav-item" data-target="protocoles"><i class="fas fa-handcuffs"></i> Protocoles d'Action</button>
            <button class="nav-item" data-target="cevital"><i class="fas fa-crosshairs"></i> ISTC & CEVITAL</button>
            <button class="nav-item" data-target="alertes"><i class="fas fa-triangle-exclamation"></i> Niveaux d'Alertes</button>
        </nav>
    </aside>

    <!-- CONTENU PRINCIPAL -->
    <main class="manual-content">
        
        <!-- SECTION : HIERARCHIE -->
        <article id="hierarchie" class="pane active">
            <header class="pane-header">
                <h2 class="pane-title"><i class="fas fa-sitemap"></i> Chaîne de Commandement</h2>
                <p class="pane-desc">Structure d'autorité opérationnelle et administrative officielle du Blaine County Sheriff's Office.</p>
            </header>
            
            <section class="tactical-hierarchy">
                <!-- COMMAND STAFF -->
                <div class="hierarchy-section command">
                    <h3 class="section-class-title"><i class="fas fa-crown"></i> Command Staff</h3>
                    <div class="ranks-grid-fluid">
                        <div class="rank-tactical-card">
                            <div class="rank-meta"><span class="rank-name">Sheriff</span><span class="rank-label">Direction</span></div>
                            <span class="rank-mission">Responsable absolu, autorité suprême du département.</span>
                        </div>
                        <div class="rank-tactical-card">
                            <div class="rank-meta"><span class="rank-name">Lieutenant</span><span class="rank-label">Commandement</span></div>
