<script>
    // Navigation dynamique par onglets
    function openTab(tabId, buttonElement) {
        document.querySelectorAll('.nav-item').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.pane').forEach(pane => pane.classList.remove('active'));
        
        buttonElement.classList.add('active');
        document.getElementById(tabId).classList.add('active');
        
        // Si on change d'onglet, on remet à zéro la recherche radio si elle existe
        const searchInput = document.getElementById('radioSearch');
        if(searchInput) {
            searchInput.value = '';
            searchRadioCodes();
        }
    }

    // Moteur de recherche instantané pour les codes radio
    function searchRadioCodes() {
        const query = document.getElementById('radioSearch').value.toLowerCase().trim();
        const listItems = document.querySelectorAll('.search-list li');
        
        listItems.forEach(item => {
            const text = item.textContent.toLowerCase();
            if (query === '' || text.includes(query)) {
                item.classList.remove('hidden');
            } else {
                item.classList.add('hidden');
            }
        });
    }
</script>

