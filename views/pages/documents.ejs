<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --bg-card: rgba(15, 23, 42, 0.4);
        --bg-dark: #07090e;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
            radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
        font-family: 'Montserrat', sans-serif;
        color: #e2e8f0;
        min-height: 100vh;
    }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .hub-container { 
        max-width: 1400px; 
        margin: 0 auto; 
        padding-top: 40px; 
        padding-bottom: 70px; 
        animation: fadeUp 0.6s ease-out forwards; 
    }

    .hub-header { 
        display: flex; flex-direction: column; align-items: center; 
        border-bottom: 1px solid rgba(189, 165, 129, 0.2); 
        padding-bottom: 30px; margin-bottom: 50px; text-align: center;
    }
    
    .hub-header h2 { 
        margin: 0; color: #fff; font-size: 32px; font-weight: 900; 
        text-transform: uppercase; letter-spacing: 2px; 
    }
    
    .hub-header h2 span { 
        background: linear-gradient(135deg, #ffffff 0%, var(--primary) 100%); 
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; 
    }
    
    .hub-header p {
        color: #94a3b8; font-size: 1rem; margin-top: 10px; font-weight: 500;
    }

    .doc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 30px;
    }

    .doc-card {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.2);
        border-radius: 16px;
        padding: 35px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .doc-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px var(--primary-glow);
        border-color: rgba(189, 165, 129, 0.4);
    }

    .doc-icon {
        font-size: 45px;
        color: var(--primary);
        margin-bottom: 20px;
        filter: drop-shadow(0 0 10px rgba(189, 165, 129, 0.3));
    }

    .doc-title {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .doc-desc {
        color: #94a3b8;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 30px;
        flex-grow: 1;
    }

    .doc-meta {
        font-size: 0.8rem;
        color: var(--primary);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 20px;
        display: inline-block;
        background: rgba(189, 165, 129, 0.1);
        padding: 5px 10px;
        border-radius: 4px;
        align-self: flex-start;
    }

    .btn-open {
        background: rgba(189, 165, 129, 0.1);
        border: 1px solid var(--primary);
        color: var(--primary);
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

    .btn-open:hover {
        background: var(--primary);
        color: #07090e;
        box-shadow: 0 0 15px rgba(189, 165, 129, 0.4);
    }
    
    .doc-card.locked { opacity: 0.6; filter: grayscale(100%); pointer-events: none; }
</style>

<div id="hub-container" class="hub-container">
    <div class="hub-header">
        <h2>Base <span>Documentaire</span></h2>
        <p>Portail centralisé des manuels, livrets et procédures officielles du BCSO.</p>
    </div>

    <div class="doc-grid">
        <!-- LE LIVRET V2 -->
        <div class="doc-card">
            <div class="doc-meta">V2.0 - Officiel</div>
            <i class="fas fa-book-open doc-icon"></i>
            <div class="doc-title">Livret d'Informations</div>
            <div class="doc-desc">Manuel complet contenant la hiérarchie, les spécialisations, les codes radio, le protocole CEVITAL et les niveaux d'alertes.</div>
            <a href="/documents/livret" class="btn-open">Consulter le livret <i class="fas fa-arrow-right"></i></a>
        </div>

        <!-- EMPLACEMENT POUR FUTUR DOCUMENT (Grisé) -->
        <div class="doc-card locked">
            <div class="doc-meta">En construction</div>
            <i class="fas fa-file-contract doc-icon"></i>
            <div class="doc-title">Code Pénal</div>
            <div class="doc-desc">Registre complet des infractions, délits, crimes et amendes de l'État de San Andreas. Document actuellement en cours de rédaction.</div>
            <a href="#" class="btn-open"><i class="fas fa-lock"></i> Accès restreint</a>
        </div>
    </div>
</div>