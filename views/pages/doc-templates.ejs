<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.2);
        --bg-dark: #05070b;
        --bg-panel: rgba(11, 15, 25, 0.75);
        --text-main: #e2e8f0;
        --border-glow: rgba(189, 165, 129, 0.25);
        --success: #10b981;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            linear-gradient(rgba(189, 165, 129, 0.01) 1px, transparent 1px),
            linear-gradient(90deg, rgba(189, 165, 129, 0.01) 1px, transparent 1px);
        background-size: 30px 30px;
        font-family: 'Montserrat', sans-serif; 
        color: var(--text-main); 
        min-height: 100vh;
    }

    @keyframes fadeUp { 
        from { opacity: 0; transform: translateY(20px); } 
        to { opacity: 1; transform: translateY(0); } 
    }
    @keyframes slideInRight { 
        from { opacity: 0; transform: translateX(20px); } 
        to { opacity: 1; transform: translateX(0); } 
    }

    .proc-wrapper { 
        max-width: 1400px; 
        margin: 40px auto 80px auto; 
        padding: 0 30px; 
        animation: fadeUp 0.5s ease-out forwards;
        margin-left: 300px;
    }

    .proc-header { 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        margin-bottom: 35px; 
        background: var(--bg-panel); 
        padding: 25px 35px; 
        border-radius: 16px; 
        border-top: 1px solid var(--border-glow); 
        backdrop-filter: blur(20px); 
        box-shadow: 0 15px 35px rgba(0,0,0,0.4); 
    }

    .btn-back { 
        background: rgba(189, 165, 129, 0.08); 
        border: 1px solid rgba(189, 165, 129, 0.3); 
        color: var(--primary); 
        padding: 12px 22px; 
        border-radius: 8px; 
        font-weight: 800; 
        text-transform: uppercase; 
        text-decoration: none; 
        transition: 0.3s ease; 
        display: inline-flex; 
        align-items: center; 
        gap: 10px; 
        letter-spacing: 1px;
        font-size: 0.8rem;
    }
    .btn-back:hover { 
        background: var(--primary); 
        color: #05070b; 
        box-shadow: 0 0 15px var(--primary-glow); 
        transform: translateX(-3px);
    }

    .proc-title { text-align: right; }
    .proc-title h1 { 
        font-size: 26px; 
        font-weight: 900; 
        margin: 0; 
        color: #fff; 
        text-transform: uppercase; 
        letter-spacing: 2px; 
    }
    .proc-title p { 
        color: var(--primary); 
        margin: 5px 0 0 0; 
        font-weight: 700; 
        font-size: 13px; 
        letter-spacing: 3px; 
        text-transform: uppercase; 
    }

    .formation-nav {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 12px;
        margin-bottom: 30px;
    }
    .form-nav-btn {
        background: rgba(6, 9, 15, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.03);
        color: #94a3b8;
        padding: 16px;
        border-radius: 10px;
        font-family: 'Montserrat', sans-serif;
        font-weight: 800;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.25s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        position: relative;
        z-index: 10;
    }
    .form-nav-btn:hover { background: rgba(255,255,255,0.02); color: #fff; }
    .form-nav-btn.active {
        background: linear-gradient(180deg, rgba(189, 165, 129, 0.15) 0%, rgba(189,165,129,0.02) 100%);
        color: var(--primary);
        border: 1px solid var(--primary);
        box-shadow: 0 5px 15px rgba(189, 165, 129, 0.05);
    }

    .formation-pane { display: none; animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .formation-pane.active { display: block; }

    .main-grid { display: grid; grid-template-columns: 1fr; gap: 30px; }

    .info-panel {
        background: var(--bg-panel);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255,255,255,0.02);
        border-left: 4px solid var(--primary);
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .info-panel h2 {
        margin: 0 0 15px 0; color: #fff; font-size: 1.25rem; text-transform: uppercase;
        font-weight: 800; letter-spacing: 1px; display: flex; align-items: center; gap: 10px;
    }
    .info-panel h2 span { color: var(--primary); }
    .info-panel p { color: #cbd5e1; line-height: 1.7; font-size: 0.92rem; margin: 0; font-weight: 500; }

    .use-case-box {
        background: rgba(10, 15, 30, 0.4);
        border: 1px solid rgba(255,255,255,0.02);
        border-radius: 12px;
        padding: 25px;
        position: relative;
    }
    
    .template-content {
        color: #e2e8f0;
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 0.9rem;
        line-height: 1.6;
        background: rgba(0, 0, 0, 0.3);
        padding: 40px 20px 20px 20px;
        border-radius: 8px;
        border: 1px dashed rgba(189, 165, 129, 0.3);
        white-space: pre-wrap;
    }

    .btn-copy {
        position: absolute;
        top: 35px;
        right: 35px;
        background: rgba(189, 165, 129, 0.1);
        border: 1px solid var(--primary);
        color: var(--primary);
        padding: 8px 15px;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
        z-index: 10;
    }
    .btn-copy:hover {
        background: var(--primary);
        color: #000;
    }
    .btn-copy.copied {
        background: var(--success);
        border-color: var(--success);
        color: #fff;
    }

    .academy-footer {
        margin-top: 40px; text-align: center; padding: 15px; border-top: 1px dashed rgba(255,255,255,0.05);
        color: #475569; font-size: 0.75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    }

    @media (max-width: 1200px) {
        .proc-wrapper { margin-left: 0; padding: 20px; }
        .formation-nav { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 768px) {
        .formation-nav { grid-template-columns: repeat(2, 1fr); }
    }
</style>

