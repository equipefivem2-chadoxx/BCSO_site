<script>
    function switchTemplate(paneId, buttonElement) {
        document.querySelectorAll('.form-nav-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.formation-pane').forEach(pane => pane.classList.remove('active'));
        
        buttonElement.classList.add('active');
        document.getElementById(paneId).classList.add('active');
    }

    function copyText(elementId, btnElement) {
        const textToCopy = document.getElementById(elementId).innerText;
        navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = btnElement.innerHTML;
            btnElement.classList.add('copied');
            btnElement.innerHTML = '<i class="fas fa-check"></i> Copié !';
            setTimeout(() => {
                btnElement.classList.remove('copied');
                btnElement.innerHTML = originalText;
            }, 2000);
        }).catch(err => {
            console.error('Erreur lors de la copie : ', err);
        });
    }
</script>