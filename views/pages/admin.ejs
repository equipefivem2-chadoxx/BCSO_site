<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #0a0f1d;
            color: #e2e8f0;
            display: flex;
        }
        .main-content {
            margin-left: 260px; /* Espace pour la sidebar */
            padding: 40px;
            width: calc(100% - 260px);
            box-sizing: border-box;
            min-height: 100vh;
            padding-bottom: 80px; /* Espace pour la bottom bar */
        }
        h1, h2, h3 {
            color: #d4af37;
            margin-top: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .page-header {
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
            padding-bottom: 15px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        /* Cartes de Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 35px;
        }
        .stat-card {
            background: #0f172a;
            border: 1px solid #1e293b;
            border-radius: 8px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.2);
        }
        .stat-card i {
            font-size: 2.5rem;
            color: #d4af37;
        }
        .stat-info div {
            font-size: 0.85rem;
            color: #94a3b8;
            text-transform: uppercase;
        }
        .stat-info span {
            font-size: 1.8rem;
            font-weight: bold;
            color: #f8fafc;
        }

        /* Layout Formulaire / Tableau */
        .admin-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 30px;
            align-items: start;
        }
        @media (max-width: 1024px) {
            .admin-grid { grid-template-columns: 1fr; }
        }

        .panel-box {
            background: #0f172a;
            border: 1px solid #1e293b;
            border-radius: 8px;
            padding: 25px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.2);
        }

        /* Formulaires standardisés */
        .form-group {
            margin-bottom: 18px;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.85rem;
            color: #94a3b8;
            text-transform: uppercase;
        }
        .form-control {
            width: 100%;
            padding: 10px 14px;
            background: #05070b;
            border: 1px solid #334155;
            border-radius: 5px;
            color: #f8fafc;
            font-size: 0.95rem;
            box-sizing: border-box;
            transition: border-color 0.3s;
        }
        .form-control:focus {
            outline: none;
            border-color: #d4af37;
        }

        /* Custom Switch pour la case Admin */
        .switch-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #05070b;
            padding: 12px;
            border-radius: 5px;
            border: 1px solid #334155;
            margin-top: 10px;
        }
        .switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 24px;
        }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #334155;
            transition: .4s;
            border-radius: 24px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 16px; width: 16px;
            left: 4px; bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        input:checked + .slider { background-color: #d4af37; }
        input:checked + .slider:before { transform: translateX(26px); }

        .btn {
            background: #d4af37;
            color: #05070b;
            border: none;
            padding: 12px 20px;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            width: 100%;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: background 0.3s;
        }
        .btn:hover { background: #bfa030; }

        /* Tableau des Agents */
        .table-responsive {
            overflow-x: auto;
        }
        .agent-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }
        .agent-table th {
            background: #05070b;
            padding: 12px 16px;
            color: #94a3b8;
            font-size: 0.8rem;
            text-transform: uppercase;
            border-bottom: 2px solid #1e293b;
        }
        .agent-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #1e293b;
            font-size: 0.95rem;
            vertical-align: middle;
        }
        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: bold;
            text-transform: uppercase;
        }
        .badge-admin { background: rgba(212, 175, 55, 0.2); color: #d4af37; border: 1px solid #d4af37; }
        .badge-user { background: rgba(71, 85, 105, 0.2); color: #94a3b8; }
        
        .actions-cell {
            display: flex;
            gap: 10px;
        }
        .btn-action {
            background: none;
            border: 1px solid #334155;
            color: #cbd5e1;
            padding: 6px 10px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-action.edit:hover { border-color: #38bdf8; color: #38bdf8; }
        .btn-action.delete:hover { border-color: #ef4444; color: #ef4444; }

        /* Ligne cachée pour modification */
        .edit-row {
            background: #05070b;
            display: none;
        }
        .edit-row td {
            padding: 20px;
            border-bottom: 2px solid #d4af37;
        }

        /* Zone de Danger */
        .danger-zone {
            margin-top: 40px;
            border: 1px dashed #ef4444;
            background: rgba(239, 68, 68, 0.05);
        }
        .danger-zone h2 { color: #ef4444; }
        .btn-danger {
            background: #ef4444;
            color: #fff;
        }
        .btn-danger:hover { background: #dc2626; }
    </style>
</head>
<body>

    <%- include('../partials/sidebar') %>

    <div class="main-content">
        <div class="page-header">
            <div>
                <h1>Haut Commandement</h1>
                <p style="color: #94a3b8; margin: 5px 0 0 0;">Gestion globale des accès et des effectifs BCSO</p>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <i class="fas fa-user-shield"></i>
                <div class="stat-info">
                    <div>Total Agents</div>
                    <span><%= agents.length %></span>
                </div>
            </div>
            <div class="stat-card">
                <i class="fas fa-lock"></i>
                <div class="stat-info">
                    <div>Admins Web</div>
                    <span><%= agents.filter(a => a.isAdmin).length %></span>
                </div>
            </div>
            <div class="stat-card">
                <i class="fas fa-file-invoice"></i>
                <div class="stat-info">
                    <div>Rapports Stockés</div>
                    <span><%= archivesCount %></span>
                </div>
            </div>
        </div>

        <div class="admin-grid">
            <div class="panel-box">
                <h2>Enregistrer un Agent</h2>
                <hr style="border: 0; border-top: 1px solid #1e293b; margin-bottom: 20px;">
                
                <form action="/admin/ajouter" method="POST">
                    <div class="form-group">
                        <label>Prénom</label>
                        <input type="text" name="prenom" class="form-control" required placeholder="John">
                    </div>
                    <div class="form-group">
                        <label>Nom</label>
                        <input type="text" name="nom" class="form-control" required placeholder="Doe">
                    </div>
                    <div class="form-group">
                        <label>Matricule</label>
                        <input type="text" name="matricule" class="form-control" required placeholder="55">
                    </div>
                    <div class="form-group">
                        <label>Téléphone (In-Game)</label>
                        <input type="text" name="telephone" class="form-control" placeholder="555-XXXX">
                    </div>
                    <div class="form-group">
                        <label>ID Discord (Obligatoire pour les accès)</label>
                        <input type="text" name="discordId" class="form-control" placeholder="1247264549489610897">
                    </div>
                    <div class="form-group">
                        <label>Grade RP</label>
                        <select name="grade" class="form-control" required>
                            <option value="Deputy Junior">Deputy Junior</option>
                            <option value="Deputy I">Deputy I</option>
                            <option value="Deputy II">Deputy II</option>
                            <option value="Deputy III">Deputy III</option>
                            <option value="SLO">SLO</option>
                            <option value="Sergeant I">Sergeant I</option>
                            <option value="Sergeant II">Sergeant II</option>
                            <option value="Sergeant Chef">Sergeant Chef</option>
                            <option value="Lieutenant">Lieutenant</option>
                            <option value="Sheriff">Sheriff</option>
                        </select>
                    </div>

                    <div class="switch-container">
                        <div>
                            <strong style="font-size: 0.9rem; display:block;">Accès Administration</strong>
                            <small style="color: #94a3b8; font-size: 0.75rem;">Donne les droits d'accès à ce panel.</small>
                        </div>
                        <label class="switch">
                            <input type="checkbox" name="isAdmin">
                            <span class="slider"></span>
                        </label>
                    </div>
                    
                    <button type="submit" class="btn" style="margin-top: 20px;"><i class="fas fa-plus"></i> Créer l'Agent</button>
                </form>
            </div>

            <div class="panel-box">
                <h2>Liste des Agents Enregistrés</h2>
                <hr style="border: 0; border-top: 1px solid #1e293b; margin-bottom: 20px;">

                <div class="table-responsive">
                    <table class="agent-table">
                        <thead>
                            <tr>
                                <th>Matricule</th>
                                <th>Identité</th>
                                <th>Grade</th>
                                <th>Permissions</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(agents.length === 0) { %>
                                <tr>
                                    <td colspan="5" style="text-align: center; color: #94a3b8; padding: 30px;">Aucun agent enregistré pour le moment.</td>
                                end;
                            <% } %>
                            <% agents.forEach(agent => { %>
                                <tr>
                                    <td style="font-weight: bold; color: #d4af37;">#<%= agent.matricule %></td>
                                    <td><%= agent.prenom %> <%= agent.nom %></td>
                                    <td><%= agent.grade %></td>
                                    <td>
                                        <span class="badge <%= agent.isAdmin ? 'badge-admin' : 'badge-user' %>">
                                            <%= agent.isAdmin ? 'Admin Site' : 'Agent' %>
                                        </span>
                                    </td>
                                    <td class="actions-cell">
                                        <button class="btn-action edit" onclick="toggleEditRow('<%= agent._id %>')"><i class="fas fa-edit"></i></button>
                                        <form action="/admin/supprimer/<%= agent._id %>" method="POST" style="margin:0;" onsubmit="return confirm('Voulez-vous vraiment supprimer cet agent ?');">
                                            <button type="submit" class="btn-action delete"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>

                                <tr id="edit-<%= agent._id %>" class="edit-row">
                                    <td colspan="5">
                                        <form action="/admin/modifier/<%= agent._id %>" method="POST">
                                            <h3 style="font-size:1rem; margin-bottom:15px; color:#38bdf8;"><i class="fas fa-user-edit"></i> Modifier l'agent <%= agent.prenom %></h3>
                                            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom:15px;">
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8;">Prénom</label>
                                                    <input type="text" name="prenom" value="<%= agent.prenom %>" class="form-control" required>
                                                </div>
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8;">Nom</label>
                                                    <input type="text" name="nom" value="<%= agent.nom %>" class="form-control" required>
                                                </div>
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8;">Matricule</label>
                                                    <input type="text" name="matricule" value="<%= agent.matricule %>" class="form-control" required>
                                                </div>
                                            </div>
                                            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom:15px;">
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8;">Téléphone</label>
                                                    <input type="text" name="telephone" value="<%= agent.telephone %>" class="form-control">
                                                </div>
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8;">ID Discord</label>
                                                    <input type="text" name="discordId" value="<%= agent.discordId %>" class="form-control">
                                                </div>
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8;">Grade</label>
                                                    <select name="grade" class="form-control" required>
                                                        <option value="Deputy Junior" <%= agent.grade === 'Deputy Junior' ? 'selected' : '' %>>Deputy Junior</option>
                                                        <option value="Deputy I" <%= agent.grade === 'Deputy I' ? 'selected' : '' %>>Deputy I</option>
                                                        <option value="Deputy II" <%= agent.grade === 'Deputy II' ? 'selected' : '' %>>Deputy II</option>
                                                        <option value="Deputy III" <%= agent.grade === 'Deputy III' ? 'selected' : '' %>>Deputy III</option>
                                                        <option value="SLO" <%= agent.grade === 'SLO' ? 'selected' : '' %>>SLO</option>
                                                        <option value="Sergeant I" <%= agent.grade === 'Sergeant I' ? 'selected' : '' %>>Sergeant I</option>
                                                        <option value="Sergeant II" <%= agent.grade === 'Sergeant II' ? 'selected' : '' %>>Sergeant II</option>
                                                        <option value="Sergeant Chef" <%= agent.grade === 'Sergeant Chef' ? 'selected' : '' %>>Sergeant Chef</option>
                                                        <option value="Lieutenant" <%= agent.grade === 'Lieutenant' ? 'selected' : '' %>>Lieutenant</option>
                                                        <option value="Sheriff" <%= agent.grade === 'Sheriff' ? 'selected' : '' %>>Sheriff</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top:15px;">
                                                <div class="switch-container" style="margin-top:0; width: 250px;">
                                                    <span style="font-size: 0.85rem;">Accès Administration</span>
                                                    <label class="switch">
                                                        <input type="checkbox" name="isAdmin" <%= agent.isAdmin ? 'checked' : '' %>>
                                                        <span class="slider"></span>
                                                    </label>
                                                </div>
                                                <div style="display:flex; gap:10px;">
                                                    <button type="button" class="btn" style="background:#475569; color:#fff;" onclick="toggleEditRow('<%= agent._id %>')">Annuler</button>
                                                    <button type="submit" class="btn" style="background:#38bdf8; color:#0f172a;">Sauvegarder</button>
                                                </div>
                                            </div>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="panel-box danger-zone">
            <h2><i class="fas fa-exclamation-triangle"></i> Zone de Danger Critique</h2>
            <p style="color: #94a3b8; font-size: 0.9rem;">Les actions ci-dessous sont irréversibles. Soyez extrêmement vigilants.</p>
            <hr style="border: 0; border-top: 1px solid rgba(239, 68, 68, 0.2); margin: 15px 0;">
            
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
                <div>
                    <strong style="display: block; color: #f8fafc;">Purger tous les rapports d'opération</strong>
                    <span style="color: #94a3b8; font-size: 0.85rem;">Efface définitivement la totalité de la collection de données des tickets (<%= archivesCount %> éléments).</span>
                </div>
                <form action="/admin/purge-rapports" method="POST" onsubmit="return confirm('⚠️ ALERTE CRITIQUE : Voulez-vous vraiment détruire l\'intégralité des rapports ? Cette action ne peut pas être annulée.');">
                    <button type="submit" class="btn btn-danger"><i class="fas fa-trash-blaster"></i> Exécuter la Purge Complexe</button>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/header') %>

    <script>
        function toggleEditRow(id) {
            const row = document.getElementById(`edit-${id}`);
            if (row.style.display === 'table-row') {
                row.style.display = 'none';
            } else {
                row.style.display = 'table-row';
            }
        }
    </script>
</body>
</html>