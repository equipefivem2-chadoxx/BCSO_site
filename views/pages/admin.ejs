<style>
    :root {
        --primary: #bda581;
        --bg-card: rgba(15, 23, 42, 0.4);
        --bg-dark: #07090e; 
    }
    
    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
            radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
        font-family: 'Montserrat', sans-serif;
        color: #e2e8f0;
        min-height: 100vh;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    #admin-container {
        max-width: 1400px;
        margin: 0 auto;
        padding-top: 40px;
        padding-bottom: 70px;
        animation: fadeIn 0.4s ease-out forwards;
    }
    
    h1, h2, h3 {
        color: var(--primary);
        margin-top: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 800;
    }
    .page-header {
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 15px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    .stat-card {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.1);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    .stat-card i {
        font-size: 2.2rem;
        color: var(--primary);
    }
    .stat-info div {
        font-size: 0.8rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
    }
    .stat-info span {
        font-size: 1.6rem;
        font-weight: 800;
        color: #f8fafc;
    }

    .admin-grid {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 25px;
        align-items: start;
    }
    @media (max-width: 1200px) {
        .admin-grid { grid-template-columns: 1fr; }
    }

    .panel-box {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.1);
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .form-group {
        margin-bottom: 15px;
    }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 0.8rem;
        color: #94a3b8;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.5px;
    }
    .form-control {
        width: 100%;
        padding: 12px;
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        color: #f8fafc;
        font-size: 0.9rem;
        transition: border-color 0.2s;
    }
    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 10px rgba(189, 165, 129, 0.2);
        background: rgba(0,0,0,0.5);
    }

    .switch-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(0,0,0,0.3);
        padding: 12px 15px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.05);
        margin-top: 15px;
    }
    .switch { position: relative; display: inline-block; width: 44px; height: 22px; flex-shrink: 0; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #334155; transition: .3s; border-radius: 22px; }
    .slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background-color: white; transition: .3s; border-radius: 50%; }
    input:checked + .slider { background-color: var(--primary); }
    input:checked + .slider:before { transform: translateX(22px); }

    .btn {
        background: var(--primary);
        color: #05070b;
        border: none;
        padding: 12px 20px;
        font-weight: 800;
        border-radius: 8px;
        cursor: pointer;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
        transition: all 0.3s;
    }
    .btn:hover { background: #e5d5b7; box-shadow: 0 0 15px rgba(189, 165, 129, 0.4); transform: translateY(-2px); }

    .table-responsive { overflow-x: auto; }
    .agent-table { width: 100%; border-collapse: collapse; text-align: left; }
    .agent-table th { background: rgba(0,0,0,0.2); padding: 15px; color: #94a3b8; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; border-bottom: 2px solid rgba(255,255,255,0.05); }
    .agent-table td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.02); font-size: 0.95rem; vertical-align: middle; }
    
    .badge { padding: 6px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
    .badge-admin { background: rgba(189, 165, 129, 0.15); color: var(--primary); border: 1px solid var(--primary); }
    .badge-user { background: rgba(71, 85, 105, 0.2); color: #94a3b8; border: 1px solid rgba(71, 85, 105, 0.4); }
    
    .actions-cell { display: flex; gap: 10px; }
    .btn-action { background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #cbd5e1; padding: 8px 12px; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
    .btn-action.edit:hover { border-color: var(--primary); color: var(--primary); background: rgba(189, 165, 129, 0.1); }
    .btn-action.delete:hover { border-color: #ef4444; color: #ef4444; background: rgba(239, 68, 68, 0.1); }

    .edit-row { background: rgba(0,0,0,0.4); display: none; }
    .edit-row td { padding: 25px; border-bottom: 2px solid var(--primary); }

    .danger-zone { margin-top: 40px; border: 1px dashed rgba(239, 68, 68, 0.4); background: rgba(239, 68, 68, 0.05); }
    .danger-zone h2 { color: #ef4444; font-size: 1.2rem; }
    .btn-danger { background: #ef4444; color: #fff; width: auto; }
    .btn-danger:hover { background: #dc2626; box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); }
</style>

<div id="admin-container">
    <div class="page-header">
        <div>
            <h1>Haut Commandement</h1>
            <p style="color: #94a3b8; font-size: 0.9rem; margin: 4px 0 0 0;">Gestion globale des accès et des effectifs BCSO</p>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <i class="fas fa-user-shield"></i>
            <div class="stat-info">
                <div>Total Agents</div>
                <span><%= agents.length %></span>
            </div>
        </div>
        <div class="stat-card">
            <i class="fas fa-lock"></i>
            <div class="stat-info">
                <div>Admins Web</div>
                <span><%= agents.filter(a => a.isAdmin).length %></span>
            </div>
        </div>
        <div class="stat-card">
            <i class="fas fa-file-invoice"></i>
            <div class="stat-info">
                <div>Rapports Stockés</div>
                <span><%= archivesCount %></span>
            </div>
        </div>
    </div>

    <div class="admin-grid">
        <div class="panel-box">
            <h2 style="font-size: 1.1rem;">Enregistrer un Agent</h2>
            <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">
            
            <form action="/admin/ajouter" method="POST">
                <div class="form-group">
                    <label>Prénom</label>
                    <input type="text" name="prenom" class="form-control" required placeholder="John">
                </div>
                <div class="form-group">
                    <label>Nom</label>
                    <input type="text" name="nom" class="form-control" required placeholder="Doe">
                </div>
                <div class="form-group">
                    <label>Matricule</label>
                    <input type="text" name="matricule" class="form-control" required placeholder="55">
                </div>
                <div class="form-group">
                    <label>Téléphone (In-Game)</label>
                    <input type="text" name="telephone" class="form-control" placeholder="555-XXXX">
                </div>
                <div class="form-group">
                    <label>ID Discord <span style="color:#ef4444;">*</span></label>
                    <input type="text" name="discordId" class="form-control" placeholder="1247264549489610897">
                </div>
                <div class="form-group">
                    <label>Grade RP</label>
                    <select name="grade" class="form-control" required>
                        <option value="Deputy Junior">Deputy Junior</option>
                        <option value="Deputy I">Deputy I</option>
                        <option value="Deputy II">Deputy II</option>
                        <option value="Deputy III">Deputy III</option>
                        <option value="SLO">SLO</option>
                        <option value="Sergeant I">Sergeant I</option>
                        <option value="Sergeant II">Sergeant II</option>
                        <option value="Sergeant Chef">Sergeant Chef</option>
                        <option value="Lieutenant">Lieutenant</option>
                        <option value="Sheriff">Sheriff</option>
                    </select>
                </div>

                <div class="switch-container">
                    <div>
                        <strong style="font-size: 0.85rem; display:block; color:#fff;">Accès Admin</strong>
                        <small style="color: #94a3b8; font-size: 0.75rem;">Autoriser le panel MDT</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" name="isAdmin">
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="switch-container">
                    <div>
                        <strong style="font-size: 0.85rem; display:block; color:#fff;">Droit de Suppression</strong>
                        <small style="color: #94a3b8; font-size: 0.75rem;">Autoriser la suppression des archives</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" name="canDeleteArchives">
                        <span class="slider"></span>
                    </label>
                </div>
                
                <button type="submit" class="btn" style="margin-top: 25px;"><i class="fas fa-plus" style="margin-right: 8px;"></i> Créer l'Agent</button>
            </form>
        </div>

        <div>
            <!-- 🚀 Encadré Entreprise mis à jour -->
            <div class="panel-box" style="margin-bottom: 25px; border-top-color: #38bdf8;">
                <h2 style="font-size: 1.1rem; color: #38bdf8;"><i class="fas fa-handshake" style="margin-right: 8px;"></i> Accès Partenaires (Entreprises)</h2>
                <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">
                
                <form action="/admin/entreprise/ajouter" method="POST" style="margin-bottom: 25px;">
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px;">
                        <input type="text" name="nom" class="form-control" placeholder="Nom (ex: Weazel News)" required>
                        <input type="text" name="identifiant" class="form-control" placeholder="Login (ex: weazel)" required>
                        <input type="text" name="motDePasse" class="form-control" placeholder="Mot de passe" required>
                    </div>
                    <button type="submit" class="btn" style="margin-top: 15px; background: #38bdf8; color: #000;"><i class="fas fa-plus"></i> Créer l'accès Partenaire</button>
                </form>

                <table class="agent-table">
                    <thead>
                        <tr>
                            <th>Entreprise</th>
                            <th>Identifiant</th>
                            <th>Mot de passe</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof entreprises !== 'undefined' && entreprises && entreprises.length > 0) { %>
                            <% entreprises.forEach(ent => { %>
                                <tr>
                                    <td style="font-weight: bold; color: #fff;"><%= ent.nom %></td>
                                    <td style="color: #38bdf8; font-family: monospace;"><%= ent.identifiant %></td>
                                    <td style="color: #cbd5e1; font-family: monospace;"><%= ent.motDePasse %></td>
                                    <td class="actions-cell">
                                        <button class="btn-action edit" onclick="toggleEditRow('ent-<%= ent._id %>')"><i class="fas fa-edit"></i></button>
                                        <form action="/admin/entreprise/supprimer/<%= ent._id %>" method="POST" style="margin:0;" onsubmit="return confirm('Révoquer cet accès entreprise ?');">
                                            <button type="submit" class="btn-action delete"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                <!-- 🚀 Ligne d'édition cachée pour l'entreprise -->
                                <tr id="edit-ent-<%= ent._id %>" class="edit-row">
                                    <td colspan="4" style="padding: 20px;">
                                        <form action="/admin/entreprise/modifier/<%= ent._id %>" method="POST" style="display: flex; gap: 15px; align-items: center;">
                                            <input type="text" name="nom" value="<%= ent.nom %>" class="form-control" required placeholder="Nom">
                                            <input type="text" name="identifiant" value="<%= ent.identifiant %>" class="form-control" required placeholder="Identifiant">
                                            <input type="text" name="motDePasse" value="<%= ent.motDePasse %>" class="form-control" required placeholder="Mot de passe">
                                            <div style="display: flex; gap: 5px;">
                                                <button type="submit" class="btn" style="width: auto; background: #38bdf8; color: #000;"><i class="fas fa-save"></i></button>
                                                <button type="button" class="btn" style="width: auto; background: rgba(255,255,255,0.1); color: #fff;" onclick="toggleEditRow('ent-<%= ent._id %>')"><i class="fas fa-times"></i></button>
                                            </div>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="4" style="text-align: center; color: #94a3b8; padding: 20px;">Aucune entreprise partenaire active.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Tableau des agents -->
            <div class="panel-box">
                <h2 style="font-size: 1.1rem;">Liste des Agents Enregistrés</h2>
                <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">

                <div class="table-responsive">
                    <table class="agent-table">
                        <thead>
                            <tr>
                                <th>Matricule</th>
                                <th>Identité</th>
                                <th>Grade</th>
                                <th>Permissions</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(agents.length === 0) { %>
                                <tr>
                                    <td colspan="5" style="text-align: center; color: #94a3b8; padding: 40px;">Aucun agent enregistré.</td>
                                </tr>
                            <% } %>
                            <% agents.forEach(agent => { %>
                                <tr>
                                    <td style="font-weight: 800; color: var(--primary);">#<%= agent.matricule %></td>
                                    <td style="color: #fff; font-weight: 600;"><%= agent.prenom %> <%= agent.nom %></td>
                                    <td style="color: #cbd5e1;"><%= agent.grade %></td>
                                    <td>
                                        <span class="badge <%= agent.isAdmin ? 'badge-admin' : 'badge-user' %>">
                                            <%= agent.isAdmin ? 'Admin Site' : 'Agent' %>
                                        </span>
                                        <% if(agent.canDeleteArchives) { %>
                                            <span class="badge" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); margin-left: 5px;">
                                                Suppression
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="actions-cell">
                                        <button class="btn-action edit" onclick="toggleEditRow('<%= agent._id %>')"><i class="fas fa-edit"></i></button>
                                        <form action="/admin/supprimer/<%= agent._id %>" method="POST" style="margin:0;" onsubmit="return confirm('Voulez-vous vraiment supprimer cet agent ?');">
                                            <button type="submit" class="btn-action delete"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>

                                <tr id="edit-<%= agent._id %>" class="edit-row">
                                    <td colspan="5">
                                        <form action="/admin/modifier/<%= agent._id %>" method="POST">
                                            <h3 style="font-size:1rem; margin-bottom:20px; color:var(--primary);"><i class="fas fa-user-edit" style="margin-right: 8px;"></i> Modifier <%= agent.prenom %> <%= agent.nom %></h3>
                                            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom:15px;">
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8; font-weight:700; text-transform:uppercase;">Prénom</label>
                                                    <input type="text" name="prenom" value="<%= agent.prenom %>" class="form-control" required>
                                                </div>
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8; font-weight:700; text-transform:uppercase;">Nom</label>
                                                    <input type="text" name="nom" value="<%= agent.nom %>" class="form-control" required>
                                                </div>
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8; font-weight:700; text-transform:uppercase;">Matricule</label>
                                                    <input type="text" name="matricule" value="<%= agent.matricule %>" class="form-control" required>
                                                </div>
                                            </div>
                                            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom:15px;">
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8; font-weight:700; text-transform:uppercase;">Téléphone</label>
                                                    <input type="text" name="telephone" value="<%= agent.telephone %>" class="form-control">
                                                </div>
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8; font-weight:700; text-transform:uppercase;">ID Discord</label>
                                                    <input type="text" name="discordId" value="<%= agent.discordId %>" class="form-control">
                                                </div>
                                                <div>
                                                    <label style="font-size:0.75rem; color:#94a3b8; font-weight:700; text-transform:uppercase;">Grade</label>
                                                    <select name="grade" class="form-control" required>
                                                        <option value="Deputy Junior" <%= agent.grade === 'Deputy Junior' ? 'selected' : '' %>>Deputy Junior</option>
                                                        <option value="Deputy I" <%= agent.grade === 'Deputy I' ? 'selected' : '' %>>Deputy I</option>
                                                        <option value="Deputy II" <%= agent.grade === 'Deputy II' ? 'selected' : '' %>>Deputy II</option>
                                                        <option value="Deputy III" <%= agent.grade === 'Deputy III' ? 'selected' : '' %>>Deputy III</option>
                                                        <option value="SLO" <%= agent.grade === 'SLO' ? 'selected' : '' %>>SLO</option>
                                                        <option value="Sergeant I" <%= agent.grade === 'Sergeant I' ? 'selected' : '' %>>Sergeant I</option>
                                                        <option value="Sergeant II" <%= agent.grade === 'Sergeant II' ? 'selected' : '' %>>Sergeant II</option>
                                                        <option value="Sergeant Chef" <%= agent.grade === 'Sergeant Chef' ? 'selected' : '' %>>Sergeant Chef</option>
                                                        <option value="Lieutenant" <%= agent.grade === 'Lieutenant' ? 'selected' : '' %>>Lieutenant</option>
                                                        <option value="Sheriff" <%= agent.grade === 'Sheriff' ? 'selected' : '' %>>Sheriff</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top:20px; flex-wrap: wrap; gap: 10px;">
                                                <div style="display: flex; gap: 15px;">
                                                    <div class="switch-container" style="margin-top:0; width: 220px; padding: 10px 15px;">
                                                        <span style="font-size: 0.85rem; font-weight:700; color:#fff;">Accès Admin</span>
                                                        <label class="switch">
                                                            <input type="checkbox" name="isAdmin" <%= agent.isAdmin ? 'checked' : '' %>>
                                                            <span class="slider"></span>
                                                        </label>
                                                    </div>
                                                    <div class="switch-container" style="margin-top:0; width: 220px; padding: 10px 15px;">
                                                        <span style="font-size: 0.85rem; font-weight:700; color:#fff;">Suppression</span>
                                                        <label class="switch">
                                                            <input type="checkbox" name="canDeleteArchives" <%= agent.canDeleteArchives ? 'checked' : '' %>>
                                                            <span class="slider"></span>
                                                        </label>
                                                    </div>
                                                </div>
                                                <div style="display:flex; gap:10px;">
                                                    <button type="button" class="btn" style="background: rgba(255,255,255,0.1); color:#fff; width: auto;" onclick="toggleEditRow('<%= agent._id %>')">Annuler</button>
                                                    <button type="submit" class="btn" style="width: auto;">Sauvegarder</button>
                                                </div>
                                            </div>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="panel-box danger-zone">
        <h2><i class="fas fa-exclamation-triangle" style="margin-right: 8px;"></i> Zone de Danger Critique</h2>
        <p style="color: #94a3b8; font-size: 0.9rem;">Les actions ci-dessous sont irréversibles. Soyez extrêmement vigilants.</p>
        <hr style="border: 0; border-top: 1px solid rgba(239, 68, 68, 0.2); margin: 20px 0;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
            <div>
                <strong style="display: block; color: #f8fafc; font-size: 1rem; margin-bottom: 5px;">Purger tous les rapports d'opération</strong>
                <span style="color: #94a3b8; font-size: 0.85rem;">Efface définitivement la totalité de la collection de données des tickets (<%= archivesCount %> éléments).</span>
            </div>
            <form action="/admin/purge-rapports" method="POST" onsubmit="return confirm('⚠️ ALERTE CRITIQUE : Voulez-vous vraiment détruire l\'intégralité des rapports ? Cette action ne peut pas être annulée.');">
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash-can" style="margin-right: 8px;"></i> Exécuter la Purge</button>
            </form>
        </div>
    </div>
</div>

<script>
    function toggleEditRow(id) {
        const row = document.getElementById(`edit-${id}`);
        if (row.style.display === 'table-row') {
            row.style.display = 'none';
        } else {
            row.style.display = 'table-row';
        }
    }
</script>