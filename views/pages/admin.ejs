<style>
/* ===== STYLE IDENTIQUE MAIS CLEAN ===== */

@keyframes fadeIn {
    from { opacity:0; transform:translateY(15px); }
    to { opacity:1; transform:translateY(0); }
}

#admin-container {
    max-width:1200px;
    margin:0 auto;
    padding-bottom:50px;
    animation:fadeIn .5s ease;
}

.admin-header {
    background:linear-gradient(90deg, rgba(212,175,55,0.1), transparent);
    padding:25px 30px;
    border-left:4px solid #d4af37;
    border-radius:8px;
    margin-bottom:30px;
}

.admin-header h2 { color:#fff; margin:0; }
.admin-header p { color:#9ca3af; margin:5px 0 0; }

.admin-grid {
    display:grid;
    grid-template-columns:1fr 2fr;
    gap:30px;
}

.form-panel, .list-panel {
    background:rgba(17,24,39,0.6);
    border:1px solid rgba(255,255,255,0.05);
    border-radius:12px;
    padding:25px;
    backdrop-filter:blur(10px);
}

.panel-title {
    color:#d4af37;
    margin-bottom:15px;
}

.input-group { margin-bottom:12px; }

.input-group label {
    display:block;
    font-size:12px;
    color:#9ca3af;
    margin-bottom:5px;
    text-transform:uppercase;
}

.form-control {
    width:100%;
    padding:10px;
    background:#0b0f19;
    border:1px solid #1f2937;
    border-radius:6px;
    color:white;
}

.btn-submit {
    width:100%;
    padding:12px;
    border:1px solid #d4af37;
    background:rgba(212,175,55,0.1);
    color:#d4af37;
    font-weight:bold;
    cursor:pointer;
    text-transform:uppercase;
}

.btn-submit:hover {
    background:#d4af37;
    color:black;
}

.agents-table {
    width:100%;
    border-collapse:collapse;
}

.agents-table th {
    text-align:left;
    font-size:11px;
    color:#9ca3af;
    border-bottom:1px solid #1f2937;
    padding:10px;
}

.agents-table td {
    padding:10px;
    border-bottom:1px solid rgba(255,255,255,0.03);
    color:#e5e7eb;
    font-size:13px;
}

.actions {
    display:flex;
    gap:10px;
}

.btn-icon {
    background:none;
    border:none;
    cursor:pointer;
    font-size:16px;
}

.btn-edit { color:#60a5fa; }
.btn-delete { color:#f87171; }

#editModal {
    display:none;
    position:fixed;
    inset:0;
    background:rgba(0,0,0,0.8);
    justify-content:center;
    align-items:center;
}

.modal-content {
    background:#05070b;
    padding:25px;
    border-radius:10px;
    width:420px;
    border:1px solid rgba(212,175,55,0.3);
}
</style>

<div id="admin-container">

    <div class="admin-header">
        <h2>⚙️ Haut Commandement</h2>
        <p>Gestion des agents</p>
    </div>

    <div class="admin-grid">

        <!-- AJOUT -->
        <div class="form-panel">
            <h3 class="panel-title">➕ Ajouter un agent</h3>

            <form action="/admin/ajouter" method="POST">

                <div class="input-group">
                    <label>Prénom</label>
                    <input name="prenom" class="form-control" required>
                </div>

                <div class="input-group">
                    <label>Nom</label>
                    <input name="nom" class="form-control" required>
                </div>

                <div class="input-group">
                    <label>Matricule</label>
                    <input name="matricule" class="form-control" required>
                </div>

                <div class="input-group">
                    <label>Grade</label>
                    <select name="grade" class="form-control">
                        <option>Sheriff</option>
                        <option>Lieutenant</option>
                        <option>Sergeant Chef</option>
                        <option>Sergeant II</option>
                        <option>Sergeant I</option>
                        <option>SLO</option>
                        <option>Deputy III</option>
                        <option>Deputy II</option>
                        <option>Deputy I</option>
                        <option>Deputy Junior</option>
                    </select>
                </div>

                <div class="input-group">
                    <label>Téléphone</label>
                    <input name="telephone" class="form-control">
                </div>

                <div class="input-group">
                    <label>Discord ID</label>
                    <input name="discordId" class="form-control">
                </div>

                <div class="input-group">
                    <label>
                        <input type="checkbox" name="isAdmin">
                        Admin
                    </label>
                </div>

                <button class="btn-submit">Valider</button>
            </form>
        </div>

        <!-- LISTE -->
        <div class="list-panel">
            <h3 class="panel-title">📋 Agents</h3>

            <% if (agents && agents.length) { %>
            <table class="agents-table">
                <thead>
                    <tr>
                        <th>Matricule</th>
                        <th>Nom</th>
                        <th>Grade</th>
                        <th>Téléphone</th>
                        <th>Admin</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% agents.forEach(function(agent){ %>
                        <tr>

                            <td style="color:#d4af37;">[<%= agent.matricule %>]</td>
                            <td><%= agent.prenom %> <%= agent.nom %></td>
                            <td><%= agent.grade %></td>
                            <td><%= agent.telephone || '-' %></td>
                            <td><%= agent.isAdmin ? '✔' : '✖' %></td>

                            <td>
                                <div class="actions">

                                    <!-- IMPORTANT : DATA SAFE -->
                                    <button
                                        class="btn-icon btn-edit"
                                        data-id="<%= agent._id %>"
                                        data-prenom="<%= agent.prenom %>"
                                        data-nom="<%= agent.nom %>"
                                        data-matricule="<%= agent.matricule %>"
                                        data-grade="<%= agent.grade %>"
                                        data-discord="<%= agent.discordId || '' %>"
                                        data-telephone="<%= agent.telephone || '' %>"
                                        data-admin="<%= agent.isAdmin ? 1 : 0 %>"
                                        onclick="openEditModal(this)">
                                        ✏️
                                    </button>

                                    <form action="/admin/supprimer/<%= agent._id %>" method="POST">
                                        <button class="btn-icon btn-delete">🗑</button>
                                    </form>

                                </div>
                            </td>

                        </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } else { %>
                <p style="color:#6b7280;text-align:center;">Aucun agent</p>
            <% } %>
        </div>
    </div>
</div>

<!-- MODAL -->
<div id="editModal">
    <div class="modal-content">

        <h3 style="color:#d4af37;">Modifier agent</h3>

        <form id="editForm" method="POST">

            <input id="editPrenom" name="prenom" class="form-control">
            <input id="editNom" name="nom" class="form-control">
            <input id="editMatricule" name="matricule" class="form-control">
            <input id="editGrade" name="grade" class="form-control">
            <input id="editDiscord" name="discordId" class="form-control">
            <input id="editTelephone" name="telephone" class="form-control">

            <label style="color:#9ca3af;">
                <input type="checkbox" id="editAdmin" name="isAdmin">
                Admin
            </label>

            <button class="btn-submit">Sauvegarder</button>
        </form>

        <button class="btn-submit" onclick="closeModal()">Fermer</button>

    </div>
</div>

<script>
function openEditModal(btn) {
    document.getElementById('editForm').action = '/admin/modifier/' + btn.dataset.id;

    document.getElementById('editPrenom').value = btn.dataset.prenom;
    document.getElementById('editNom').value = btn.dataset.nom;
    document.getElementById('editMatricule').value = btn.dataset.matricule;
    document.getElementById('editGrade').value = btn.dataset.grade;
    document.getElementById('editDiscord').value = btn.dataset.discord;
    document.getElementById('editTelephone').value = btn.dataset.telephone;
    document.getElementById('editAdmin').checked = btn.dataset.admin === "1";

    document.getElementById('editModal').style.display = 'flex';
}

function closeModal() {
    document.getElementById('editModal').style.display = 'none';
}
</script>