<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BCSO - Authentification</title>
    <!-- On reprend la même police que tes autres pages -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* Exactement les mêmes variables que effectifs.ejs */
        :root {
            --primary: #bda581;
            --primary-glow: rgba(189, 165, 129, 0.15);
            --bg-card: rgba(15, 23, 42, 0.4);
            --bg-dark: #07090e; 
        }
        
        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-dark);
            /* Même fond premium exact */
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
            font-family: 'Montserrat', sans-serif;
            color: #e2e8f0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }

        .login-wrapper {
            animation: fadeUp 0.6s ease-out forwards;
            width: 100%;
            max-width: 400px;
            padding: 20px;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Style de carte copié sur tes .agent-card */
        .login-card {
            background: var(--bg-card);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-top: 1px solid rgba(189, 165, 129, 0.2);
            border-radius: 16px;
            padding: 45px 40px;
            text-align: center;
            position: relative;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
        }

        /* Petite ligne d'accentuation en haut identique aux cartes agents */
        .card-accent-top {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(to right, transparent, var(--primary), transparent);
            opacity: 0.5;
            border-radius: 16px 16px 0 0;
        }

        .login-logo {
            width: 120px;
            margin-bottom: 25px;
            filter: drop-shadow(0px 5px 15px rgba(0,0,0,0.5));
        }

        .login-title {
            margin: 0 0 5px 0;
            font-size: 24px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #ffffff;
        }

        .login-title span {
            /* Reprise du dégradé de ton h2 span */
            background: linear-gradient(135deg, #ffffff 0%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-subtitle {
            color: #94a3b8;
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 35px;
        }

        /* Bouton Discord revu : Fini le gros bloc bleu, place à l'élégance */
        .discord-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background-color: rgba(88, 101, 242, 0.05); /* Fond presque transparent */
            color: #e2e8f0;
            border: 1px solid rgba(88, 101, 242, 0.3); /* Bordure bleue subtile */
            padding: 14px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            width: 100%;
            box-sizing: border-box;
        }

        .discord-btn i {
            font-size: 18px;
            color: #5865F2; /* Icône aux couleurs de Discord */
            transition: all 0.3s ease;
        }

        .discord-btn:hover {
            background-color: rgba(88, 101, 242, 0.15);
            border-color: #5865F2;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(88, 101, 242, 0.15);
        }

        /* Messages d'erreur propres et intégrés */
        .error-msg {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #fca5a5;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        
        .error-msg i {
            color: #ef4444;
        }
    </style>
</head>
<body>

    <div class="login-wrapper">
        <div class="login-card">
            <div class="card-accent-top"></div>
            
            <img src="/images/bcso.png" alt="Sceau du BCSO" class="login-logo" onerror="this.style.display='none'">
            
            <h2 class="login-title">MDT <span>SYSTEM</span></h2>
            <div class="login-subtitle">Accès restreint au personnel autorisé</div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-msg">
                    <i class="fas fa-shield-alt"></i>
                    <% if (error === 'AccessDenied') { %>
                        Habilitations insuffisantes.
                    <% } else if (error === 'NotOnServer') { %>
                        Impossible de vérifier vos accréditations.
                    <% } else if (error === 'NoCode') { %>
                        Authentification annulée.
                    <% } else { %>
                        Une erreur système est survenue.
                    <% } %>
                </div>
            <% } %>

            <a href="/auth/discord" class="discord-btn">
                <i class="fab fa-discord"></i> Connexion sécurisée
            </a>
        </div>
    </div>

</body>
</html>