<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BCSO - Portail MDT</title>
    <!-- Police Montserrat pour le côté propre et institutionnel -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #bda581;
            --primary-bright: #d8c3a5;
            --primary-glow: rgba(189, 165, 129, 0.3);
            --bg-dark: #07090e;
            --bg-card: rgba(15, 23, 42, 0.65);
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-dark);
            /* Ajout d'une grille holographique très subtile et d'une grosse lueur centrale */
            background-image: 
                radial-gradient(circle at 50% 40%, rgba(189, 165, 129, 0.12), transparent 60%),
                linear-gradient(rgba(189, 165, 129, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(189, 165, 129, 0.03) 1px, transparent 1px);
            background-size: 100% 100%, 40px 40px, 40px 40px;
            font-family: 'Montserrat', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
            color: #fff;
        }

        /* Animation d'entrée */
        @keyframes scaleUp {
            0% { opacity: 0; transform: scale(0.95) translateY(20px); }
            100% { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* Lueur pulsante derrière la carte */
        @keyframes pulseGlow {
            0% { box-shadow: 0 0 40px rgba(189, 165, 129, 0.05); }
            50% { box-shadow: 0 0 60px rgba(189, 165, 129, 0.15); }
            100% { box-shadow: 0 0 40px rgba(189, 165, 129, 0.05); }
        }

        .login-card {
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(189, 165, 129, 0.25);
            border-radius: 16px;
            padding: 50px;
            width: 100%;
            max-width: 420px;
            text-align: center;
            position: relative;
            animation: scaleUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards, pulseGlow 4s infinite ease-in-out;
            box-shadow: inset 0 0 30px rgba(189, 165, 129, 0.05), 0 20px 50px rgba(0,0,0,0.8);
        }

        /* Lignes d'ornement haut et bas pour structurer */
        .card-decoration-top, .card-decoration-bottom {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 40%;
            height: 2px;
            background: var(--primary);
            box-shadow: 0 0 10px var(--primary);
        }
        .card-decoration-top { top: 0; }
        .card-decoration-bottom { bottom: 0; }

        .logo-container {
            margin-bottom: 30px;
            position: relative;
            display: inline-block;
        }

        /* Halo fort derrière le logo */
        .logo-container::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 120px;
            height: 120px;
            background: var(--primary);
            filter: blur(45px);
            opacity: 0.25;
            z-index: -1;
            border-radius: 50%;
        }

        .login-logo {
            width: 160px; /* Logo beaucoup plus grand et imposant */
            filter: drop-shadow(0 10px 15px rgba(0,0,0,0.8));
            transition: transform 0.3s ease;
        }

        .login-card:hover .login-logo {
            transform: scale(1.05);
        }

        .login-title {
            font-size: 32px;
            font-weight: 900;
            margin: 0 0 10px 0;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .login-title span {
            background: linear-gradient(to right, #fff, var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-subtitle {
            font-family: monospace;
            color: var(--primary);
            font-size: 12px;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            opacity: 0.8;
        }

        .login-subtitle::before, .login-subtitle::after {
            content: '///';
            color: rgba(189, 165, 129, 0.4);
            letter-spacing: -1px;
        }

        /* Le Bouton : Fini le bleu ! Un bouton or massif transparent qui s'illumine */
        .discord-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            background: rgba(189, 165, 129, 0.08);
            border: 1px solid var(--primary);
            color: var(--primary-bright);
            padding: 16px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 700;
            font-size: 15px;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            position: relative;
            overflow: hidden;
            box-shadow: inset 0 0 15px rgba(189, 165, 129, 0.1);
        }

        .discord-btn i {
            font-size: 20px;
        }

        /* Effet au survol hyper dynamique */
        .discord-btn:hover {
            background: var(--primary);
            color: var(--bg-dark); /* Le texte devient sombre pour contraster avec le fond or */
            box-shadow: 0 0 25px var(--primary-glow), inset 0 0 10px rgba(255,255,255,0.5);
            transform: translateY(-3px);
        }

        .discord-btn:hover i {
            animation: bounce 0.5s ease;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-3px); }
        }

        /* Zone d'erreur stylisée terminal rouge */
        .error-msg {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-left: 4px solid #ef4444;
            color: #fca5a5;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 30px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-align: left;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
        }

        .error-msg i {
            color: #ef4444;
            font-size: 18px;
        }

    </style>
</head>
<body>

    <div class="login-card">
        <div class="card-decoration-top"></div>

        <div class="logo-container">
            <!-- Toujours ton image -->
            <img src="/images/bcso.png" alt="Sceau du BCSO" class="login-logo" onerror="this.style.display='none'">
        </div>
        
        <h2 class="login-title">MDT <span>SYSTEM</span></h2>
        <div class="login-subtitle">Portail Fédéral Restreint</div>

        <!-- Gestion des erreurs EJS intacte -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-msg">
                <i class="fas fa-lock"></i>
                <div>
                    <% if (error === 'AccessDenied') { %>
                        <strong>ACCÈS REFUSÉ</strong><br>Habilitations insuffisantes pour ce matricule.
                    <% } else if (error === 'NotOnServer') { %>
                        <strong>ÉCHEC SYSTÈME</strong><br>Accréditation serveur introuvable.
                    <% } else if (error === 'NoCode') { %>
                        <strong>ANNULATION</strong><br>Processus d'authentification interrompu.
                    <% } else { %>
                        <strong>ERREUR CRITIQUE</strong><br>Anomalie système détectée.
                    <% } %>
                </div>
            </div>
        <% } %>

        <a href="/auth/discord" class="discord-btn">
            <i class="fab fa-discord"></i> Initialiser la session
        </a>

        <div class="card-decoration-bottom"></div>
    </div>

</body>
</html>