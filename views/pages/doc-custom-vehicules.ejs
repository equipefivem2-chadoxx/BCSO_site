<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.2);
        --bg-dark: #05070b;
        --bg-panel: rgba(11, 15, 25, 0.75);
        --text-main: #e2e8f0;
        --border-glow: rgba(189, 165, 129, 0.25);
        --success: #10b981;
        --info: #38bdf8;
        --warning: #f59e0b;
        --danger: #ef4444;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            linear-gradient(rgba(189, 165, 129, 0.01) 1px, transparent 1px),
            linear-gradient(90deg, rgba(189, 165, 129, 0.01) 1px, transparent 1px);
        background-size: 30px 30px;
        font-family: 'Montserrat', sans-serif; 
        color: var(--text-main); 
        min-height: 100vh;
    }

    @keyframes fadeUp { 
        from { opacity: 0; transform: translateY(20px); } 
        to { opacity: 1; transform: translateY(0); } 
    }
    @keyframes slideInRight { 
        from { opacity: 0; transform: translateX(20px); } 
        to { opacity: 1; transform: translateX(0); } 
    }

    .proc-wrapper { 
        max-width: 1400px; 
        margin: 40px auto 80px auto; 
        padding: 0 30px; 
        animation: fadeUp 0.5s ease-out forwards;
        margin-left: 300px; 
    }

    .proc-header { 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        margin-bottom: 35px; 
        background: var(--bg-panel); 
        padding: 25px 35px; 
        border-radius: 16px; 
        border-top: 1px solid var(--border-glow); 
        backdrop-filter: blur(20px); 
        box-shadow: 0 15px 35px rgba(0,0,0,0.4); 
    }

    .btn-back { 
        background: rgba(189, 165, 129, 0.08); 
        border: 1px solid rgba(189, 165, 129, 0.3); 
        color: var(--primary); 
        padding: 12px 22px; 
        border-radius: 8px; 
        font-weight: 800; 
        text-transform: uppercase; 
        text-decoration: none; 
        transition: 0.3s ease; 
        display: inline-flex; 
        align-items: center; 
        gap: 10px; 
        letter-spacing: 1px;
        font-size: 0.8rem;
    }
    .btn-back:hover { 
        background: var(--primary); 
        color: #05070b; 
        box-shadow: 0 0 15px var(--primary-glow); 
        transform: translateX(-3px);
    }

    .proc-title { text-align: right; }
    .proc-title h1 { font-size: 26px; font-weight: 900; margin: 0; color: #fff; text-transform: uppercase; letter-spacing: 2px; }
    .proc-title p { color: var(--primary); margin: 5px 0 0 0; font-weight: 700; font-size: 13px; letter-spacing: 3px; text-transform: uppercase; }

    .formation-nav {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 30px;
    }
    .form-nav-btn {
        background: rgba(6, 9, 15, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.03);
        color: #94a3b8;
        padding: 16px 10px;
        border-radius: 10px;
        font-family: 'Montserrat', sans-serif;
        font-weight: 800;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.25s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .form-nav-btn:hover { background: rgba(255,255,255,0.02); color: #fff; }
    .form-nav-btn.active {
        background: linear-gradient(180deg, rgba(189, 165, 129, 0.15) 0%, rgba(189,165,129,0.02) 100%);
        color: var(--primary); border: 1px solid var(--primary); box-shadow: 0 5px 15px rgba(189, 165, 129, 0.05);
    }

    .formation-pane { display: none; animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .formation-pane.active { display: block; }

    .main-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 30px; }
    .tactical-details { display: flex; flex-direction: column; gap: 20px; }

    .info-panel {
        background: var(--bg-panel); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.02);
        border-left: 4px solid var(--primary); border-radius: 12px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .info-panel h2 { margin: 0 0 20px 0; color: #fff; font-size: 1.25rem; text-transform: uppercase; font-weight: 800; letter-spacing: 1px; display: flex; align-items: center; gap: 10px; }
    .info-panel h2 span { color: var(--primary); }
    
    .tactical-list { margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 12px; }
    .tactical-list li { color: #cbd5e1; font-size: 0.95rem; font-weight: 600; line-height: 1.5; }
    .tactical-list li strong { color: #fff; }

    .use-case-box { background: rgba(10, 15, 30, 0.4); border: 1px solid rgba(255,255,255,0.02); border-radius: 12px; padding: 25px; }
    .use-case-box h3 { margin: 0 0 12px 0; font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--primary); }
    .use-case-text { color: #94a3b8; font-size: 0.9rem; line-height: 1.6; margin: 0; font-weight: 600; }

    .visuals-column { display: flex; flex-direction: column; gap: 20px; }
    .media-tactical-card { background: rgba(4, 6, 10, 0.5); border: 1px solid rgba(255,255,255,0.03); border-radius: 12px; padding: 12px; }
    .media-image-wrapper { width: 100%; height: 250px; border-radius: 8px; overflow: hidden; background: #000; border: 1px solid rgba(255,255,255,0.05); }
    .media-image-wrapper img { width: 100%; height: 100%; object-fit: cover; opacity: 0.8; }
    
    .academy-footer { margin-top: 40px; text-align: center; padding: 15px; border-top: 1px dashed rgba(255,255,255,0.05); color: #475569; font-size: 0.75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; }
</style>

<div class="proc-wrapper">
    <div class="proc-header">
        <a href="/documents" class="btn-back"><i class="fas fa-chevron-left"></i> Retour aux Documents</a>
        <div class="proc-title">
            <h1>Customisation Véhicules</h1>
            <p>Sheriff Academy - Procédure Officielle</p>
        </div>
    </div>

    <div class="formation-nav">
        <button class="form-nav-btn active" onclick="switchFormation('peinture', this)"><i class="fas fa-paint-roller"></i> 1. Peinture</button>
        <button class="form-nav-btn" onclick="switchFormation('stickers', this)"><i class="fas fa-star"></i> 2. Stickers</button>
        <button class="form-nav-btn" onclick="switchFormation('matricule', this)"><i class="fas fa-hashtag"></i> 3. Matricule Toit</button>
    </div>

    <!-- M1 : PEINTURE -->
    <div id="peinture" class="formation-pane active">
        <div class="main-grid">
            <div class="tactical-details">
                <div class="info-panel">
                    <h2><span>01 /</span> Code Couleur Officiel</h2>
                    <p style="color: #f1f5f9; font-size: 1.05rem; font-weight: 700; margin-bottom: 20px; line-height: 1.5;">
                        Tout véhicule d'intervention du BCSO doit strictement respecter le code couleur imposé par la direction.
                    </p>
                    <ul class="tactical-list">
                        <li><strong>Catégorie :</strong> Métallique</li>
                        <li><strong>Couleur Principale :</strong> Reference 1</li>
                        <li><strong>Couleur Secondaire :</strong> Reference 1</li>
                    </ul>
                </div>
            </div>
            <div class="visuals-column">
                <!-- NOUVELLE IMAGE AJOUTÉE ICI -->
                <div class="media-tactical-card">
                    <div class="media-image-wrapper">
                        <img src="/images/custom_peinture.png" alt="Aperçu Peinture" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1616423640778-28d1b53229bd?q=80&w=1000'">
                    </div>
                </div>
                <div class="use-case-box" style="border-left: 4px solid var(--info); background: rgba(56, 189, 248, 0.03);">
                    <h3>Chemin au LS Custom</h3>
                    <p class="use-case-text" style="color: #7dd3fc;">Menu Custom Véhicules > Repeindre > Couleurs Principale & Secondaire en Métallique : Reference 56.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- M2 : STICKERS -->
    <div id="stickers" class="formation-pane">
        <div class="main-grid">
            <div class="tactical-details">
                <div class="info-panel" style="border-left-color: var(--info);">
                    <h2><span>02 /</span> Pose des Stickers</h2>
                    <p style="color: #cbd5e1; margin-bottom: 20px; font-weight: 600;">
                        Appliquez les stickers officiels du BCSO sur les flancs du véhicule, comme sur l'image. 
                    </p>
                </div>
            </div>
            <div class="visuals-column">
                <div class="media-tactical-card">
                    <div class="media-image-wrapper">
                        <img src="/images/custom_stickers.png" alt="Aperçu Stickers" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1616423640778-28d1b53229bd?q=80&w=1000'">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- M3 : MATRICULE -->
    <div id="matricule" class="formation-pane">
        <div class="main-grid">
            <div class="tactical-details">
                <div class="info-panel" style="border-left-color: var(--warning);">
                    <h2><span>03 /</span> Matricule sur le Toit</h2>
                    <p style="color: #fff; font-weight: 700; margin-bottom: 20px;">
                        Ne pas oublier de mettre le matricule de l'agent le plus haut gradé sur le haut du véhicule.
                    </p>
                </div>
                <div class="use-case-box" style="border-left: 4px solid var(--primary); background: rgba(189, 165, 129, 0.05);">
                    <h3>Exemple d'Application</h3>
                    <p class="use-case-text" style="color: #fff; font-weight: 600;">
                        Si vous êtes Junior et que vous patrouillez avec le Sheriff Pickens, ajoutez le matricule 100, même si c'est vous qui réalisez la customisation.
                    </p>
                </div>
            </div>
            <div class="visuals-column">
                <div class="media-tactical-card">
                    <div class="media-image-wrapper">
                        <img src="/images/custom_toit.png" alt="Matricule sur le toit" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1541899481282-d53bffe3c35d?q=80&w=1000'">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="academy-footer">Blaine County Sheriff's Office — Official Manual</div>
</div>

<script>
    function switchFormation(paneId, buttonElement) {
        document.querySelectorAll('.form-nav-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.formation-pane').forEach(pane => pane.classList.remove('active'));
        buttonElement.classList.add('active');
        document.getElementById(paneId).classList.add('active');
    }
</script>