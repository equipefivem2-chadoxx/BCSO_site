<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>BCSO - Détail Archive</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;800;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #bda581;
            --primary-glow: rgba(189, 165, 129, 0.15);
            --bg-dark: #07090e;
            --bg-card: rgba(15, 23, 42, 0.4);
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
        }

        body {
            margin: 0;
            background-color: var(--bg-dark);
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
            font-family: 'Montserrat', sans-serif;
            color: var(--text-main);
            min-height: 100vh;
        }

        @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        #mdt-container { 
            max-width: 1200px; 
            margin: 60px auto; 
            padding: 0 20px 100px 20px; 
            animation: fadeUp 0.6s ease-out forwards; 
        }
        
        .mdt-header { 
            display: flex; justify-content: space-between; align-items: center; 
            border-bottom: 1px solid rgba(189, 165, 129, 0.2); 
            padding-bottom: 25px; margin-bottom: 40px; 
        }
        
        .btn-back { 
            background: rgba(189, 165, 129, 0.05); color: var(--primary); 
            padding: 10px 20px; border-radius: 8px; text-decoration: none; 
            font-weight: 700; border: 1px solid rgba(189, 165, 129, 0.3); 
            transition: all 0.3s ease; display: flex; align-items: center; gap: 8px; 
        }
        .btn-back:hover { 
            background: var(--primary); color: #000; 
            box-shadow: 0 0 15px var(--primary-glow); 
        }
        
        .btn-delete { 
            background: rgba(239, 68, 68, 0.1); color: #ef4444; 
            border: 1px solid rgba(239, 68, 68, 0.3); padding: 10px 20px; 
            border-radius: 8px; font-weight: 700; cursor: pointer; 
            transition: all 0.3s ease; display: flex; align-items: center; gap: 8px; 
        }
        .btn-delete:hover { 
            background: #ef4444; color: #fff; 
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.3); 
        }

        .title-gradient {
            background: linear-gradient(135deg, #ffffff 0%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 900;
            font-size: 2.2rem;
            margin: 0;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .info-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); 
            gap: 24px; margin-bottom: 50px; 
        }
        
        .premium-card {
            background: var(--bg-card);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-top: 1px solid rgba(189, 165, 129, 0.1);
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
            position: relative;
            overflow: hidden;
        }
        .premium-card:hover { transform: translateY(-3px); box-shadow: 0 10px 25px var(--primary-glow); border-color: rgba(189, 165, 129, 0.3); }
        .card-accent { position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: linear-gradient(to bottom, var(--primary), transparent); opacity: 0.8; }
        
        .info-label { color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 800; margin-bottom: 12px; display: block; }
        .info-value { color: #fff; font-size: 1.1rem; font-weight: 700; display: flex; align-items: center; gap: 12px; }
        .info-icon { color: var(--primary); background: rgba(189, 165, 129, 0.1); padding: 10px; border-radius: 8px; font-size: 14px; }

        .thread-section { background: rgba(15, 23, 42, 0.2); border: 1px solid rgba(255, 255, 255, 0.03); border-radius: 16px; margin-bottom: 30px; overflow: hidden; backdrop-filter: blur(5px); }
        .thread-header { background: rgba(189, 165, 129, 0.03); padding: 20px 30px; border-bottom: 1px solid rgba(189, 165, 129, 0.1); display: flex; align-items: center; gap: 15px; }
        .thread-icon { color: var(--primary); font-size: 18px; }
        .thread-title-text { color: var(--primary); font-size: 1rem; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; }
        .thread-body { padding: 30px; display: flex; flex-direction: column; gap: 25px; }
        
        .msg-item { display: flex; flex-direction: column; gap: 12px; border-bottom: 1px dashed rgba(255, 255, 255, 0.05); padding-bottom: 20px; }
        .msg-item:last-child { border-bottom: none; padding-bottom: 0; }
        .msg-header { display: flex; justify-content: space-between; align-items: center; }
        .msg-author { color: #fff; font-weight: 800; font-size: 0.95rem; display: flex; align-items: center; gap: 10px; }
        .msg-author i { color: var(--primary); font-size: 16px; }
        .msg-date { color: var(--text-muted); font-size: 0.8rem; font-weight: 600; }
        
        .msg-content { color: var(--text-main); font-size: 0.95rem; line-height: 1.7; white-space: pre-wrap; padding-left: 26px; border-left: 2px solid rgba(189, 165, 129, 0.3); word-wrap: break-word; overflow-wrap: break-word; }
        
        .msg-images { display: flex; gap: 15px; flex-wrap: wrap; margin-top: 15px; padding-left: 26px; }
        .evidence-img { height: 150px; border-radius: 10px; border: 1px solid rgba(189, 165, 129, 0.3); cursor: pointer; transition: 0.3s; object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        .evidence-img:hover { transform: translateY(-5px); box-shadow: 0 10px 20px var(--primary-glow); border-color: var(--primary); }
        .broken-img-badge { background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 10px 15px; border-radius: 8px; font-size: 0.85rem; font-weight: 700; border: 1px solid rgba(239, 68, 68, 0.3); display: inline-block; }

        .final-report-wrapper { margin-top: 50px; background: var(--bg-card); border: 1px solid var(--primary); border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.4); position: relative; backdrop-filter: blur(10px); }
        .final-report-wrapper::before { content: 'RAPPORT OFFICIEL'; position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: var(--bg-dark); color: var(--primary); padding: 4px 25px; font-weight: 900; letter-spacing: 4px; font-size: 0.8rem; border: 1px solid var(--primary); border-radius: 20px; }
        .final-report-body { padding: 50px 40px; }
        
        .report-field { margin-bottom: 30px; }
        .report-label { color: var(--primary); font-size: 0.8rem; text-transform: uppercase; font-weight: 900; margin-bottom: 12px; display: block; letter-spacing: 2px; }
        .report-value { background: rgba(0, 0, 0, 0.4); padding: 20px 25px; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.03); color: #f8fafc; line-height: 1.8; font-size: 0.95rem; white-space: pre-wrap; word-wrap: break-word; border-left: 3px solid rgba(189, 165, 129, 0.5); }
        .report-hr { border: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(189, 165, 129, 0.4), transparent); margin: 40px 0; }
    </style>
</head>
<body>

<!-- 🔒 Données sécurisées -->
<div id="messages-secure-data" style="display: none;" data-json="<%= JSON.stringify(ticket.messages || []) %>"></div>

<div id="mdt-container">
    <div class="mdt-header">
        <a href="/archives" class="btn-back"><i class="fas fa-arrow-left"></i> RETOUR</a>
        <h1 class="title-gradient">ARCHIVE #<%= ticket.channelName %></h1>
        <div>
            <% 
            const aLeDroit = (typeof agentConnecte !== 'undefined' && agentConnecte && (agentConnecte.canDeleteArchives || agentConnecte.isAdmin));
            if (aLeDroit) { 
            %>
                <form action="/archives/supprimer/<%= ticket._id.toString() %>" method="POST" onsubmit="return confirm('⚠️ ATTENTION : Supprimer définitivement ce dossier du BCSO ? Cette action est irréversible.');">
                    <button type="submit" class="btn-delete"><i class="fas fa-trash-alt"></i> SUPPRIMER</button>
                </form>
            <% } else { %>
                <div style="width: 130px;"></div>
            <% } %>
        </div>
    </div>

    <div class="info-grid">
        <div class="premium-card">
            <div class="card-accent"></div>
            <span class="info-label">Date de clôture</span>
            <div class="info-value"><i class="fas fa-calendar-check info-icon"></i> <%= new Date(ticket.dateCreation).toLocaleString('fr-FR') %></div>
        </div>
        <div class="premium-card">
            <div class="card-accent"></div>
            <span class="info-label">Ouvert par</span>
            <div class="info-value"><i class="fas fa-folder-open info-icon"></i> <%= ticket.openedBy %></div>
        </div>
        <div class="premium-card">
            <div class="card-accent"></div>
            <span class="info-label">Clôturé par</span>
            <div class="info-value"><i class="fas fa-user-shield info-icon"></i> <%= ticket.closedBy %></div>
        </div>
    </div>

    <div id="dynamic-content"></div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const secureContainer = document.getElementById('messages-secure-data');
        const messages = JSON.parse(secureContainer.getAttribute('data-json') || '[]');
        
        const container = document.getElementById('dynamic-content');
        const threads = { "GÉNÉRAL": [] };
        let currentThread = "GÉNÉRAL";
        let finalReportHtml = "";

        // Parseur du Rapport Final
        function parseFinalReport(text) {
            let cleanText = text
                .replace(/╔════════════════════╗/g, '')
                .replace(/🚨 TITRE OPÉRATION 🚨/g, '')
                .replace(/╚════════════════════╝/g, '')
                .replace(/━━━━━━━━━━━━━━━━━━━━/g, '<hr class="report-hr">')
                .replace(/Décrivez précisément les faits, le déroulement de l'intervention et son dénouement\.\.\./g, '');

            const regexFields = /(📅 Date \/ Heure :|📍 Secteur :|⚖️ Infraction :|👥 Suspects(?:\s*:)??|🎭 Otages(?:\s*:)??|🚗 Véhicules Impliqués(?:\s*:)??|🚗 Véhicules(?:\s*:)??|📢 Revendications(?:\s*:)??|🎖️ Lead Terrain :|🤝 Lead Négociations :|📝 Rapport d'Opération|Compte-rendu :|COMPTE-RENDU :)/gi;

            let parts = cleanText.split(regexFields);
            let parsedOutput = "";
            let currentLabel = "";

            for (let i = 0; i < parts.length; i++) {
                let part = parts[i] ? parts[i].trim() : '';
                if (!part) continue;

                if (part.match(regexFields)) {
                    currentLabel = part;
                } else {
                    if (currentLabel) {
                        parsedOutput += `
                            <div class="report-field">
                                <span class="report-label">${currentLabel}</span>
                                <div class="report-value">${part}</div>
                            </div>
                        `;
                        currentLabel = "";
                    } else {
                        if(part !== '<hr class="report-hr">') {
                            parsedOutput += `<div class="report-value" style="margin-bottom: 20px;">${part}</div>`;
                        } else {
                            parsedOutput += part;
                        }
                    }
                }
            }
            return parsedOutput;
        }

        function formatTime(timeStr) {
            if (!timeStr) return "Date inconnue";
            const d = new Date(timeStr);
            return !isNaN(d.getTime()) ? d.toLocaleString('fr-FR') : timeStr;
        }

        // Nettoyage et organisation des messages
        messages.forEach(msg => {
            let contentText = msg.content ? msg.content.trim() : '';

            if (contentText === '*Message vide ou embed non pris en charge*') return;

            const sectionMatch = contentText.match(/DÉBUT DE LA SECTION : (.*?)\*\*/i);
            if (sectionMatch) {
                currentThread = sectionMatch[1].trim().toUpperCase();
                if (!threads[currentThread]) threads[currentThread] = [];
                return;
            }

            if (contentText.includes('🚨 TITRE OPÉRATION 🚨') || contentText.includes('╔════════════════════╗')) {
                finalReportHtml += parseFinalReport(contentText);
                return;
            }

            let images = [];
            
            // 🚀 CORRECTION IMAGES : Extraction d'URL ultra robuste via Regex
            if (contentText.includes('[IMAGE]')) {
                const parts = contentText.split('[IMAGE]');
                contentText = parts[0].trim();
                
                // On cherche n'importe quelle URL valide (http ou https) dans ce qui suit le tag
                const urlRegex = /(https?:\/\/[^\s"'<>]+)/g;
                const urlsTrouvees = parts[1].match(urlRegex);
                
                if (urlsTrouvees) {
                    urlsTrouvees.forEach(url => images.push(url));
                }
            }
            
            if (msg.attachments && Array.isArray(msg.attachments)) {
                msg.attachments.forEach(att => {
                    let url = att.url || (typeof att === 'string' ? att : '');
                    if (url.startsWith('http')) images.push(url);
                });
            }

            if (contentText !== "" || images.length > 0) {
                threads[currentThread].push({
                    author: msg.author || "Système",
                    time: msg.timestamp || "",
                    text: contentText,
                    pics: images
                });
            }
        });

        let htmlOutput = "";

        // 1. On injecte D'ABORD les discussions et salons
        for (const [threadName, msgs] of Object.entries(threads)) {
            if (msgs.length === 0) continue;

            htmlOutput += `
                <div class="thread-section">
                    <div class="thread-header">
                        <i class="fas fa-comments thread-icon"></i>
                        <span class="thread-title-text">${threadName}</span>
                    </div>
                    <div class="thread-body">
            `;

            msgs.forEach(m => {
                let picsHtml = "";
                if (m.pics.length > 0) {
                    picsHtml = `<div class="msg-images">`;
                    m.pics.forEach(pic => {
                        // Ajout d'une sécurité onerror : si l'image Discord est expirée, on affiche un badge propre au lieu d'une image cassée.
                        picsHtml += `
                            <div>
                                <a href="${pic}" target="_blank">
                                    <img src="${pic}" class="evidence-img" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-block';">
                                    <span class="broken-img-badge" style="display:none;"><i class="fas fa-link-slash"></i> Lien image expiré</span>
                                </a>
                            </div>
                        `;
                    });
                    picsHtml += `</div>`;
                }

                let textHtml = m.text ? `<div class="msg-content">${m.text}</div>` : '';

                htmlOutput += `
                    <div class="msg-item">
                        <div class="msg-header">
                            <span class="msg-author"><i class="fas fa-user-circle"></i> ${m.author}</span>
                            <span class="msg-date">${formatTime(m.time)}</span>
                        </div>
                        ${textHtml}
                        ${picsHtml}
                    </div>
                `;
            });
            htmlOutput += `</div></div>`;
        }

        // 2. On injecte ENSUITE le rapport d'opération (tout en bas)
        if (finalReportHtml !== "") {
            htmlOutput += `
                <div class="final-report-wrapper">
                    <div class="final-report-body">
                        <h3 style="color: var(--primary); font-weight: 900; letter-spacing: 2px; text-transform: uppercase; margin-top: 0; margin-bottom: 40px; text-align: center;"><i class="fas fa-file-signature"></i> COMPTE-RENDU SYNTHÉTIQUE</h3>
                        ${finalReportHtml}
                    </div>
                </div>
            `;
        }

        container.innerHTML = htmlOutput || `
            <div style="text-align: center; color: var(--text-muted); padding: 50px 20px; background: var(--bg-card); border-radius: 16px; border: 1px dashed rgba(189,165,129,0.2);">
                <i class="fas fa-folder-open" style="font-size: 30px; color: var(--primary); margin-bottom: 15px;"></i>
                <p style="margin: 0; font-weight: 600;">Aucune transcription textuelle ou rapport trouvé pour ce dossier.</p>
            </div>
        `;
    });
</script>

</body>
</html>