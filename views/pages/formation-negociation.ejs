<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.2);
        --bg-dark: #05070b;
        --bg-panel: rgba(11, 15, 25, 0.75);
        --text-main: #e2e8f0;
        --border-glow: rgba(189, 165, 129, 0.25);
        --success: #10b981;
        --info: #38bdf8;
        --warning: #f59e0b;
        --danger: #ef4444;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            linear-gradient(rgba(189, 165, 129, 0.01) 1px, transparent 1px),
            linear-gradient(90deg, rgba(189, 165, 129, 0.01) 1px, transparent 1px);
        background-size: 30px 30px;
        font-family: 'Montserrat', sans-serif; 
        color: var(--text-main); 
        min-height: 100vh;
    }

    @keyframes fadeUp { 
        from { opacity: 0; transform: translateY(20px); } 
        to { opacity: 1; transform: translateY(0); } 
    }
    @keyframes slideInRight { 
        from { opacity: 0; transform: translateX(20px); } 
        to { opacity: 1; transform: translateX(0); } 
    }

    .proc-wrapper { 
        max-width: 1400px; 
        margin: 40px auto 80px auto; 
        padding: 0 30px; 
        animation: fadeUp 0.5s ease-out forwards;
        margin-left: 300px; 
    }

    /* HEADER TACTIQUE */
    .proc-header { 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        margin-bottom: 35px; 
        background: var(--bg-panel); 
        padding: 25px 35px; 
        border-radius: 16px; 
        border-top: 1px solid var(--border-glow); 
        backdrop-filter: blur(20px); 
        box-shadow: 0 15px 35px rgba(0,0,0,0.4); 
    }

    .btn-back { 
        background: rgba(189, 165, 129, 0.08); 
        border: 1px solid rgba(189, 165, 129, 0.3); 
        color: var(--primary); 
        padding: 12px 22px; 
        border-radius: 8px; 
        font-weight: 800; 
        text-transform: uppercase; 
        text-decoration: none; 
        transition: 0.3s ease; 
        display: inline-flex; 
        align-items: center; 
        gap: 10px; 
        letter-spacing: 1px;
        font-size: 0.8rem;
    }
    .btn-back:hover { 
        background: var(--primary); 
        color: #05070b; 
        box-shadow: 0 0 15px var(--primary-glow); 
        transform: translateX(-3px);
    }

    .proc-title { text-align: right; }
    .proc-title h1 { 
        font-size: 26px; 
        font-weight: 900; 
        margin: 0; 
        color: #fff; 
        text-transform: uppercase; 
        letter-spacing: 2px; 
    }
    .proc-title p { 
        color: var(--primary); 
        margin: 5px 0 0 0; 
        font-weight: 700; 
        font-size: 13px; 
        letter-spacing: 3px; 
        text-transform: uppercase; 
    }

    /* BARRE D'ONGLETS MODULARISÉE */
    .formation-nav {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
        margin-bottom: 30px;
    }
    .form-nav-btn {
        background: rgba(6, 9, 15, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.03);
        color: #94a3b8;
        padding: 16px 10px;
        border-radius: 10px;
        font-family: 'Montserrat', sans-serif;
        font-weight: 800;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.25s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .form-nav-btn:hover {
        background: rgba(255,255,255,0.02);
        color: #fff;
    }
    .form-nav-btn.active {
        background: linear-gradient(180deg, rgba(189, 165, 129, 0.15) 0%, rgba(189,165,129,0.02) 100%);
        color: var(--primary);
        border: 1px solid var(--primary);
        box-shadow: 0 5px 15px rgba(189, 165, 129, 0.05);
    }

    .formation-pane { 
        display: none; 
        animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; 
    }
    .formation-pane.active { display: block; }

    .main-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 30px;
    }

    /* CONTENUS TEXTUELS */
    .tactical-details {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .info-panel {
        background: var(--bg-panel);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255,255,255,0.02);
        border-left: 4px solid var(--primary);
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .info-panel h2 {
        margin: 0 0 20px 0;
        color: #fff;
        font-size: 1.25rem;
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .info-panel h2 span { color: var(--primary); }
    
    .tactical-list {
        margin: 0;
        padding-left: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .tactical-list li {
        color: #cbd5e1;
        font-size: 0.95rem;
        font-weight: 600;
        line-height: 1.5;
    }
    .tactical-list li strong {
        color: #fff;
    }

    /* BLOCS DE DOCTRINE SÉCURISÉ */
    .use-case-box {
        background: rgba(10, 15, 30, 0.4);
        border: 1px solid rgba(255,255,255,0.02);
        border-radius: 12px;
        padding: 25px;
    }
    .use-case-box h3 {
        margin: 0 0 12px 0;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--primary);
    }
    .use-case-text {
        color: #94a3b8;
        font-size: 0.9rem;
        line-height: 1.6;
        margin: 0;
        font-weight: 600;
    }

    .doctrine-rule {
        border-left: 4px solid var(--danger);
        background: rgba(239, 68, 68, 0.03);
    }

    /* COMM' DO & DON'T TABLES */
    .comm-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .comm-card {
        border-radius: 10px;
        padding: 20px;
    }
    .comm-card.card-do {
        background: rgba(16, 185, 129, 0.03);
        border: 1px solid rgba(16, 185, 129, 0.15);
    }
    .comm-card.card-dont {
        background: rgba(239, 68, 68, 0.03);
        border: 1px solid rgba(239, 68, 68, 0.15);
    }
    .comm-card h4 {
        margin: 0 0 15px 0;
        text-transform: uppercase;
        font-size: 0.9rem;
        font-weight: 800;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .comm-card.card-do h4 { color: var(--success); }
    .comm-card.card-dont h4 { color: var(--danger); }

    /* VISUELS ET CAPTURES LIÉES */
    .visuals-column {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    
    .media-tactical-card {
        background: rgba(4, 6, 10, 0.5);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 12px;
        padding: 12px;
        cursor: pointer;
        transition: 0.3s ease;
    }
    .media-tactical-card:hover {
        border-color: var(--primary);
        background: rgba(189, 165, 129, 0.02);
        transform: translateY(-2px);
    }

    .media-image-wrapper {
        width: 100%;
        height: 250px;
        border-radius: 8px;
        overflow: hidden;
        background: #000;
        border: 1px solid rgba(255,255,255,0.05);
    }
    .media-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.8;
        transition: 0.5s ease;
    }
    .media-tactical-card:hover .media-image-wrapper img {
        opacity: 0.95;
    }

    .media-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 10px;
        padding: 0 5px;
    }
    .media-label span {
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #64748b;
    }
    .media-tactical-card:hover .media-label span { color: var(--primary); }

    /* LIGHTBOX ZOOM */
    .zoom-modal {
        display: none; position: fixed; z-index: 99999; left: 0; top: 0; width: 100%; height: 100%; background: rgba(3, 5, 8, 0.97); backdrop-filter: blur(12px);
        justify-content: center; align-items: center; opacity: 0; transition: opacity 0.3s ease;
    }
    .zoom-modal.active { display: flex; opacity: 1; }
    .modal-container { position: relative; width: 85%; height: 85%; display: flex; justify-content: center; align-items: center; }
    .modal-container img { max-width: 100%; max-height: 100%; object-fit: contain; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); }
    .modal-close { position: absolute; top: -50px; right: 0; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; display: flex; justify-content: center; align-items: center; }
    .modal-close:hover { background: var(--danger); }

    .academy-footer {
        margin-top: 40px; text-align: center; padding: 15px; border-top: 1px dashed rgba(255,255,255,0.05); color: #475569; font-size: 0.75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    }

    @media (max-width: 1200px) {
        .proc-wrapper { margin-left: 0; padding: 20px; }
        .main-grid { grid-template-columns: 1fr; }
        .formation-nav { grid-template-columns: 1fr; }
        .comm-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="proc-wrapper">
    
    <!-- HEADER -->
    <div class="proc-header">
        <a href="/formations" class="btn-back"><i class="fas fa-chevron-left"></i> Formations</a>
        <div class="proc-title">
            <h1>Formation Négociation</h1>
            <p>Sheriff Academy - Manuel Officiel</p>
        </div>
    </div>

    <!-- ONGLETS DE NAVIGATION -->
    <div class="formation-nav">
        <button class="form-nav-btn active" onclick="switchFormation('role', this)"><i class="fas fa-user-shield"></i> 1. Rôle & Priorités</button>
        <button class="form-nav-btn" onclick="switchFormation('contact', this)"><i class="fas fa-bullhorn"></i> 2. Premier Contact</button>
        <button class="form-nav-btn" onclick="switchFormation('otages', this)"><i class="fas fa-users-viewfinder"></i> 3. Gestion Otages</button>
        <button class="form-nav-btn" onclick="switchFormation('revendications', this)"><i class="fas fa-comments"></i> 4. Échanges & Comm'</button>
        <button class="form-nav-btn" onclick="switchFormation('cloture', this)"><i class="fas fa-flag-checkered"></i> 5. Fin de Négociation</button>
    </div>

    <!-- ============================================== -->
    <!-- M1 : RÔLE & PRIORITÉS -->
    <!-- ============================================== -->
    <div id="role" class="formation-pane active">
        <div class="main-grid">
            <div class="tactical-details">
                <div class="info-panel">
                    <h2><span>01 /</span> Le Rôle du Négociateur</h2>
                    <p style="color: #f1f5f9; font-size: 1.05rem; font-weight: 700; margin-bottom: 20px; line-height: 1.5;">
                        Le négociateur est l'interlocuteur unique entre les braqueurs et les forces de l'ordre.
                    </p>
                    <h3 style="font-size: 0.85rem; text-transform: uppercase; color: var(--primary); margin-bottom: 10px;">Ses missions fondamentales :</h3>
                    <ul class="tactical-list">
                        <li>Instaurer un dialogue calme.</li>
                        <li>Recueillir les informations nécessaires.</li>
                        <li>S'assurer du bon état des otages.</li>
                        <li>Transmettre les demandes au commandement.</li>
                        <li>Maintenir une négociation fluide jusqu'à la sortie.</li>
                    </ul>
                </div>

                <div class="info-panel" style="border-left-color: var(--info);">
                    <h2><span>02 /</span> Les Priorités Absolues</h2>
                    <ul class="tactical-list">
                        <li><strong>LES OTAGES :</strong> Leur sécurité est la priorité absolue.</li>
                        <li><strong>LES INFORMATIONS :</strong> Chaque échange doit permettre d'obtenir davantage d'informations.</li>
                        <li><strong>LE CONTRÔLE :</strong> Une négociation doit rester calme et organisée.</li>
                    </ul>
                </div>

                <div class="use-case-box doctrine-rule">
                    <h3><i class="fas fa-gavel"></i> Règle de commandement impérative</h3>
                    <p class="use-case-text" style="color: #fca5a5;">
                        Le négociateur ne décide jamais seul des concessions.
                    </p>
                </div>
            </div>
            <div class="visuals-column">
                <div class="media-tactical-card" onclick="triggerZoom('/images/nego_bureau.png')">
                    <div class="media-image-wrapper">
                        <img src="/images/nego_bureau.png" alt="Bureau Négociation" onerror="this.src='https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=1000'">
                    </div>
                    <div class="media-label"><span></span><i class="fas fa-search-plus"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================== -->
    <!-- M2 : PREMIER CONTACT -->
    <!-- ============================================== -->
    <div id="contact" class="formation-pane">
        <div class="main-grid">
            <div class="tactical-details">
                <div class="info-panel">
                    <h2><span>03 /</span> Premier Contact</h2>
                    <p style="color: #cbd5e1; margin-bottom: 20px; font-weight: 600;">
                        Le premier échange est primordial. Le négociateur applique scrupuleusement la feuille de route suivante :
                    </p>
                    <ul class="tactical-list">
                        <li>Se présente.</li>
                        <li>Demande qui est le responsable des négociations.</li>
                        <li>Établit un climat calme.</li>
                        <li>Explique que son objectif est de trouver une solution.</li>
                    </ul>
                </div>

                <div class="info-panel" style="border-left-color: var(--info);">
                    <h2><span>04 /</span> Collecte d'Informations Cibles</h2>
                    <p style="color: #cbd5e1; margin-bottom: 15px; font-weight: 600;">Pendant la négociation, le négociateur cherche continuellement à obtenir :</p>
                    <ul class="tactical-list" style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                        <li>• Nombre exact de braqueurs.</li>
                        <li>• Nombre exact d'otages.</li>
                        <li>• État des otages.</li>
                        <li>• Revendications.</li>
                        <li>• Véhicule souhaité.</li>
                        <li>• Conditions de sortie.</li>
                    </ul>
                </div>

                <div class="use-case-box" style="border-left: 4px solid var(--warning); background: rgba(245, 158, 11, 0.03);">
                    <h3><i class="fas fa-radio"></i> Protocole Radio Réseau</h3>
                    <p class="use-case-text" style="color: #fde047;">
                        Toutes les informations doivent être annoncées à la radio pour la synchronisation des unités en attente.
                    </p>
                </div>
            </div>
            <div class="visuals-column">
                <div class="media-tactical-card" onclick="triggerZoom('/images/nego_contact.png')">
                    <div class="media-image-wrapper">
                        <img src="/images/nego_contact.png" alt="Premier Contact" onerror="this.src='https://images.unsplash.com/photo-1557804506-669a67965ba0?q=80&w=1000'">
                    </div>
                    <div class="media-label"><span>Périmètre de crise - Premier Échange</span><i class="fas fa-search-plus"></i></div>
                </div>
                <div class="use-case-box doctrine-rule" style="margin-top: -10px;">
                    <h3>Loi de négociation</h3>
                    <p class="use-case-text" style="color: #fca5a5;">Aucune négociation ne commence sans dialogue.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================== -->
    <!-- M3 : GESTION DES OTAGES -->
    <!-- ============================================== -->
    <div id="otages" class="formation-pane">
        <div class="main-grid">
            <div class="tactical-details">
                <div class="info-panel">
                    <h2><span>05 /</span> Protocole Otages</h2>
                    <p style="color: #f1f5f9; font-weight: 600; line-height: 1.6; margin-bottom: 20px;">
                        Au début de la négociation, le négociateur demande combien il y a d'otages, puis demande à voir chaque otage individuellement.
                    </p>
                    
                    <h3 style="font-size: 0.85rem; text-transform: uppercase; color: var(--primary); margin-bottom: 15px;">Grille d'évaluation (Pour chaque otage) :</h3>
                    <ul class="tactical-list">
                        <li><strong>Son état général :</strong> Posez la question directe : « Est-ce que vous allez bien ? »</li>
                        <li>S'il a été frappé ou violenté.</li>
                        <li>S'il présente des blessures.</li>
                        <li>S'il nécessite une assistance médicale.</li>
                        <li>S'il a besoin de boire.</li>
                        <li>S'il a besoin de manger.</li>
                    </ul>
                </div>

                <div class="info-panel" style="border-left-color: var(--success); background: rgba(16, 185, 129, 0.02);">
                    <h2><span>06 /</span> Traçabilité administrative</h2>
                    <p style="color: #cbd5e1; font-weight: 600; margin: 0;">
                        Le négociateur relève ensuite son <strong>nom</strong> et son <strong>prénom</strong> afin d'établir un suivi précis de chaque otage. Toutes ces informations sont immédiatement transmises aux unités de secours et d'intervention.
                    </p>
                </div>
            </div>
            <div class="visuals-column">
                <div class="media-tactical-card" onclick="triggerZoom('/images/nego_otages.png')">
                    <div class="media-image-wrapper">
                        <img src="/images/nego_otages.png" alt="Suivi Otages" onerror="this.src='https://images.unsplash.com/photo-1508962914676-134849a727f0?q=80&w=1000'">
                    </div>
                    <div class="media-label"><span>Visualisation & Contrôle visuel des otages</span><i class="fas fa-search-plus"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================== -->
    <!-- M4 : REVENDICATIONS & COMMUNICATION -->
    <!-- ============================================== -->
    <div id="revendications" class="formation-pane">
        <div class="main-grid">
            <div class="tactical-details">
                <div class="info-panel">
                    <h2><span>07 /</span> Gestion des Revendications</h2>
                    <p style="color: #94a3b8; font-weight: 700; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.5px; margin-bottom: 10px;">Phase critique : Les braqueurs exposent leurs demandes.</p>
                    <p style="color: #cbd5e1; margin-bottom: 20px; font-weight: 500;">Le négociateur applique une méthodologie stricte en 4 étapes :</p>
                    <ul class="tactical-list">
                        <li>1. Écoute sans interrompre.</li>
                        <li>2. Reformule la demande.</li>
                        <li>3. Consulte le commandement.</li>
                        <li>4. Répond clairement.</li>
                    </ul>
                </div>

                <!-- TABLEAU TOUJOURS / NE JAMAIS -->
                <div class="comm-grid">
                    <div class="comm-card card-do">
                        <h4><i class="fas fa-check-circle"></i> Toujours :</h4>
                        <ul class="tactical-list" style="padding-left: 15px; gap: 8px; font-size: 0.85rem;">
                            <li>Parler calmement</li>
                            <li>Rester respectueux</li>
                            <li>Laisser parler le braqueur</li>
                            <li>Éviter les provocations</li>
                            <li>Expliquer les décisions</li>
                        </ul>
                    </div>
                    <div class="comm-card card-dont">
                        <h4><i class="fas fa-times-circle"></i> Ne Jamais :</h4>
                        <ul class="tactical-list" style="padding-left: 15px; gap: 8px; font-size: 0.85rem;">
                            <li>Couper la parole</li>
                            <li>Hausser le ton</li>
                            <li>Mentir inutilement</li>
                            <li>Répondre sous l'énervement</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="visuals-column">
                <div class="media-tactical-card" onclick="triggerZoom('/images/nego_dialogue.png')">
                    <div class="media-image-wrapper">
                        <img src="/images/nego_dialogue.png" alt="Dialogue Tactique" onerror="this.src='https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=1000'">
                    </div>
                    <div class="media-label"><span>Communication avec les individus</span><i class="fas fa-search-plus"></i></div>
                </div>
                <div class="use-case-box doctrine-rule">
                    <h3>Engagement et Clause limitative</h3>
                    <p class="use-case-text" style="color: #fca5a5;">Le négociateur ne promet jamais quelque chose qu'il ne peut pas garantir.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================== -->
    <!-- M5 : FIN DE NÉGOCIATION -->
    <!-- ============================================== -->
    <div id="cloture" class="formation-pane">
        <div class="main-grid">
            <div class="tactical-details">
                <div class="info-panel" style="border-left-color: #fff;">
                    <h2><span>08 /</span> Clôture et Fin de Négociation</h2>
                    <p style="color: var(--primary); font-weight: 800; font-size: 0.9rem; text-transform: uppercase; margin-bottom: 15px;">Une fois les conditions acceptées :</p>
                    <ul class="tactical-list">
                        <li>• Confirmer les accords.</li>
                        <li>• Rappeler les consignes de sortie.</li>
                        <li>• Surveiller la libération des otages.</li>
                        <li>• Confirmer que tous les otages sont en sécurité.</li>
                    </ul>
                </div>

                <div class="use-case-box" style="background: rgba(255,255,255,0.02);">
                    <h3><i class="fas fa-hourglass-end"></i> Transition Opérationnelle</h3>
                    <p class="use-case-text" style="color: #cbd5e1; margin-bottom: 10px;">
                        Lorsque les braqueurs quittent les lieux, la négociation est officiellement <span style="color: var(--danger); font-weight: 800;">TERMINÉE</span>.
                    </p>
                    <p class="use-case-text" style="font-size: 0.85rem; color: #94a3b8; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 10px;">
                        La suite de l'intervention relève entièrement des unités opérationnelles (généralement une poursuite selon les circonstances).
                    </p>
                </div>
            </div>
            <div class="visuals-column">
                <div class="media-tactical-card" onclick="triggerZoom('/images/nego_fin.png')">
                    <div class="media-image-wrapper">
                        <img src="/images/nego_fin.png" alt="Fin Intervention" onerror="this.src='https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=1000'">
                    </div>
                    <div class="media-label"><span>Extraction & Phase de poursuite</span><i class="fas fa-search-plus"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="academy-footer">
        Blaine County Sheriff's Office — Official Training Manual
    </div>
</div>

<!-- MODAL LIGHTBOX ZOOM -->
<div id="tacticalLightbox" class="zoom-modal" onclick="closeZoom()">
    <div class="modal-container">
        <button class="modal-close" onclick="closeZoom()"><i class="fas fa-times"></i></button>
        <img id="modalTargetImg" src="" alt="Tactical Zoom View" onclick="event.stopPropagation()">
    </div>
</div>

<script>
    function switchFormation(paneId, buttonElement) {
        document.querySelectorAll('.form-nav-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.formation-pane').forEach(pane => pane.classList.remove('active'));
        
        buttonElement.classList.add('active');
        document.getElementById(paneId).classList.add('active');
    }

    const lightbox = document.getElementById('tacticalLightbox');
    const modalImg = document.getElementById('modalTargetImg');

    function triggerZoom(imgSrc) {
        modalImg.src = imgSrc;
        lightbox.classList.add('active');
    }

    function closeZoom() {
        lightbox.classList.remove('active');
    }
</script>