<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BCSO - Authentification Système</title>
    <!-- Importation de la police du thème -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            /* Reprise EXACTE des variables de ta page effectifs */
            --primary: #bda581;
            --primary-glow: rgba(189, 165, 129, 0.15);
            --bg-card: rgba(15, 23, 42, 0.4);
            --bg-dark: #07090e;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-dark);
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
            font-family: 'Montserrat', sans-serif;
            color: #e2e8f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
        }

        @keyframes fadeUp { 
            from { opacity: 0; transform: translateY(30px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
        
        @keyframes pulseGlow {
            0% { box-shadow: 0 0 20px rgba(189, 165, 129, 0.05); }
            50% { box-shadow: 0 0 30px rgba(189, 165, 129, 0.15); }
            100% { box-shadow: 0 0 20px rgba(189, 165, 129, 0.05); }
        }

        .login-container {
            width: 100%;
            max-width: 440px;
            padding: 20px;
            animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* La carte : Calquée sur .agent-card mais dimensionnée pour le login */
        .login-card {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-top: 1px solid rgba(189, 165, 129, 0.2);
            border-radius: 16px;
            padding: 45px 40px;
            text-align: center;
            position: relative;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
            animation: pulseGlow 4s infinite alternate ease-in-out;
            overflow: hidden;
        }

        /* L'accentuation en haut, identique à card-accent-top */
        .card-accent-top {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(to right, transparent, var(--primary), transparent);
            opacity: 0.5;
        }

        /* Lueur subtile derrière le logo */
        .logo-wrapper {
            position: relative;
            display: inline-block;
            margin-bottom: 25px;
        }
        .logo-wrapper::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 80px;
            height: 80px;
            background: var(--primary);
            filter: blur(40px);
            opacity: 0.15;
            z-index: -1;
            border-radius: 50%;
        }

        .login-logo {
            width: 130px;
            filter: drop-shadow(0px 8px 12px rgba(0,0,0,0.6));
        }

        .login-title {
            margin: 0;
            color: #fff;
            font-size: 28px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .login-title span {
            background: linear-gradient(135deg, #ffffff 0%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-subtitle {
            font-size: 12px;
            color: #94a3b8;
            font-family: monospace;
            letter-spacing: 1px;
            margin-top: 8px;
            margin-bottom: 35px;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .login-subtitle::before, .login-subtitle::after {
            content: '';
            height: 1px;
            width: 20px;
            background: rgba(189, 165, 129, 0.3);
        }

        /* Le Bouton Discord : Totalement intégré au thème, zéro bleu flashy */
        .discord-btn {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            background: rgba(189, 165, 129, 0.05);
            border: 1px solid rgba(189, 165, 129, 0.2);
            color: #e2e8f0;
            padding: 15px 24px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: all 0.3s ease;
            width: 100%;
            box-sizing: border-box;
            position: relative;
            overflow: hidden;
        }

        .discord-btn i {
            color: var(--primary);
            font-size: 18px;
            transition: transform 0.3s ease;
        }

        .discord-btn:hover {
            background: rgba(189, 165, 129, 0.15);
            border-color: rgba(189, 165, 129, 0.5);
            color: #ffffff;
            box-shadow: 0 10px 25px var(--primary-glow);
            transform: translateY(-2px);
        }

        .discord-btn:hover i {
            transform: scale(1.1);
        }

        /* Zone d'erreur stylisée façon terminal */
        .error-msg {
            background: rgba(239, 68, 68, 0.05);
            border-left: 3px solid #ef4444;
            color: #fca5a5;
            padding: 12px 15px;
            border-radius: 4px;
            margin-bottom: 25px;
            font-size: 13px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            text-align: left;
        }

        .error-msg i {
            color: #ef4444;
            font-size: 16px;
        }
        
        .security-badge {
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--bg-dark);
            border: 1px solid rgba(189, 165, 129, 0.2);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 10px;
            color: var(--primary);
            font-family: monospace;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card">
            <!-- La ligne dorée au sommet -->
            <div class="card-accent-top"></div>
            
            <div class="logo-wrapper">
                <img src="/images/bcso.png" alt="Sceau du BCSO" class="login-logo" onerror="this.style.display='none'">
            </div>
            
            <h2 class="login-title">MDT <span>SYSTEM</span></h2>
            <div class="login-subtitle">Accès restreint</div>

            <!-- Gestion des erreurs EJS -->
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-msg">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                        <% if (error === 'AccessDenied') { %>
                            <strong>REFUSÉ :</strong> Habilitations insuffisantes.
                        <% } else if (error === 'NotOnServer') { %>
                            <strong>ERREUR :</strong> Accréditation serveur introuvable.
                        <% } else if (error === 'NoCode') { %>
                            <strong>ANNULÉ :</strong> Processus d'authentification interrompu.
                        <% } else { %>
                            <strong>SYSTÈME :</strong> Une erreur inattendue est survenue.
                        <% } %>
                    </div>
                </div>
            <% } %>

            <!-- Bouton totalement fondu dans l'identité visuelle -->
            <a href="/auth/discord" class="discord-btn">
                <i class="fab fa-discord"></i> Initialiser la session
            </a>

            <!-- Petit détail "Roleplay" qui rend la carte pro -->
            <div class="security-badge">CONNEXION CHIFFRÉE</div>
        </div>
    </div>

</body>
</html>