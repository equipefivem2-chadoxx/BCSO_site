<style>
    @keyframes slideIn { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
    
    #roster-container { max-width: 1400px; margin: 0 auto; padding-bottom: 70px; }
    
    .roster-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(212, 175, 55, 0.2); padding-bottom: 20px; margin-bottom: 40px; }
    .roster-header h2 { margin: 0; color: #f3f4f6; font-size: 28px; font-weight: 600; }
    .roster-header h2 span { color: #d4af37; }
    .total-badge { background: rgba(212, 175, 55, 0.1); border: 1px solid rgba(212, 175, 55, 0.3); padding: 8px 20px; border-radius: 30px; color: #d4af37; font-weight: bold; letter-spacing: 1px; }

    .grade-section { margin-bottom: 40px; animation: slideIn 0.5s ease-out backwards; }
    .grade-title { color: #9ca3af; font-size: 16px; text-transform: uppercase; letter-spacing: 3px; border-left: 3px solid #d4af37; padding-left: 15px; margin-bottom: 25px; display: flex; align-items: center; }
    
    .agents-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    
    .agent-card { background: linear-gradient(145deg, #0b0f19 0%, #111827 100%); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 10px; padding: 25px; transition: all 0.3s ease; position: relative; overflow: hidden; }
    .agent-card:hover { transform: translateY(-5px); border-color: rgba(212, 175, 55, 0.4); box-shadow: 0 10px 20px rgba(0,0,0,0.4); }
    .agent-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: #d4af37; opacity: 0.5; }
    
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
    .matricule { font-size: 22px; font-weight: 800; color: #d4af37; font-family: monospace; }
    .status-dot { width: 8px; height: 8px; background-color: #10b981; border-radius: 50%; box-shadow: 0 0 10px #10b981; }
    
    .agent-name { font-size: 18px; color: #f3f4f6; font-weight: 600; margin-bottom: 5px; }
    .agent-discord { font-size: 12px; color: #6b7280; display: flex; align-items: center; gap: 5px; }
</style>

<div id="roster-container">
    <div class="roster-header">
        <h2>Effectifs du <span>Blaine County</span></h2>
        <div class="total-badge"><i class="fas fa-users"></i> <%= (typeof total !== 'undefined') ? total : 0 %> AGENTS ACCRÉDITÉS</div>
    </div>

    <% 
    if (typeof effectifsTries !== 'undefined' && Object.keys(effectifsTries).length > 0) {
        let grades = Object.keys(effectifsTries);
        for(let i = 0; i < grades.length; i++) {
            let grade = grades[i];
            let delay = i * 0.1;
    %>
            <div class="grade-section" style="animation-delay: <%= delay %>s;">
                <h3 class="grade-title"><%= grade %></h3>
                <div class="agents-grid">
                    <% effectifsTries[grade].forEach(function(agent) { %>
                        <div class="agent-card">
                            <div class="card-header">
                                <span class="matricule">[<%= agent.matricule %>]</span>
                                <div class="status-dot"></div>
                            </div>
                            <div class="agent-name"><%= agent.prenom %> <%= agent.nom %></div>
                            <% if (agent.discordId && agent.discordId.trim() !== '') { %>
                                <div class="agent-discord"><i class="fab fa-discord"></i> Ligne Sécurisée active</div>
                            <% } else { %>
                                <div class="agent-discord" style="color: #4b5563;"><i class="fas fa-unlink"></i> Non lié</div>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            </div>
    <% 
        }
    } else { 
    %>
        <div style="text-align: center; padding: 100px 0; color: #6b7280;">
            <i class="fas fa-folder-open" style="font-size: 40px; margin-bottom: 20px; opacity: 0.3;"></i>
            <p>Les dossiers des effectifs sont actuellement vides.</p>
        </div>
    <% } %>
</div>