<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<!-- Ajout de marked.js pour lire le texte Discord (Markdown) -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --bg-card: rgba(15, 23, 42, 0.6);
        --bg-dark: #07090e;
        --text-main: #e2e8f0;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
            radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
        font-family: 'Montserrat', sans-serif;
        color: var(--text-main);
    }

    #patchnotes-container {
        margin-left: 280px;
        padding: 40px 60px 80px 60px;
        max-width: 1200px;
        animation: fadeIn 0.4s ease-out forwards;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 20px;
        margin-bottom: 40px;
    }

    .header-title h1 { color: #fff; margin: 0; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 900; font-size: 28px; }
    .header-title h1 span { color: var(--primary); }
    .header-title p { color: #94a3b8; margin-top: 5px; font-size: 14px; }

    .btn-back {
        background: rgba(189, 165, 129, 0.05);
        color: var(--primary);
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
        border: 1px solid rgba(189, 165, 129, 0.3);
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
        font-size: 13px;
    }
    .btn-back:hover { background: var(--primary); color: #000; }

    /* TIMELINE STYLING */
    .timeline {
        position: relative;
        padding-left: 30px;
        border-left: 2px solid rgba(189, 165, 129, 0.3);
        margin-top: 20px;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 40px;
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        transition: transform 0.3s ease;
    }

    .timeline-item:hover {
        transform: translateX(5px);
        border-color: rgba(189, 165, 129, 0.3);
    }

    .timeline-item::before {
        content: '';
        position: absolute;
        left: -37px;
        top: 30px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--primary);
        border: 4px solid var(--bg-dark);
        box-shadow: 0 0 10px var(--primary);
    }

    .item-header {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        margin-bottom: 10px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .item-meta { display: flex; align-items: center; gap: 15px; font-size: 12px; color: #94a3b8; font-weight: 600; }

    .btn-delete-patch {
        background: transparent;
        color: #ef4444;
        border: none;
        cursor: pointer;
        font-size: 13px;
        transition: 0.2s;
        padding: 4px 8px;
    }
    .btn-delete-patch:hover { color: #dc2626; transform: scale(1.1); }

    /* STYLES PERSONNALISÉS POUR LE RENDU DISCORD (MARKDOWN) */
    .markdown-body {
        color: #cbd5e1;
        font-size: 14px;
        line-height: 1.7;
    }
    
    .markdown-body h1 {
        color: #fff;
        font-size: 20px;
        margin: 0 0 15px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 10px;
        font-weight: 800;
    }
    
    .markdown-body h2 {
        color: var(--primary);
        font-size: 16px;
        margin-top: 25px;
        margin-bottom: 10px;
        text-transform: uppercase;
        font-weight: 700;
    }

    .markdown-body p { margin: 10px 0; }
    
    .markdown-body strong { color: #fff; }
    
    .markdown-body blockquote {
        border-left: 3px solid var(--primary);
        background: rgba(189, 165, 129, 0.05);
        padding: 10px 20px;
        margin: 15px 0;
        border-radius: 0 8px 8px 0;
    }

    .markdown-body ul { padding-left: 20px; }
    .markdown-body li { margin-bottom: 5px; }

</style>

<div id="patchnotes-container">
    <div class="header-section">
        <div class="header-title">
            <h1>Historique des <span>Patchnotes</span></h1>
            <p>Suivez en temps réel les évolutions techniques, ajouts et corrections sur le MDT et le serveur.</p>
        </div>
        <a href="/dashboard" class="btn-back"><i class="fas fa-arrow-left"></i> RETOUR</a>
    </div>

    <% if (typeof patchnotes !== 'undefined' && patchnotes.length > 0) { %>
        <div class="timeline">
            <% patchnotes.forEach(patch => { %>
                <div class="timeline-item">
                    
                    <div class="item-header">
                        <div class="item-meta">
                            <span><i class="fas fa-user" style="color: var(--primary); margin-right: 5px;"></i> <%= patch.auteur %></span>
                            <span><i class="fas fa-calendar-alt" style="color: var(--primary); margin-right: 5px;"></i> <%= new Date(patch.dateCreation).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                            
                            <% 
                            const canDelete = (typeof user !== 'undefined' && user && (
                                user.isAdmin === true || 
                                user.role === 'admin' || 
                                user.id === '1247264549489610897'
                            ));
                            %>
                            <% if (canDelete) { %>
                                <form action="/patchnotes/supprimer/<%= patch._id %>" method="POST" style="display: inline;" onsubmit="return confirm('Supprimer définitivement ce patchnote ?');">
                                    <button type="submit" class="btn-delete-patch" title="Supprimer ce patchnote"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            <% } %>
                        </div>
                    </div>

                    <!-- Ici, on stocke le contenu brut de manière invisible pour le script en bas -->
                    <textarea class="raw-markdown-content" style="display: none;"><%= patch.contenu %></textarea>
                    
                    <!-- C'est ici que le contenu rendu en HTML propre s'affichera -->
                    <div class="parsed-content markdown-body"></div>

                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div style="text-align: center; padding: 60px; background: var(--bg-card); border-radius: 12px; border: 1px dashed rgba(255,255,255,0.1);">
            <i class="fas fa-bullhorn" style="font-size: 40px; color: #475569; margin-bottom: 15px;"></i>
            <p style="color: #94a3b8; font-size: 16px; margin: 0;">Aucun patchnote publié pour le moment.</p>
        </div>
    <% } %>
</div>

<script>
    // 🔧 On force marked.js à respecter les simples retours à la ligne (comme sur Discord)
    marked.use({
        breaks: true,
        gfm: true
    });

    document.addEventListener('DOMContentLoaded', () => {
        // Dictionnaire pour remplacer le format Discord en émojis réels
        const emojis = {
            ':arrows_counterclockwise:': '🔄',
            ':date:': '📅',
            ':sparkles:': '✨',
            ':wrench:': '🔧',
            ':warning:': '⚠️',
            ':bug:': '🐛',
            ':green_circle:': '🟢',
            ':red_circle:': '🔴'
        };

        function replaceEmojis(text) {
            return text.replace(/:[a-zA-Z0-9_]+:/g, match => emojis[match] || match);
        }

        // On parcourt tous les patchnotes affichés sur la page
        document.querySelectorAll('.timeline-item').forEach(item => {
            const rawContent = item.querySelector('.raw-markdown-content').value;
            const targetDiv = item.querySelector('.parsed-content');

            // 1. On remplace les emojis Discord
            let formattedText = replaceEmojis(rawContent);
            
            // 2. On transforme le texte Discord (Markdown) en beau HTML
            targetDiv.innerHTML = marked.parse(formattedText);
        });
    });
</script>