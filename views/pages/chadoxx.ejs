<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
    /* VARIABLES & SETUP */
    :root {
        --chad-primary: #d4af37;
        --chad-dark: #07090e;
        --chad-panel: rgba(15, 20, 30, 0.85);
        --chad-danger: #ef4444;
        --chad-success: #10b981;
    }

    .chadoxx-wrapper {
        margin-left: 280px; 
        padding: 50px;
        color: #e2e8f0;
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        background: radial-gradient(circle at top right, rgba(212, 175, 55, 0.03) 0%, transparent 60%);
    }

    /* HEADER */
    .chadoxx-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        border-bottom: 1px solid rgba(212, 175, 55, 0.15);
        padding-bottom: 25px;
        margin-bottom: 35px;
    }
    .header-titles h1 {
        margin: 0;
        font-size: 2.2rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .header-titles p {
        margin: 8px 0 0 0;
        color: var(--chad-primary);
        font-weight: 700;
        letter-spacing: 2px;
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    /* NAVIGATION MODULAIRE (ONGLETS) */
    .chadoxx-nav {
        display: flex;
        gap: 15px;
        margin-bottom: 40px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        padding-bottom: 15px;
        flex-wrap: wrap;
    }
    .nav-tab {
        background: transparent;
        border: 1px solid transparent;
        color: #64748b;
        padding: 12px 25px;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 800;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .nav-tab:hover {
        color: #fff;
        background: rgba(255,255,255,0.02);
    }
    .nav-tab.active {
        background: rgba(212, 175, 55, 0.05);
        border: 1px solid rgba(212, 175, 55, 0.3);
        color: var(--chad-primary);
        box-shadow: 0 0 20px rgba(212, 175, 55, 0.05);
    }

    /* CONTENU DES ONGLETS */
    .chadoxx-pane {
        display: none;
        animation: fadeIn 0.4s ease forwards;
    }
    .chadoxx-pane.active {
        display: block;
    }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* GRILLE ET CARTES */
    .panel-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
        gap: 30px;
    }
    .admin-card {
        background: var(--chad-panel);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        padding: 35px;
        position: relative;
        overflow: hidden;
    }
    .admin-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 3px;
    }
    .card-system::before { background: var(--chad-primary); }
    
    .admin-card h2 {
        margin: 0 0 15px 0;
        font-size: 1.2rem;
        color: #fff;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .admin-card p.desc {
        color: #94a3b8;
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 25px;
        font-weight: 500;
    }

    /* ALERTS & BUTTONS */
    .status-alert {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px 20px;
        border-radius: 8px;
        font-weight: 800;
        margin-bottom: 25px;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .alert-danger { background: rgba(239, 68, 68, 0.05); color: var(--chad-danger); border: 1px solid rgba(239, 68, 68, 0.2); }
    .alert-success { background: rgba(16, 185, 129, 0.05); color: var(--chad-success); border: 1px solid rgba(16, 185, 129, 0.2); }

    .btn-killswitch {
        width: 100%;
        padding: 18px;
        font-size: 0.9rem;
        font-weight: 900;
        font-family: inherit;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 2px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }
    .btn-lock { 
        background: var(--chad-danger); 
        color: #fff; 
        box-shadow: 0 10px 20px rgba(239, 68, 68, 0.15);
    }
    .btn-lock:hover { background: #b91c1c; transform: translateY(-2px); }
    
    .btn-restore { 
        background: var(--chad-success); 
        color: #064e3b; 
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.15);
    }
    .btn-restore:hover { background: #059669; color: #fff; transform: translateY(-2px); }

    /* PLACEHOLDER MODULES & FORM STYLES */
    .coming-soon-box {
        border: 1px dashed rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 50px;
        text-align: center;
        color: #475569;
    }
    .coming-soon-box i { font-size: 2rem; margin-bottom: 15px; color: #334155; }

    .form-group { margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px; }
    .form-label { color: var(--chad-primary); font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
    .form-input, .form-select, .form-textarea {
        background: rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        padding: 12px;
        border-radius: 6px;
        font-family: inherit;
        font-size: 14px;
        width: 100%;
    }
    .form-textarea { min-height: 250px; resize: vertical; line-height: 1.6; }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--chad-primary); outline: none; }

    .btn-publish {
        background: var(--chad-primary);
        color: #000;
        font-weight: 900;
        padding: 15px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 2px;
        width: 100%;
        transition: 0.3s;
    }
    .btn-publish:hover { background: #fff; box-shadow: 0 0 20px rgba(212, 175, 55, 0.4); transform: translateY(-2px); }
</style>

<div class="chadoxx-wrapper">
    <!-- HEADER -->
    <div class="chadoxx-header">
        <div class="header-titles">
            <h1><i class="fas fa-satellite-dish" style="color: var(--chad-primary);"></i> Serveur Central</h1>
            <p>Accès ChadoxX — Interface Modulaire</p>
        </div>
    </div>

    <!-- ONGLETS DE NAVIGATION -->
    <div class="chadoxx-nav">
        <button class="nav-tab active" onclick="switchPane('pane-system', this)"><i class="fas fa-network-wired"></i> Système & Réseau</button>
        <button class="nav-tab" onclick="switchPane('pane-patchnotes', this)"><i class="fas fa-bullhorn"></i> Patchnotes</button>
        <button class="nav-tab" onclick="switchPane('pane-bdd', this)"><i class="fas fa-database"></i> Base de Données</button>
        <button class="nav-tab" onclick="switchPane('pane-api', this)"><i class="fas fa-cogs"></i> Configuration API</button>
    </div>

    <!-- MODULE 1 : SYSTÈME & RÉSEAU -->
    <div id="pane-system" class="chadoxx-pane active">
        <div class="panel-grid">
            
            <!-- CARTE MAINTENANCE -->
            <div class="admin-card card-system">
                <h2><i class="fas fa-shield-alt"></i> Protocole de Maintenance</h2>
                <p class="desc">
                    Ce module déclenche un "Kill Switch". Il coupe ou rétablit instantanément l'accès au portail pour tous les agents via un signal WebSocket prioritaire.
                </p>
                
                <% if (maintenanceActive) { %>
                    <div class="status-alert alert-danger">
                        <i class="fas fa-lock"></i> Réseau verrouillé — Accès public bloqué
                    </div>
                    <button onclick="toggleMaintenance()" class="btn-killswitch btn-restore">
                        <i class="fas fa-globe"></i> Rétablir le trafic
                    </button>
                <% } else { %>
                    <div class="status-alert alert-success">
                        <i class="fas fa-check-circle"></i> Réseau en ligne — Trafic fluide
                    </div>
                    <button onclick="toggleMaintenance()" class="btn-killswitch btn-lock">
                        <i class="fas fa-power-off"></i> Verrouiller le réseau
                    </button>
                <% } %>
            </div>

            <!-- CARTE ESPACE LIBRE -->
            <div class="admin-card">
                <h2><i class="fas fa-microchip"></i> Statut Serveur (En dev)</h2>
                <p class="desc">Emplacement prêt pour tes futurs widgets de monitoring (CPU, RAM, Uptime...).</p>
                <div class="coming-soon-box">
                    <i class="fas fa-tools"></i>
                    <p style="margin:0; font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">Module en construction</p>
                </div>
            </div>
            
        </div>
    </div>

    <!-- 🚀 MODULE 2 : PATCHNOTES (Nouveau) -->
    <div id="pane-patchnotes" class="chadoxx-pane">
        <div class="admin-card card-system" style="max-width: 800px;">
            <h2><i class="fas fa-edit"></i> Publier un nouveau Patchnote</h2>
            <p class="desc">Colle directement ton message Discord ici. Les titres, listes et emojis seront automatiquement mis en page pour le site public.</p>
            
            <form action="/patchnotes/ajouter" method="POST">
                <div class="form-group">
                    <label class="form-label">Contenu Brut (Copie-colle ton Markdown / Discord) :</label>
                    <textarea name="contenu" class="form-textarea" placeholder="# :arrows_counterclockwise: Mise à jour — Site BCSO&#10;&#10;:date: **22/07/2026**&#10;&#10;## :sparkles: Nouveautés&#10;> • Ajout d'une fonctionnalité de ouf&#10;&#10;## :wrench: Améliorations&#10;> • Refonte du design" required></textarea>
                </div>

                <button type="submit" class="btn-publish"><i class="fas fa-paper-plane" style="margin-right: 8px;"></i> PUBLIER DANS L'HISTORIQUE</button>
            </form>

            <div style="margin-top: 30px; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;">
                <a href="/patchnotes" style="color: var(--chad-primary); font-weight: 800; text-decoration: none; font-size: 13px;"><i class="fas fa-external-link-alt" style="margin-right: 5px;"></i> CONSULTER LA FRISES DES PATCHNOTES PUBLIÉS</a>
            </div>
        </div>
    </div>

    <!-- MODULE 3 : BDD -->
    <div id="pane-bdd" class="chadoxx-pane">
        <div class="coming-soon-box" style="margin-top: 20px;">
            <i class="fas fa-database"></i>
            <h3 style="color: #94a3b8; text-transform: uppercase; font-weight: 800;">Gestionnaire de Base de données</h3>
            <p style="font-size: 0.9rem;">Prépare tes futurs boutons ici (Reset des mots de passe, Purge des archives, etc.)</p>
        </div>
    </div>

    <!-- MODULE 4 : API -->
    <div id="pane-api" class="chadoxx-pane">
        <div class="coming-soon-box" style="margin-top: 20px;">
            <i class="fas fa-code-branch"></i>
            <h3 style="color: #94a3b8; text-transform: uppercase; font-weight: 800;">Endpoints & API</h3>
            <p style="font-size: 0.9rem;">Prépare tes futurs contrôles de webhooks Discord ici.</p>
        </div>
    </div>

</div>

<script>
    // Script des onglets
    function switchPane(paneId, btnElement) {
        document.querySelectorAll('.nav-tab').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.chadoxx-pane').forEach(el => el.classList.remove('active'));
        
        btnElement.classList.add('active');
        document.getElementById(paneId).classList.add('active');
    }

    // Requête d'actualisation invisible
    function toggleMaintenance() {
        fetch('/chadoxx/toggle-maintenance', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => response.json())
        .then(data => {
            if(data.success) {
                window.location.reload();
            }
        })
        .catch(error => console.error('Erreur:', error));
    }
</script>