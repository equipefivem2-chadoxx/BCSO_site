<style>
    .chadoxx-container {
        padding: 40px;
        color: white;
    }
    .chadoxx-header {
        border-bottom: 2px solid var(--primary);
        padding-bottom: 20px;
        margin-bottom: 30px;
    }
    .maintenance-card {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(189, 165, 129, 0.3);
        border-radius: 15px;
        padding: 30px;
        max-width: 500px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .status-badge {
        display: inline-block;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: bold;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .status-on { background: rgba(220, 38, 38, 0.2); color: #ef4444; border: 1px solid #ef4444; }
    .status-off { background: rgba(34, 197, 94, 0.2); color: #22c55e; border: 1px solid #22c55e; }
    
    .btn-toggle {
        padding: 15px 30px;
        font-size: 16px;
        font-weight: bold;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        width: 100%;
    }
    .btn-activate { background: #ef4444; color: white; }
    .btn-activate:hover { background: #dc2626; box-shadow: 0 0 20px rgba(239, 68, 68, 0.5); }
    .btn-deactivate { background: #22c55e; color: white; }
    .btn-deactivate:hover { background: #16a34a; box-shadow: 0 0 20px rgba(34, 197, 94, 0.5); }
</style>

<div class="chadoxx-container">
    <div class="chadoxx-header">
        <h1><i class="fas fa-crown" style="color: var(--primary);"></i> Pannel Super-Admin : ChadoxX</h1>
        <p>Interface exclusive. Ces actions affectent l'intégralité du site en temps réel.</p>
    </div>

    <div class="maintenance-card">
        <h2><i class="fas fa-tools"></i> Mode Maintenance</h2>
        <p style="color: #94a3b8; margin-bottom: 20px;">Permet de bloquer l'accès au site à tous les agents. Vous seul y aurez accès.</p>
        
        <% if (maintenanceActive) { %>
            <div class="status-badge status-on">Maintenance Activée (Site Fermé)</div>
            <form action="/chadoxx/toggle-maintenance" method="POST">
                <button type="submit" class="btn-toggle btn-deactivate"><i class="fas fa-play"></i> Réouvrir le site</button>
            </form>
        <% } else { %>
            <div class="status-badge status-off">Système En Ligne (Site Ouvert)</div>
            <form action="/chadoxx/toggle-maintenance" method="POST">
                <button type="submit" class="btn-toggle btn-activate"><i class="fas fa-power-off"></i> Fermer le site (Maintenance)</button>
            </form>
        <% } %>
    </div>
</div>