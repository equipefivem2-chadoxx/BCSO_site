<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --primary-glow-strong: rgba(189, 165, 129, 0.4);
        --bg-card: rgba(15, 23, 42, 0.4);
        --bg-dark: #07090e;
        --text-main: #e2e8f0;
        --text-muted: #94a3b8;
    }

    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
            radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
        font-family: 'Montserrat', sans-serif;
        color: var(--text-main);
        min-height: 100vh;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    #supervision-container {
        margin-left: 280px;
        padding: 50px 60px 80px 60px;
        min-height: 100vh;
        box-sizing: border-box;
        animation: fadeIn 0.4s ease-out forwards;
    }

    /* =========================================================
       🔴 STYLE DU PANNEAU DE REFUS (PARFAITEMENT CENTRÉ)
       ========================================================= */
    .refus-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 140px);
        width: 100%;
        padding-right: 40px; 
    }

    .access-denied-box {
        width: 100%;
        max-width: 580px;
        background: rgba(13, 17, 26, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(239, 68, 68, 0.35);
        border-top: 4px solid #ef4444;
        border-radius: 16px;
        padding: 45px 40px;
        text-align: center;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7), 0 0 40px rgba(239, 68, 68, 0.12);
    }

    .access-denied-icon {
        width: 76px;
        height: 76px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px auto;
        color: #ef4444;
        font-size: 34px;
        box-shadow: 0 0 25px rgba(239, 68, 68, 0.25);
    }

    .access-denied-box h2 {
        color: #fff;
        font-size: 24px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 0 0 8px 0;
    }

    .error-subtitle {
        color: #ef4444;
        font-weight: 700;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 24px;
    }

    .access-denied-box p {
        color: var(--text-muted);
        font-size: 14px;
        line-height: 1.6;
        margin: 0 0 30px 0;
    }

    .agent-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 12px 22px;
        border-radius: 8px;
        margin-bottom: 32px;
        color: #cbd5e1;
        font-family: monospace;
        font-size: 13px;
    }

    .btn-return {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(189, 165, 129, 0.1);
        color: var(--primary);
        border: 1px solid rgba(189, 165, 129, 0.3);
        padding: 12px 28px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 800;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

    .btn-return:hover {
        background: var(--primary);
        color: #05070b;
        box-shadow: 0 0 20px var(--primary-glow-strong);
        transform: translateY(-2px);
    }

    /* =========================================================
       🟡 STYLE DU PANEL SUPERVISION (CALQUÉ SUR ADMIN.EJS)
       ========================================================= */
    .page-header {
        border-bottom: 1px solid rgba(189, 165, 129, 0.2);
        padding-bottom: 20px;
        margin-bottom: 35px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-header h1 {
        color: var(--primary);
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 900;
        font-size: 28px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
        margin-bottom: 35px;
    }

    .stat-card {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.15);
        border-radius: 12px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .stat-card i {
        font-size: 2.5rem;
        color: var(--primary);
    }

    .stat-info div {
        font-size: 0.8rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
    }

    .stat-info span {
        font-size: 1.8rem;
        font-weight: 800;
        color: #f8fafc;
    }

    .panel-box {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.15);
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .table-responsive { overflow-x: auto; }
    .eval-table { width: 100%; border-collapse: collapse; text-align: left; }
    .eval-table th { background: rgba(0,0,0,0.25); padding: 16px; color: #94a3b8; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; border-bottom: 2px solid rgba(255,255,255,0.05); }
    .eval-table td { padding: 18px 16px; border-bottom: 1px solid rgba(255,255,255,0.02); font-size: 0.95rem; vertical-align: middle; }
    
    .badge { padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
    .badge-favorable { background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); }
    .badge-reserve { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
    .badge-defavorable { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

    .btn-action { background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #cbd5e1; padding: 8px 14px; border-radius: 6px; cursor: pointer; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: bold; }
    .btn-action.read:hover { border-color: var(--primary); color: var(--primary); background: rgba(189, 165, 129, 0.1); }
</style>

<div id="supervision-container">
    
    <!-- 🚀 SI ACCÈS REFUSÉ (PAS SLO OU SUPÉRIEUR) -->
    <% if (typeof accessDenied !== 'undefined' && accessDenied === true) { %>
        <div class="refus-wrapper">
            <div class="access-denied-box">
                <div class="access-denied-icon">
                    <i class="fas fa-user-shield"></i>
                </div>
                <h2>Accès Restreint</h2>
                <div class="error-subtitle">Réservé au Staff de Supervision (SLO & +)</div>
                
                <p>Ce terminal est consacré au suivi de carrière et à la validation des périodes probatoires. Votre grade actuel ne vous permet pas de consulter les archives des évaluations Junior.</p>

                <div class="agent-status-badge">
                    <i class="fas fa-lock" style="color: #ef4444;"></i>
                    <span>STATUT ACTUEL : <strong style="color: #fff;"><%= typeof currentGrade !== 'undefined' ? currentGrade : 'Non habilité' %></strong></span>
                </div>

                <div>
                    <a href="/dashboard" class="btn-return">
                        <i class="fas fa-arrow-left"></i> Retour au Dashboard
                    </a>
                </div>
            </div>
        </div>

    <!-- 🚀 SINON : AFFICHAGE DU PANEL SUPERVISION -->
    <% } else { %>

        <div class="page-header">
            <div>
                <h1>Supervision & Suivi Junior</h1>
                <p style="color: #94a3b8; font-size: 0.95rem; margin: 6px 0 0 0;">Consultation des rapports d'évaluation soumis par les évaluateurs de terrain</p>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <i class="fas fa-file-signature"></i>
                <div class="stat-info">
                    <div>Rapports Reçus</div>
                    <span><%= rapports ? rapports.length : 0 %></span>
                </div>
            </div>
            <div class="stat-card">
                <i class="fas fa-user-clock"></i>
                <div class="stat-info">
                    <div>En Attente Avis</div>
                    <span><%= rapports ? rapports.filter(r => r.statut === 'en_attente').length : 0 %></span>
                </div>
            </div>
            <div class="stat-card">
                <i class="fas fa-check-double"></i>
                <div class="stat-info">
                    <div>Validés SLO+</div>
                    <span><%= rapports ? rapports.filter(r => r.statut === 'valide').length : 0 %></span>
                </div>
            </div>
        </div>

        <div class="panel-box">
            <h2 style="font-size: 1.2rem; color: #fff; margin-bottom: 20px;"><i class="fas fa-inbox" style="color: var(--primary); margin-right: 10px;"></i> Archives des Évaluations</h2>
            <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">

            <div class="table-responsive">
                <table class="eval-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Deputy Junior Évalué</th>
                            <th>Évaluateur (Deputy I+)</th>
                            <th>Avis Global</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!rapports || rapports.length === 0) { %>
                            <tr>
                                <td colspan="6" style="text-align: center; color: #94a3b8; padding: 60px;">
                                    <i class="fas fa-folder-open" style="font-size: 36px; color: var(--primary); opacity: 0.3; display: block; margin: 0 auto 15px auto;"></i>
                                    Aucune évaluation de Junior n'a été soumise pour le moment.
                                </td>
                            </tr>
                        <% } else { %>
                            <% rapports.forEach(rapport => { %>
                                <tr>
                                    <td style="color: #cbd5e1; font-family: monospace;"><%= new Date(rapport.dateCreation).toLocaleDateString('fr-FR') %></td>
                                    <td style="font-weight: 800; color: #fff;">[<%= rapport.matriculeJunior %>] <%= rapport.nomJunior %></td>
                                    <td style="color: var(--primary); font-weight: 600;"><%= rapport.nomEvaluateur %></td>
                                    <td>
                                        <span class="badge <%= rapport.avis === 'Favorable' ? 'badge-favorable' : (rapport.avis === 'Défavorable' ? 'badge-defavorable' : 'badge-reserve') %>">
                                            <%= rapport.avis || 'À déterminer' %>
                                        </span>
                                    </td>
                                    <td style="color: #94a3b8; font-size: 0.85rem;"><%= rapport.statut === 'valide' ? '✅ Traité' : '⏳ En attente' %></td>
                                    <td>
                                        <a href="/superviseur/rapport/<%= rapport._id %>" class="btn-action read"><i class="fas fa-eye"></i> Consulter</a>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    <% } %>

</div>