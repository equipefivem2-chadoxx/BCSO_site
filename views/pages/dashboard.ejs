<style>
    /* Scoping strict pour éviter les conflits avec ton ancien style.css */
    #bcso-dashboard-container {
        padding-bottom: 70px; /* Laisse de la place pour la barre du bas */
        max-width: 1200px;
        margin: 0 auto;
    }
    .header-panel {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(90deg, rgba(17,24,39,1) 0%, rgba(11,15,25,0) 100%);
        padding: 20px 30px;
        border-radius: 8px;
        border-left: 4px solid #d4af37;
        margin-bottom: 40px;
    }
    .header-panel h2 { margin: 0; font-size: 24px; font-weight: 500; }
    .badge-admin {
        background-color: rgba(212, 175, 55, 0.1);
        color: #d4af37;
        padding: 8px 16px;
        border-radius: 4px;
        border: 1px solid rgba(212, 175, 55, 0.4);
        font-weight: bold;
        letter-spacing: 2px;
    }
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 25px;
        margin-bottom: 40px;
    }
    .kpi-card {
        background-color: #111827;
        border: 1px solid #1f2937;
        padding: 25px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }
    .kpi-icon {
        font-size: 30px;
        margin-right: 20px;
        padding: 15px;
        border-radius: 8px;
    }
    .kpi-data h3 { margin: 0; font-size: 13px; color: #9ca3af; text-transform: uppercase; letter-spacing: 1px; }
    .kpi-data p { margin: 5px 0 0 0; font-size: 28px; font-weight: bold; color: #fff; }
</style>

<div id="bcso-dashboard-container">
    <div class="header-panel">
        <h2>Bienvenue, <%= user ? user.username : 'Officier' %></h2>
        <span class="badge-admin"><i class="fas fa-star"></i> <%= user ? user.role.toUpperCase() : 'UTILISATEUR' %></span>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon" style="color: #60a5fa; background-color: rgba(96, 165, 250, 0.1);"><i class="fas fa-ticket-alt"></i></div>
            <div class="kpi-data"><h3>Tickets Traités</h3><p>0</p></div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon" style="color: #ef4444; background-color: rgba(239, 68, 68, 0.1);"><i class="fas fa-gavel"></i></div>
            <div class="kpi-data"><h3>Opérations</h3><p>0</p></div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon" style="color: #d4af37; background-color: rgba(212, 175, 55, 0.1);"><i class="fas fa-folder"></i></div>
            <div class="kpi-data"><h3>Rapports Validés</h3><p>0</p></div>
        </div>
    </div>
</div>