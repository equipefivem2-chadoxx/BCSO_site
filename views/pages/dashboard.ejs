<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --bg-card: rgba(15, 23, 42, 0.4);
        --bg-dark: #07090e; /* 🚀 Fond uniforme */
    }

    /* 🚀 NOUVEAU : Application du fond premium à la page entière */
    body {
        margin: 0;
        background-color: var(--bg-dark);
        background-image: 
            radial-gradient(circle at 15% 50%, rgba(189, 165, 129, 0.03), transparent 25%),
            radial-gradient(circle at 85% 30%, rgba(189, 165, 129, 0.04), transparent 25%);
        font-family: 'Montserrat', sans-serif;
        color: #e2e8f0;
        min-height: 100vh;
        overflow-x: hidden;
    }

    /* 🚀 ANIMATIONS FLUIDES EN CASCADE */
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @keyframes pulse-green {
        0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
        70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
        100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }

    @keyframes shine {
        0% { left: -100%; }
        20% { left: 100%; }
        100% { left: 100%; }
    }

    #bcso-dashboard-container {
        padding: 40px 0 70px 0;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* BANNIÈRE DE BIENVENUE 2.0 */
    .master-header {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.8) 0%, rgba(7, 9, 14, 0.95) 100%);
        backdrop-filter: blur(15px);
        padding: 40px 50px;
        border-radius: 20px;
        border: 1px solid rgba(189, 165, 129, 0.15);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.05);
        margin-bottom: 50px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        animation: fadeUp 0.6s ease-out forwards;
    }

    .master-header::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 5px; height: 100%;
        background: linear-gradient(to bottom, transparent, var(--primary), transparent);
        box-shadow: 0 0 20px var(--primary);
    }

    .welcome-text h2 {
        margin: 0;
        font-size: 32px;
        font-weight: 900;
        letter-spacing: 1px;
        color: #fff;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }
    .welcome-text p {
        margin: 8px 0 0 0;
        color: var(--primary);
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 3px;
        font-weight: 700;
    }

    .badge-premium {
        position: relative;
        background: rgba(189, 165, 129, 0.1);
        color: var(--primary);
        padding: 12px 25px;
        border-radius: 10px;
        border: 1px solid rgba(189, 165, 129, 0.3);
        font-weight: 800;
        letter-spacing: 2px;
        box-shadow: 0 0 20px rgba(189, 165, 129, 0.15);
        backdrop-filter: blur(5px);
        overflow: hidden;
    }

    .badge-premium::after {
        content: '';
        position: absolute;
        top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transform: skewX(-20deg);
        animation: shine 4s infinite;
    }

    /* GRILLE DES STATISTIQUES (KPIs) 2.0 */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-bottom: 50px;
    }

    .kpi-card {
        background: var(--bg-card);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.2);
        padding: 35px 30px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        opacity: 0;
        animation: fadeUp 0.6s ease-out forwards;
    }
    
    .kpi-card:nth-child(1) { animation-delay: 0.1s; }
    .kpi-card:nth-child(2) { animation-delay: 0.2s; }
    .kpi-card:nth-child(3) { animation-delay: 0.3s; }

    .kpi-card:hover {
        transform: translateY(-8px);
        border-color: rgba(189, 165, 129, 0.5);
        box-shadow: 0 20px 40px var(--primary-glow);
    }

    .kpi-card::before {
        content: '';
        position: absolute;
        bottom: 0; right: 0; width: 150px; height: 150px;
        background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
        opacity: 0;
        transition: 0.4s;
    }

    .kpi-card:hover::before { opacity: 1; }

    .kpi-icon {
        font-size: 38px;
        margin-right: 25px;
        padding: 18px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 50px; height: 50px;
        box-shadow: inset 0 2px 10px rgba(255,255,255,0.05);
    }

    .kpi-data h3 { margin: 0; font-size: 13px; color: #94a3b8; text-transform: uppercase; letter-spacing: 2px; font-weight: 800; }
    .kpi-data p { margin: 5px 0 0 0; font-size: 38px; font-weight: 900; color: #ffffff; letter-spacing: -1px; }

    /* SECTION ACTIVITÉ RÉCENTE 2.0 */
    .recent-section {
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.15);
        border-radius: 20px;
        padding: 35px;
        backdrop-filter: blur(15px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        opacity: 0;
        animation: fadeUp 0.6s ease-out forwards;
        animation-delay: 0.4s;
    }

    .recent-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 20px;
        margin-bottom: 30px;
    }

    .recent-header h3 {
        margin: 0;
        font-size: 20px;
        font-weight: 900;
        color: #fff;
        letter-spacing: 1px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sync-status {
        font-size: 12px; 
        color: #94a3b8; 
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
        background: rgba(16, 185, 129, 0.1);
        padding: 6px 12px;
        border-radius: 20px;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    
    .sync-dot {
        width: 8px; height: 8px;
        background: #10b981;
        border-radius: 50%;
        animation: pulse-green 2s infinite;
    }

    .empty-pulse { text-align: center; padding: 60px 0; color: #6b7280; }
    .empty-pulse i { font-size: 45px; margin-bottom: 20px; opacity: 0.5; animation: pulse 2s infinite; color: var(--primary); }
    @keyframes pulse { 0% { transform: scale(1); opacity: 0.3; } 50% { transform: scale(1.1); opacity: 0.8; } 100% { transform: scale(1); opacity: 0.3; } }

    /* LISTE DU FLUX EN DIRECT */
    .recent-list { display: flex; flex-direction: column; gap: 15px; }
    .recent-item { 
        background: rgba(0,0,0,0.25); 
        border: 1px solid rgba(255,255,255,0.02); 
        border-left: 4px solid transparent;
        border-radius: 10px; 
        padding: 20px 25px; 
        display: flex; justify-content: space-between; align-items: center; 
        transition: all 0.3s ease; 
    }
    
    .recent-item:hover { 
        border-color: rgba(189,165,129,0.3); 
        border-left-color: var(--primary);
        background: linear-gradient(90deg, rgba(189,165,129,0.05) 0%, transparent 100%);
        transform: translateX(8px); 
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }
    
    .recent-info { display: flex; flex-direction: column; gap: 10px; }
    .recent-title { color: #fff; font-weight: 800; font-size: 16px; text-transform: uppercase; letter-spacing: 1px; }
    .recent-title span { color: var(--primary); font-family: monospace; font-size: 18px; }
    .recent-meta { color: #94a3b8; font-size: 12px; display: flex; gap: 25px; font-weight: 600; }
    .recent-meta span { display: flex; align-items: center; gap: 6px; }
    .recent-meta i { color: var(--primary); font-size: 14px; }
    
    .btn-open { 
        background: rgba(189,165,129,0.1); 
        color: var(--primary); 
        padding: 12px 25px; 
        border-radius: 8px; 
        text-decoration: none; 
        font-weight: 800; 
        font-size: 13px; 
        border: 1px solid rgba(189,165,129,0.2); 
        transition: all 0.3s; 
        display: flex; align-items: center; gap: 10px; 
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .btn-open:hover { 
        background: var(--primary); 
        color: #07090e; 
        box-shadow: 0 0 20px var(--primary-glow); 
        transform: scale(1.05);
    }
</style>

<div id="bcso-dashboard-container">
    
    <div class="master-header">
        <div class="welcome-text">
            <h2>Bienvenue, <%= user ? user.username : 'Agent' %></h2>
            <p>Système Centralisé du Blaine County Sheriff Office</p>
        </div>
        <div class="badge-premium"><i class="fas fa-shield-alt" style="margin-right: 8px;"></i><%= user ? user.role.toUpperCase() : 'ACCÈS SÉCURISÉ' %></div>
    </div>

    <div class="kpi-grid">
        <!-- Tickers en cours -->
        <div class="kpi-card">
            <div class="kpi-icon" style="color: #60a5fa; background: rgba(96, 165, 250, 0.1); border: 1px solid rgba(96, 165, 250, 0.2);">
                <i class="fas fa-headset"></i>
            </div>
            <div class="kpi-data">
                <h3>Tickets en cours</h3>
                <p><%= locals.ticketsEnCoursCount || 0 %></p>
            </div>
        </div>

        <!-- Rapports Validés -->
        <div class="kpi-card">
            <div class="kpi-icon" style="color: var(--primary); background: rgba(189, 165, 129, 0.1); border: 1px solid rgba(189, 165, 129, 0.2);">
                <i class="fas fa-file-signature"></i>
            </div>
            <div class="kpi-data">
                <h3>Rapports Validés</h3>
                <p><%= locals.ticketsArchivesCount || 0 %></p>
            </div>
        </div>

        <!-- Effectifs Accrédités -->
        <div class="kpi-card">
            <div class="kpi-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2);">
                <i class="fas fa-id-card-clip"></i>
            </div>
            <div class="kpi-data">
                <h3>Agents Accrédités</h3>
                <p><%= locals.agentsCount || 0 %></p>
            </div>
        </div>
    </div>

    <div class="recent-section">
        <div class="recent-header">
            <h3><i class="fas fa-satellite-dish" style="color: var(--primary);"></i> Flux de données en direct</h3>
            <div class="sync-status">
                <div class="sync-dot"></div> Sync active
            </div>
        </div>
        
        <% if (typeof recentTickets !== 'undefined' && recentTickets.length > 0) { %>
            <div class="recent-list">
                <% recentTickets.forEach(ticket => { %>
                    <div class="recent-item">
                        <div class="recent-info">
                            <div class="recent-title">Dossier <span>#<%= ticket.channelName %></span></div>
                            <div class="recent-meta">
                                <span><i class="fas fa-user-shield"></i> Validé par : <%= ticket.closedBy %></span>
                                <span><i class="fas fa-folder-open"></i> Type : <%= ticket.motif.charAt(0).toUpperCase() + ticket.motif.slice(1) %></span>
                                <span><i class="fas fa-clock"></i> <%= new Date(ticket.dateCreation).toLocaleDateString('fr-FR') %></span>
                            </div>
                        </div>
                        <a href="/archives/<%= ticket._id %>" class="btn-open">Ouvrir <i class="fas fa-chevron-right"></i></a>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-pulse">
                <i class="fas fa-database"></i>
                <p style="font-weight: 600; letter-spacing: 1px;">EN ATTENTE DES TRANSMISSIONS DU BOT DISCORD...</p>
            </div>
        <% } %>
    </div>

</div>