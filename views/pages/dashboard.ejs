<style>
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

#bcso-dashboard-container {
    padding-bottom: 70px;
    max-width: 1400px;
    margin: 0 auto;
    animation: fadeInUp 0.6s ease-out;
}

.master-header {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #111827 0%, #05070b 100%);
    padding: 35px 40px;
    border-radius: 12px;
    border: 1px solid rgba(212, 175, 55, 0.15);
    margin-bottom: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.master-header::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 4px;
    height: 100%;
    background: #d4af37;
}

.welcome-text h2 {
    margin: 0;
    font-size: 28px;
    color: #fff;
}

.welcome-text p {
    margin: 5px 0 0;
    color: #9ca3af;
    font-size: 13px;
}

.badge-premium {
    color: #d4af37;
    border: 1px solid #d4af37;
    padding: 8px 15px;
    border-radius: 6px;
}

.kpi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    margin-bottom: 40px;
}

.kpi-card {
    background: rgba(17,24,39,0.7);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 25px;
    border-radius: 10px;
    display: flex;
    align-items: center;
}

.kpi-icon {
    margin-right: 15px;
    font-size: 26px;
}

.kpi-data h3 {
    margin: 0;
    font-size: 12px;
    color: #9ca3af;
}

.kpi-data p {
    margin: 5px 0 0;
    font-size: 26px;
    color: #fff;
}

.recent-section {
    background: rgba(17,24,39,0.6);
    padding: 25px;
    border-radius: 12px;
}

.recent-item {
    display: flex;
    justify-content: space-between;
    padding: 15px;
    background: rgba(0,0,0,0.3);
    border-radius: 8px;
    margin-bottom: 10px;
}

.btn-open {
    color: #d4af37;
    border: 1px solid #d4af37;
    padding: 8px 12px;
    border-radius: 6px;
    text-decoration: none;
}
</style>

<div id="bcso-dashboard-container">

    <!-- HEADER -->
    <div class="master-header">

        <div class="welcome-text">
            <h2>
                Bienvenue, 
                <%= user && user.username ? user.username : 'Agent inconnu' %>
            </h2>

            <p>Système Centralisé du Blaine County Sheriff Office</p>
        </div>

        <span class="badge-premium">
            <%= user && user.isAdmin ? 'ADMIN' : (user && user.role ? user.role.toUpperCase() : 'OFFICER') %>
        </span>

    </div>

    <!-- KPI -->
    <div class="kpi-grid">

        <div class="kpi-card">
            <div class="kpi-icon">📡</div>
            <div class="kpi-data">
                <h3>Tickets en cours</h3>
                <p><%= locals.ticketsEnCoursCount || 0 %></p>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">📁</div>
            <div class="kpi-data">
                <h3>Rapports validés</h3>
                <p><%= locals.ticketsArchivesCount || 0 %></p>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">👮</div>
            <div class="kpi-data">
                <h3>Agents</h3>
                <p><%= locals.agentsCount || 0 %></p>
            </div>
        </div>

    </div>

    <!-- RECENT -->
    <div class="recent-section">

        <h3 style="color:#fff;">Derniers dossiers</h3>

        <% if (recentTickets && recentTickets.length) { %>

            <% recentTickets.forEach(ticket => { %>
                <div class="recent-item">

                    <div>
                        <div style="color:#fff;font-weight:bold;">
                            Dossier #<%= ticket.channelName %>
                        </div>

                        <div style="font-size:12px;color:#9ca3af;">
                            <%= ticket.motif %> • <%= ticket.closedBy %> • 
                            <%= new Date(ticket.dateCreation).toLocaleDateString('fr-FR') %>
                        </div>
                    </div>

                    <a class="btn-open" href="/archives/<%= ticket._id %>">
                        Ouvrir
                    </a>

                </div>
            <% }) %>

        <% } else { %>

            <p style="color:#777;">Aucun dossier récent</p>

        <% } %>

    </div>

</div>