<style>
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

#bcso-dashboard-container {
    padding-bottom: 70px;
    max-width: 1400px;
    margin: 0 auto;
    animation: fadeInUp 0.6s ease-out;
}

/* HEADER */
.master-header {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #111827 0%, #05070b 100%);
    padding: 35px 40px;
    border-radius: 12px;
    border: 1px solid rgba(212, 175, 55, 0.15);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    margin-bottom: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.master-header::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 100%;
    background: linear-gradient(to bottom, #d4af37, #f3e5ab);
}

.welcome-text h2 {
    margin: 0;
    font-size: 28px;
    color: #f3f4f6;
}

.welcome-text p {
    margin: 5px 0 0;
    color: #9ca3af;
    font-size: 14px;
}

.badge-premium {
    background: rgba(212, 175, 55, 0.1);
    color: #d4af37;
    padding: 10px 20px;
    border-radius: 6px;
    border: 1px solid rgba(212, 175, 55, 0.3);
    font-weight: 700;
}

/* KPI */
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-bottom: 40px;
}

.kpi-card {
    background: rgba(17, 24, 39, 0.7);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 30px;
    border-radius: 12px;
    display: flex;
    align-items: center;
}

.kpi-data h3 {
    margin: 0;
    font-size: 12px;
    color: #9ca3af;
}

.kpi-data p {
    margin: 8px 0 0;
    font-size: 32px;
    font-weight: 700;
    color: #fff;
}

/* RECENT */
.recent-section {
    background: rgba(17, 24, 39, 0.6);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 30px;
}

.recent-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 25px;
}

.recent-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.recent-item {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 8px;
    padding: 18px 25px;
    display: flex;
    justify-content: space-between;
}

.recent-title {
    color: #fff;
    font-weight: 800;
}

.recent-title span {
    color: #d4af37;
}

.recent-meta {
    color: #9ca3af;
    font-size: 12px;
    display: flex;
    gap: 15px;
}

.btn-open {
    background: rgba(212,175,55,0.1);
    color: #d4af37;
    padding: 10px 15px;
    border-radius: 6px;
    text-decoration: none;
}
</style>

<div id="bcso-dashboard-container">

    <div class="master-header">
        <div class="welcome-text">

            <!-- 🔥 FIX IMPORTANT : fallback propre -->
            <h2>
                Bienvenue, 
                <%= user?.username || 'Agent' %>
                <% if (user?.grade) { %>
                    - <%= user.grade %>
                <% } %>
            </h2>

            <p>Système Centralisé du Blaine County Sheriff Office</p>
        </div>

        <span class="badge-premium">
            <%= user?.role ? user.role.toUpperCase() : 'ACCES LIMITE' %>
        </span>
    </div>

    <div class="kpi-grid">

        <div class="kpi-card">
            <div class="kpi-data">
                <h3>Tickets en cours</h3>
                <p><%= ticketsEnCoursCount || 0 %></p>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-data">
                <h3>Rapports validés</h3>
                <p><%= ticketsArchivesCount || 0 %></p>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-data">
                <h3>Agents accrédités</h3>
                <p><%= agentsCount || 0 %></p>
            </div>
        </div>

    </div>

    <div class="recent-section">

        <div class="recent-header">
            <h3>Flux en direct</h3>
        </div>

        <% if (recentTickets && recentTickets.length > 0) { %>
            <div class="recent-list">

                <% recentTickets.forEach(ticket => { %>
                    <div class="recent-item">

                        <div>
                            <div class="recent-title">
                                Dossier <span>#<%= ticket.channelName %></span>
                            </div>

                            <div class="recent-meta">
                                <span>Validé: <%= ticket.closedBy %></span>
                                <span>Type: <%= ticket.motif %></span>
                                <span><%= new Date(ticket.dateCreation).toLocaleDateString('fr-FR') %></span>
                            </div>
                        </div>

                        <a class="btn-open" href="/archives/<%= ticket._id %>">
                            Ouvrir
                        </a>

                    </div>
                <% }) %>

            </div>
        <% } else { %>

            <p style="color:#6b7280; text-align:center;">
                Aucun rapport pour le moment
            </p>

        <% } %>

    </div>

</div>