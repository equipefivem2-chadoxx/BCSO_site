<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --bg-card: rgba(15, 23, 42, 0.4);
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    #bcso-dashboard-container {
        padding-bottom: 70px;
        max-width: 1400px;
        margin: 0 auto;
        animation: fadeInUp 0.6s ease-out forwards;
    }

    /* BANNIÈRE DE BIENVENUE */
    .master-header {
        position: relative;
        overflow: hidden;
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        padding: 35px 40px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        margin-bottom: 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .master-header::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 4px; height: 100%;
        background: linear-gradient(to bottom, transparent, var(--primary), transparent);
        box-shadow: 0 0 15px rgba(189, 165, 129, 0.5);
    }

    .welcome-text h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 800;
        letter-spacing: 1px;
        color: #fff;
    }
    .welcome-text p {
        margin: 5px 0 0 0;
        color: #94a3b8;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .badge-premium {
        background: rgba(189, 165, 129, 0.1);
        color: var(--primary);
        padding: 10px 20px;
        border-radius: 8px;
        border: 1px solid rgba(189, 165, 129, 0.3);
        font-weight: 700;
        letter-spacing: 2px;
        box-shadow: 0 0 20px rgba(189, 165, 129, 0.1);
        backdrop-filter: blur(5px);
    }

    /* GRILLE DES STATISTIQUES (KPIs) */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-bottom: 40px;
    }

    .kpi-card {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.1);
        padding: 30px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .kpi-card:hover {
        transform: translateY(-5px);
        border-color: rgba(189, 165, 129, 0.3);
        box-shadow: 0 15px 30px var(--primary-glow);
    }

    .kpi-card::after {
        content: '';
        position: absolute;
        top: 0; right: 0; width: 100px; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.02));
        transform: skewX(-20deg) translateX(150px);
        transition: 0.5s;
    }

    .kpi-card:hover::after {
        transform: skewX(-20deg) translateX(-150px);
    }

    .kpi-icon {
        font-size: 35px;
        margin-right: 25px;
        padding: 15px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 45px; height: 45px;
    }

    .kpi-data h3 { margin: 0; font-size: 12px; color: #94a3b8; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700; }
    .kpi-data p { margin: 8px 0 0 0; font-size: 32px; font-weight: 800; color: #ffffff; }

    /* SECTION ACTIVITÉ RÉCENTE */
    .recent-section {
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(189, 165, 129, 0.1);
        border-radius: 16px;
        padding: 30px;
        backdrop-filter: blur(10px);
    }

    .recent-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 20px;
        margin-bottom: 25px;
    }

    .recent-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 800;
        color: #fff;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .empty-pulse { text-align: center; padding: 50px 0; color: #6b7280; }
    .empty-pulse i { font-size: 40px; margin-bottom: 15px; opacity: 0.5; animation: pulse 2s infinite; }
    @keyframes pulse { 0% { transform: scale(1); opacity: 0.3; } 50% { transform: scale(1.1); opacity: 0.6; } 100% { transform: scale(1); opacity: 0.3; } }

    /* LISTE DU FLUX EN DIRECT */
    .recent-list { display: flex; flex-direction: column; gap: 15px; }
    .recent-item { 
        background: rgba(0,0,0,0.2); 
        border: 1px solid rgba(255,255,255,0.03); 
        border-left: 3px solid var(--primary);
        border-radius: 8px; 
        padding: 18px 25px; 
        display: flex; justify-content: space-between; align-items: center; transition: 0.3s; 
    }
    .recent-item:hover { border-color: rgba(189,165,129,0.3); background: rgba(189,165,129,0.03); transform: translateX(5px); }
    .recent-info { display: flex; flex-direction: column; gap: 8px; }
    .recent-title { color: #fff; font-weight: 800; font-size: 15px; text-transform: uppercase; letter-spacing: 1px; }
    .recent-title span { color: var(--primary); }
    .recent-meta { color: #94a3b8; font-size: 12px; display: flex; gap: 20px; font-weight: 600; }
    .recent-meta i { color: var(--primary); margin-right: 5px; }
    
    .btn-open { background: rgba(189,165,129,0.1); color: var(--primary); padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 13px; border: 1px solid rgba(189,165,129,0.2); transition: 0.3s; display: flex; align-items: center; gap: 8px; text-transform: uppercase; }
    .btn-open:hover { background: var(--primary); color: #000; box-shadow: 0 0 15px var(--primary-glow); }
</style>

<div id="bcso-dashboard-container">
    
    <div class="master-header">
        <div class="welcome-text">
            <h2>Bienvenue, <%= user ? user.username : 'Agent' %></h2>
            <p>Système Centralisé du Blaine County Sheriff Office</p>
        </div>
        <span class="badge-premium"><i class="fas fa-shield-alt"></i> <%= user ? user.role.toUpperCase() : 'ACCÈS SÉCURISÉ' %></span>
    </div>

    <div class="kpi-grid">
        <!-- Tickers en cours -->
        <div class="kpi-card">
            <div class="kpi-icon" style="color: #60a5fa; background: rgba(96, 165, 250, 0.1); border: 1px solid rgba(96, 165, 250, 0.2);">
                <i class="fas fa-headset"></i>
            </div>
            <div class="kpi-data">
                <h3>Tickets en cours</h3>
                <p><%= locals.ticketsEnCoursCount || 0 %></p>
            </div>
        </div>

        <!-- Rapports Validés -->
        <div class="kpi-card">
            <div class="kpi-icon" style="color: var(--primary); background: rgba(189, 165, 129, 0.1); border: 1px solid rgba(189, 165, 129, 0.2);">
                <i class="fas fa-file-signature"></i>
            </div>
            <div class="kpi-data">
                <h3>Rapports Validés</h3>
                <p><%= locals.ticketsArchivesCount || 0 %></p>
            </div>
        </div>

        <!-- Effectifs Accrédités -->
        <div class="kpi-card">
            <div class="kpi-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2);">
                <i class="fas fa-id-card-clip"></i>
            </div>
            <div class="kpi-data">
                <h3>Agents Accrédités</h3>
                <p><%= locals.agentsCount || 0 %></p>
            </div>
        </div>
    </div>

    <div class="recent-section">
        <div class="recent-header">
            <h3><i class="fas fa-satellite-dish" style="color: var(--primary); margin-right: 10px;"></i> Flux de données en direct</h3>
            <span style="font-size: 12px; color: #94a3b8; font-weight: 600;"><i class="fas fa-circle" style="color: #10b981; font-size: 8px; margin-right: 5px;"></i> Sync active</span>
        </div>
        
        <% if (typeof recentTickets !== 'undefined' && recentTickets.length > 0) { %>
            <div class="recent-list">
                <% recentTickets.forEach(ticket => { %>
                    <div class="recent-item">
                        <div class="recent-info">
                            <div class="recent-title">Dossier <span>#<%= ticket.channelName %></span></div>
                            <div class="recent-meta">
                                <span><i class="fas fa-user-shield"></i> Validé par : <%= ticket.closedBy %></span>
                                <span><i class="fas fa-folder-open"></i> Type : <%= ticket.motif.charAt(0).toUpperCase() + ticket.motif.slice(1) %></span>
                                <span><i class="fas fa-clock"></i> <%= new Date(ticket.dateCreation).toLocaleDateString('fr-FR') %></span>
                            </div>
                        </div>
                        <a href="/archives/<%= ticket._id %>" class="btn-open">Ouvrir <i class="fas fa-chevron-right"></i></a>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-pulse">
                <i class="fas fa-database"></i>
                <p>En attente des transmissions du Bot Discord...</p>
            </div>
        <% } %>
    </div>

</div>