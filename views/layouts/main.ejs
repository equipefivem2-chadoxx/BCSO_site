<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="icon" type="image/png" href="/images/bcso.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- SCRIPTS SWUP -->
    <script src="https://unpkg.com/swup@4"></script>
    <script src="https://unpkg.com/@swup/preload-plugin@3"></script>
    <script src="https://unpkg.com/@swup/progress-plugin@3"></script>
    
    <!-- 🚀 LE NOUVEAU PLUGIN MAGIQUE (Relance les scripts) -->
    <script src="https://unpkg.com/@swup/scripts-plugin@3"></script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { background-color: #0a0e17; color: #f3f4f6; font-family: 'Montserrat', sans-serif; overflow-x: hidden; }

        .main-content-wrapper {
            margin-left: 280px; 
            padding-bottom: 70px; 
            min-height: 100vh;
            width: calc(100% - 280px); 
            padding-top: 40px; 
            padding-left: 40px; 
            padding-right: 40px; 
        }

        /* SÉCURITÉ ANTI-DUPLICATION */
        main .bcso-sidebar, 
        main #bcsoSidebar, 
        main .bcso-header,
        main .bcso-bottom-bar { 
            display: none !important; 
        }

        /* INSTANTANÉ : Pas de délai d'animation */
        #swup { opacity: 1; }

        /* Barre de progression dorée */
        .swup-progress-bar {
            height: 3px;
            background: #d4af37;
            z-index: 9999;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR FIXE -->
    <%- include('../partials/sidebar') %>
    
    <!-- CONTENU DYNAMIQUE -->
    <main class="main-content-wrapper">
        <div id="swup">
            <%- body %>
        </div>
    </main>

    <!-- BARRE DU BAS FIXE -->
    <%- include('../partials/header') %>

    <!-- SCRIPTS -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const swup = new Swup({
            containers: ['#swup'],
            plugins: [
                new SwupPreloadPlugin(),
                new SwupProgressPlugin({ 
                    color: '#d4af37', 
                    delay: 50, 
                    transition: 150
                }),
                // 🚀 Ce plugin force le JavaScript de tes pages à se recharger
                new SwupScriptsPlugin({
                    head: false,
                    body: true 
                })
            ]
        });

        const socket = io();
        socket.on('maintenance-toggled', (isMaintenance) => {
            if (window.location.pathname !== '/chadoxx') {
                window.location.reload(); 
            }
        });

        swup.hooks.on('page:view', () => {
            // 1. Nettoyage des doublons (Réparation du Patchnote)
            const sidebars = document.querySelectorAll('#swup #bcsoSidebar, #swup .bcso-sidebar, #swup .bcso-bottom-bar');
            sidebars.forEach(el => el.remove());

            // 2. 🚀 L'ASTUCE GLOBALE : On simule un rechargement pour réveiller tes boutons (Véhicules, Livret, etc.)
            setTimeout(() => {
                document.dispatchEvent(new Event('DOMContentLoaded', {
                    bubbles: true,
                    cancelable: true
                }));
            }, 50);
        });
    </script>
</body>
</html>