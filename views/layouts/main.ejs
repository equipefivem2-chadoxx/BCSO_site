<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* BASE RESET - Empêche les bugs d'espacement */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body, html {
            height: 100vh;
            background-color: #05070b;
            color: #f3f4f6;
            font-family: 'Segoe UI', system-ui, sans-serif;
            overflow: hidden; /* Désactive le scroll global de la page */
        }

        .app-layout {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        .main-content {
            flex: 1;
            background-color: #0b0f19;
            height: calc(100vh - 50px); /* Laisse la place pour ta barre du bas */
            overflow-y: auto; /* Active le scroll uniquement ici */
            position: relative;
        }

        .page-wrapper {
            padding: 40px;
            width: 100%;
        }
    </style>
</head>
<body>

    <div class="app-layout">
        
        <!-- SIDEBAR GAUCHE -->
        <%- include('../partials/sidebar') %>
        
        <!-- CONTENU CENTRAL -->
        <div class="main-content">
            <div class="page-wrapper">
                <%- body %>
            </div>
        </div>

    </div>

    <!-- BARRE DU BAS -->
    <%- include('../partials/header') %>

</body>
</html>