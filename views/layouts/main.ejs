<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="icon" type="image/png" href="/images/bcso.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- SCRIPTS SWUP -->
    <script src="https://unpkg.com/swup@4"></script>
    <script src="https://unpkg.com/@swup/preload-plugin@3"></script>
    <script src="https://unpkg.com/@swup/progress-plugin@3"></script>
    <script src="https://unpkg.com/@swup/scripts-plugin@3"></script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { background-color: #0a0e17; color: #f3f4f6; font-family: 'Montserrat', sans-serif; overflow-x: hidden; }

        .main-content-wrapper {
            margin-left: 280px; 
            padding-bottom: 70px; 
            min-height: 100vh;
            width: calc(100% - 280px); 
            padding-top: 40px; 
            padding-left: 40px; 
            padding-right: 40px; 
            /* On évite les débordements pendant l'animation */
            overflow-x: hidden; 
        }

        /* SÉCURITÉ ANTI-DUPLICATION */
        main .bcso-sidebar, 
        main #bcsoSidebar, 
        main .bcso-header,
        main .bcso-bottom-bar { 
            display: none !important; 
        }

        /* ========================================================
           ✨ ANIMATIONS SWUP "ULTRA PREMIUM" (Rapide & Fluide)
           ======================================================== */
        
        /* État 0 : La page est affichée normalement au centre */
        #swup {
            /* Utilisation d'une courbe "Expo" : Démarre très vite, freine à la fin. Donne un effet hyper réactif ! */
            transition: opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1), 
                        transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
                        filter 0.2s ease-out;
            opacity: 1;
            transform: translateY(0) scale(1);
            filter: blur(0px);
        }

        /* État 1 : Quand on clique, l'ancienne page part vers le haut, rétrécit et se floute légèrement */
        html.is-animating #swup {
            opacity: 0;
            transform: translateY(-15px) scale(0.98);
            filter: blur(2px);
        }

        /* État 2 : La nouvelle page se prépare à arriver par le bas */
        html.is-rendering #swup {
            opacity: 0;
            transform: translateY(15px) scale(0.98);
            filter: blur(2px);
        }

        /* Barre de progression dorée ultra fine en haut */
        .swup-progress-bar {
            height: 3px;
            background: linear-gradient(90deg, #bda581, #d4af37, #ffffff);
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
            z-index: 9999;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR FIXE -->
    <%- include('../partials/sidebar') %>
    
    <!-- CONTENU DYNAMIQUE -->
    <main class="main-content-wrapper">
        <div id="swup">
            <%- body %>
        </div>
    </main>

    <!-- BARRE DU BAS FIXE -->
    <%- include('../partials/header') %>

    <!-- SCRIPTS -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        // Configuration optimale pour une réactivité maximale
        const swup = new Swup({
            containers: ['#swup'],
            animationSelector: '[class*="transition-"]',
            plugins: [
                new SwupPreloadPlugin(),
                new SwupProgressPlugin({ 
                    color: '#d4af37', 
                    delay: 40, // S'affiche presque immédiatement si ça lag
                    transition: 150
                }),
                new SwupScriptsPlugin({
                    head: false,
                    body: true 
                })
            ]
        });

        const socket = io();
        socket.on('maintenance-toggled', (isMaintenance) => {
            if (window.location.pathname !== '/chadoxx') {
                window.location.reload(); 
            }
        });

        swup.hooks.on('page:view', () => {
            // Nettoyage visuel instantané
            const sidebars = document.querySelectorAll('#swup #bcsoSidebar, #swup .bcso-sidebar, #swup .bcso-bottom-bar');
            sidebars.forEach(el => el.remove());

            // Réveil des scripts interactifs (boutons, onglets, etc.)
            setTimeout(() => {
                document.dispatchEvent(new Event('DOMContentLoaded', {
                    bubbles: true,
                    cancelable: true
                }));
            }, 30); // Délai très court pour matcher la nouvelle animation
        });
    </script>
</body>
</html>