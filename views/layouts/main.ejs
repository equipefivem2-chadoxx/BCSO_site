<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="icon" type="image/png" href="/images/bcso.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- 🚀 SCRIPT SWUP POUR LA NAVIGATION 100% INSTANTANÉE -->
    <script src="https://unpkg.com/swup@4"></script>
    <script src="https://unpkg.com/@swup/preload-plugin@3"></script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { background-color: #0a0e17; color: #f3f4f6; font-family: 'Montserrat', sans-serif; overflow-x: hidden; }

        .main-content-wrapper {
            margin-left: 280px; 
            padding-bottom: 70px; 
            min-height: 100vh;
            width: calc(100% - 280px); 
            padding-top: 40px; 
            padding-left: 40px; 
            padding-right: 40px; 
        }

        /* SUPPRESSION DU DOUBLE AFFICHAGE */
        main .bcso-sidebar, main #bcsoSidebar, main .bcso-header { display: none !important; }

        /* ========================================================
           ✨ ANIMATIONS SWUP (Changements de page ultra fluides)
           ======================================================== */
        
        /* État normal de la page (centre de l'écran) */
        #swup {
            transition: opacity 0.25s ease-out, transform 0.25s ease-out;
            opacity: 1;
            transform: translateY(0);
        }

        /* État pendant que la page charge (disparaît légèrement vers le haut) */
        html.is-animating #swup {
            opacity: 0;
            transform: translateY(-10px);
        }

        /* État quand la nouvelle page arrive (apparaît par le bas) */
        html.is-leaving #swup {
            opacity: 0;
            transform: translateY(10px);
        }
    </style>
</head>
<body>

    <!-- SIDEBAR PRINCIPALE (Fixe, ne recharge jamais) -->
    <%- include('../partials/sidebar') %>
    
    <!-- CONTENU PRINCIPAL (Dynamique avec Swup) -->
    <main class="main-content-wrapper">
        <div id="swup" class="transition-fade">
            <%- body %>
        </div>
    </main>

    <!-- BARRE DU BAS (Fixe, ne recharge jamais) -->
    <%- include('../partials/header') %>

    <!-- SCRIPTS DU SYSTÈME GLOBAL -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        // 1. Initialisation de Swup (Navigation sans rechargement)
        const swup = new Swup({
            containers: ['#swup'], // On ne remplace QUE la div centrale, la sidebar reste intacte !
            plugins: [new SwupPreloadPlugin()] // Précharge la page dès que la souris survole un lien
        });

        // 2. WebSocket Maintenance (Géré hors de Swup pour toujours fonctionner)
        const socket = io();
        socket.on('maintenance-toggled', (isMaintenance) => {
            if (window.location.pathname !== '/chadoxx') {
                window.location.reload(); 
            }
        });

        // 3. Nettoyage de sécurité après chaque changement de page
        swup.hooks.on('page:view', () => {
            const sidebars = document.querySelectorAll('#swup #bcsoSidebar, #swup .bcso-sidebar');
            sidebars.forEach(sb => sb.remove());
        });
    </script>
</body>
</html>