<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="icon" type="image/png" href="/images/bcso.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- 🚀 SCRIPTS SWUP (Navigation + Préchargement + Barre de progression) -->
    <script src="https://unpkg.com/swup@4"></script>
    <script src="https://unpkg.com/@swup/preload-plugin@3"></script>
    <script src="https://unpkg.com/@swup/progress-plugin@3"></script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { background-color: #0a0e17; color: #f3f4f6; font-family: 'Montserrat', sans-serif; overflow-x: hidden; }

        .main-content-wrapper {
            margin-left: 280px; 
            padding-bottom: 70px; 
            min-height: 100vh;
            width: calc(100% - 280px); 
            padding-top: 40px; 
            padding-left: 40px; 
            padding-right: 40px; 
        }

        /* 🚀 SUPPRESSION DU DOUBLE AFFICHAGE (Répare la page Patchnote et les autres) */
        main .bcso-sidebar, 
        main #bcsoSidebar, 
        main .bcso-header,
        main .bcso-bottom-bar { 
            display: none !important; 
        }

        /* ========================================================
           ✨ ANIMATIONS SWUP (Changements de page ultra fluides)
           ======================================================== */
        
        /* État normal de la page (centre de l'écran) */
        #swup {
            transition: opacity 0.25s ease-out, transform 0.25s ease-out;
            opacity: 1;
            transform: translateY(0);
        }

        /* État pendant que la page charge (disparaît légèrement vers le haut) */
        html.is-animating #swup {
            opacity: 0;
            transform: translateY(-10px);
        }

        /* État quand la nouvelle page arrive (apparaît par le bas) */
        html.is-leaving #swup {
            opacity: 0;
            transform: translateY(10px);
        }

        /* 🔥 Design de la barre de chargement au clic rapide */
        .swup-progress-bar {
            height: 4px;
            background: linear-gradient(90deg, #bda581, #d4af37, #ffffff);
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
            z-index: 9999;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR PRINCIPALE (Fixe, ne recharge jamais) -->
    <%- include('../partials/sidebar') %>
    
    <!-- CONTENU PRINCIPAL (Dynamique avec Swup) -->
    <main class="main-content-wrapper">
        <div id="swup" class="transition-fade">
            <%- body %>
        </div>
    </main>

    <!-- BARRE DU BAS (Fixe, ne recharge jamais) -->
    <%- include('../partials/header') %>

    <!-- SCRIPTS DU SYSTÈME GLOBAL -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        // 1. Initialisation de Swup avec les plugins
        const swup = new Swup({
            containers: ['#swup'],
            plugins: [
                new SwupPreloadPlugin(), // Précharge au survol
                new SwupProgressPlugin({ // Barre dorée en haut
                    color: '#d4af37', 
                    delay: 80, // Ne s'affiche que si ça prend plus de 80ms
                    transition: 300
                })
            ]
        });

        // 2. WebSocket Maintenance
        const socket = io();
        socket.on('maintenance-toggled', (isMaintenance) => {
            if (window.location.pathname !== '/chadoxx') {
                window.location.reload(); 
            }
        });

        // 3. Nettoyage de sécurité JS après chaque changement de page
        swup.hooks.on('page:view', () => {
            const sidebars = document.querySelectorAll('#swup #bcsoSidebar, #swup .bcso-sidebar, #swup .bcso-bottom-bar');
            sidebars.forEach(el => el.remove());
        });
    </script>
</body>
</html>