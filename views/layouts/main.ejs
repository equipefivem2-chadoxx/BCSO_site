<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* BASE RESET */
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
        }
        
        body {
            background-color: #0a0e17; /* Fond raccord avec ta barre du bas */
            color: #f3f4f6;
            font-family: 'Segoe UI', system-ui, sans-serif;
            overflow-x: hidden; /* Empêche tout défilement horizontal */
        }

        /* LE CONTENEUR MAGIQUE QUI RÈGLE TON PROBLÈME DE DÉCALAGE */
        .main-content-wrapper {
            margin-left: 260px; /* Pousse tout à droite de la sidebar (260px) */
            padding-bottom: 50px; /* Laisse la place pour la barre du bas (50px) */
            min-height: 100vh;
            width: calc(100% - 260px); /* Prend exactement le reste de l'écran */
            padding-top: 40px; /* Espacement en haut */
            padding-left: 40px; /* Espacement à gauche */
            padding-right: 40px; /* Espacement à droite */
        }
    </style>
</head>
<body>

    <!-- 1. TA SIDEBAR GAUCHE -->
    <%- include('../partials/sidebar') %>
    
    <!-- 2. TON CONTENU CENTRAL (qui va charger dashboard, admin, etc.) -->
    <main class="main-content-wrapper">
        <%- body %>
    </main>

    <!-- 3. TA BARRE DU BAS -->
    <%- include('../partials/header') %>

</body>
</html>