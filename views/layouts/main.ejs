<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="icon" type="image/png" href="/images/bcso.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
        }
        
        body {
            background-color: #0a0e17;
            color: #f3f4f6;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        .main-content-wrapper {
            margin-left: 280px; 
            padding-bottom: 70px; 
            min-height: 100vh;
            width: calc(100% - 280px); 
            padding-top: 40px; 
            padding-left: 40px; 
            padding-right: 40px; 
            animation: initialFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes initialFadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* 🚀 SUPPRESSION DU DOUBLE AFFICHAGE (Bloque les sidebars et headers injectés dans le contenu) */
        main .bcso-sidebar,
        main #bcsoSidebar,
        main .bcso-header {
            display: none !important;
        }

        /* API VIEW TRANSITIONS (Animations fluides entre les pages) */
        @view-transition {
            navigation: auto;
        }

        ::view-transition-old(root) {
            animation: 0.22s cubic-bezier(0.4, 0, 1, 1) both fade-out, 0.22s cubic-bezier(0.4, 0, 0.2, 1) both slide-out;
        }

        ::view-transition-new(root) {
            animation: 0.32s cubic-bezier(0, 0, 0.2, 1) 0.05s both fade-in, 0.32s cubic-bezier(0, 0, 0.2, 1) both slide-in;
        }

        @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
        @keyframes fade-out { from { opacity: 1; } to { opacity: 0; } }
        @keyframes slide-in { from { transform: translateY(14px); } to { transform: translateY(0); } }
        @keyframes slide-out { from { transform: translateY(0); } to { transform: translateY(-14px); } }

        /* Barre de chargement fluide au clic */
        .page-loader {
            position: fixed;
            top: 0;
            left: 280px;
            width: calc(100% - 280px);
            height: 3px;
            background: linear-gradient(90deg, transparent, #bda581, #ffffff);
            z-index: 9999;
            opacity: 0;
            transition: opacity 0.2s ease;
            pointer-events: none;
        }

        .page-loader.active {
            opacity: 1;
            animation: loaderProgress 1s infinite linear;
        }

        @keyframes loaderProgress {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
    </style>
</head>
<body>

    <div class="page-loader" id="pageLoader"></div>

    <!-- SIDEBAR PRINCIPALE (Unique) -->
    <%- include('../partials/sidebar') %>
    
    <!-- CONTENU PRINCIPAL -->
    <main class="main-content-wrapper">
        <%- body %>
    </main>

    <!-- BARRE DU BAS -->
    <%- include('../partials/header') %>

    <!-- SCRIPTS DU SYSTÈMEs -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        // 1. WebSocket Maintenance
        const socket = io();
        socket.on('maintenance-toggled', (isMaintenance) => {
            if (window.location.pathname !== '/chadoxx') {
                window.location.reload(); 
            }
        });

        // 2. 🚀 NETTOYAGE DOM : Suppression physique des sidebars et headers en double
        document.addEventListener("DOMContentLoaded", () => {
            const sidebars = document.querySelectorAll('#bcsoSidebar, .bcso-sidebar');
            if (sidebars.length > 1) {
                for (let i = 1; i < sidebars.length; i++) {
                    sidebars[i].remove();
                }
            }
        });

        // 3. 🚀 PRÉCHARGEMENT INSTANTANÉ AU SURVOL (Instant Prefetching)
        let prefetchTimeout;
        const prefetchedUrls = new Set();

        document.addEventListener('mouseover', (e) => {
            const link = e.target.closest('a');
            if (!link || !link.href || link.href.startsWith('#') || link.origin !== window.location.origin) return;
            
            if (prefetchedUrls.has(link.href)) return;

            prefetchTimeout = setTimeout(() => {
                const prefetchLink = document.createElement('link');
                prefetchLink.rel = 'prefetch';
                prefetchLink.href = link.href;
                document.head.appendChild(prefetchLink);
                prefetchedUrls.add(link.href);
            }, 65);
        });

        document.addEventListener('mouseout', (e) => {
            if (e.target.closest('a')) {
                clearTimeout(prefetchTimeout);
            }
        });

        // 4. Activation de la barre de chargement lors d'un clic
        document.addEventListener('click', (e) => {
            const link = e.target.closest('a');
            if (link && link.href && !link.href.startsWith('#') && link.origin === window.location.origin && link.target !== '_blank') {
                document.getElementById('pageLoader').classList.add('active');
            }
        });
    </script>
    <script src="/js/smooth-router.js"></script>
</body>
</html>