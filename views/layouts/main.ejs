<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="icon" type="image/png" href="/images/bcso.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- SCRIPTS SWUP -->
    <script src="https://unpkg.com/swup@4"></script>
    <script src="https://unpkg.com/@swup/preload-plugin@3"></script>
    <script src="https://unpkg.com/@swup/progress-plugin@3"></script>
    <script src="https://unpkg.com/@swup/scripts-plugin@3"></script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { background-color: #0a0e17; color: #f3f4f6; font-family: 'Montserrat', sans-serif; overflow-x: hidden; }

        .main-content-wrapper {
            margin-left: 280px; 
            padding-bottom: 70px; 
            min-height: 100vh;
            width: calc(100% - 280px); 
            padding-top: 40px; 
            padding-left: 40px; 
            padding-right: 40px; 
            overflow-x: hidden; 
        }

        /* SÉCURITÉ ANTI-DUPLICATION */
        main .bcso-sidebar, 
        main #bcsoSidebar, 
        main .bcso-header,
        main .bcso-bottom-bar { 
            display: none !important; 
        }

        /* ========================================================
           ✨ ANIMATIONS SWUP "ULTRA PREMIUM"
           ======================================================== */
        
        /* 1. État normal (Page affichée au centre) */
        .transition-fade {
            transition: opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                        transform 0.4s cubic-bezier(0.25, 1, 0.5, 1),
                        filter 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            opacity: 1;
            transform: translateY(0) scale(1);
            filter: blur(0px);
        }

        /* 2. État quand on clique (L'ancienne page part vers le haut avec un flou profond) */
        html.is-animating .transition-fade {
            opacity: 0;
            transform: translateY(-25px) scale(0.96);
            filter: blur(4px);
        }

        /* 3. État d'arrivée (La nouvelle page arrive par le bas en s'éclaircissant) */
        html.is-rendering .transition-fade {
            transform: translateY(25px) scale(0.96);
        }

        /* 🔥 Barre de progression dorée premium */
        .swup-progress-bar {
            height: 4px;
            background: linear-gradient(90deg, transparent, #bda581, #d4af37, #ffffff);
            box-shadow: 0 0 12px rgba(212, 175, 55, 0.8);
            z-index: 9999;
            border-radius: 0 2px 2px 0;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR FIXE -->
    <%- include('../partials/sidebar') %>
    
    <!-- CONTENU DYNAMIQUE -->
    <main class="main-content-wrapper">
        <!-- 🚀 CORRECTION : Ajout de la classe "transition-fade" indispensable pour l'animation -->
        <div id="swup" class="transition-fade">
            <%- body %>
        </div>
    </main>

    <!-- BARRE DU BAS FIXE -->
    <%- include('../partials/header') %>

    <!-- SCRIPTS -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const swup = new Swup({
            containers: ['#swup'],
            animationSelector: '[class*="transition-"]',
            plugins: [
                new SwupPreloadPlugin(),
                new SwupProgressPlugin({ 
                    color: '#d4af37', 
                    delay: 0, // 🚀 CORRECTION : Forcé à 0 pour toujours afficher la barre au clic
                    transition: 200
                }),
                new SwupScriptsPlugin({
                    head: false,
                    body: true 
                })
            ]
        });

        const socket = io();
        socket.on('maintenance-toggled', (isMaintenance) => {
            if (window.location.pathname !== '/chadoxx') {
                window.location.reload(); 
            }
        });

        swup.hooks.on('page:view', () => {
            const sidebars = document.querySelectorAll('#swup #bcsoSidebar, #swup .bcso-sidebar, #swup .bcso-bottom-bar');
            sidebars.forEach(el => el.remove());

            setTimeout(() => {
                document.dispatchEvent(new Event('DOMContentLoaded', {
                    bubbles: true,
                    cancelable: true
                }));
            }, 50);
        });
    </script>
</body>
</html>