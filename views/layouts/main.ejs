<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="icon" type="image/png" href="/images/bcso.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- SCRIPTS SWUP OFFICIELS (Stables et légers) -->
    <script src="https://unpkg.com/swup@4"></script>
    <script src="https://unpkg.com/@swup/preload-plugin@3"></script>
    <script src="https://unpkg.com/@swup/progress-plugin@3"></script>
    <!-- Ajout du plugin pour gérer les scripts de tes pages sans doublons -->
    <script src="https://unpkg.com/@swup/scripts-plugin@3"></script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            background-color: #07090e; 
            color: #f3f4f6; 
            font-family: 'Montserrat', sans-serif; 
            overflow-x: hidden; 
        }

        .main-content-wrapper {
            margin-left: 280px;
            padding-bottom: 75px;
            min-height: 100vh;
            width: calc(100% - 280px);
            padding: 50px; 
            overflow-x: hidden;
        }

        /* ANTI-DOUBLONS EXTRÊME : Cache instantanément les menus inclus dans les pages EJS */
        #swup .bcso-sidebar, 
        #swup #bcsoSidebar, 
        #swup .bcso-bottom-bar,
        #swup aside { 
            display: none !important; 
        }

        /* ========================================================
           ⚡ ANIMATIONS SWUP (2D Ultra-Rapide & Lisse)
           ======================================================== */
        
        /* 1. État stable (Page visible) */
        .transition-fade {
            transition: opacity 0.25s ease-out, transform 0.25s ease-out;
            opacity: 1;
            transform: translateY(0);
        }

        /* 2. Au clic (La page disparaît rapidement vers le haut) */
        html.is-animating .transition-fade {
            opacity: 0;
            transform: translateY(-10px);
        }

        /* 3. Préparation nouvelle page (Apparaît du bas vers le haut) */
        html.is-rendering .transition-fade {
            opacity: 0;
            transform: translateY(10px);
        }

        /* Barre de chargement fine et élégante */
        .swup-progress-bar {
            height: 3px;
            background: linear-gradient(90deg, transparent, #bda581, #d4af37);
            z-index: 9999;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR FIXE -->
    <%- include('../partials/sidebar') %>
    
    <main class="main-content-wrapper">
        <div id="swup" class="transition-fade">
            <%- body %>
        </div>
    </main>

    <!-- BARRE DU BAS FIXE -->
    <%- include('../partials/header') %>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            
            /* ========================================================
               🛠️ NETTOYEUR GLOBAL : Intercepte et mémorise les boucles (ex: dashboard)
               ======================================================== */
            const originalSetInterval = window.setInterval;
            window.activePageIntervals = new Set();

            window.setInterval = function(callback, delay) {
                const intervalId = originalSetInterval(callback, delay);
                window.activePageIntervals.add(intervalId); 
                return intervalId;
            };

            /* ========================================================
               🚀 INITIALISATION SWUP
               ======================================================== */
            const swup = new Swup({
                containers: ['#swup'],
                animationSelector: '[class*="transition-"]',
                plugins: [
                    new SwupPreloadPlugin(),
                    new SwupProgressPlugin({ color: '#d4af37', delay: 0, transition: 200 }),
                    new SwupScriptsPlugin({ optin: false }) // Gère les scripts de tes pages proprement
                ]
            });

            /* ========================================================
               🧹 QUAND ON QUITTE LA PAGE (Nettoyage anti-spam)
               ======================================================== */
            swup.hooks.on('visit:start', () => {
                // Tue toutes les boucles de la page avant de charger la nouvelle
                window.activePageIntervals.forEach(clearInterval);
                window.activePageIntervals.clear();
            });

            /* ========================================================
               ✨ QUAND ON ARRIVE SUR LA NOUVELLE PAGE
               ======================================================== */
            swup.hooks.on('page:view', () => {
                
                // --- A. Mise à jour de la Sidebar ---
                const currentUrl = window.location.pathname;
                document.querySelectorAll('.nav-item-premium').forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('href') === currentUrl || (link.getAttribute('href') !== '/' && currentUrl.startsWith(link.getAttribute('href')))) {
                        link.classList.add('active');
                    }
                });

                // --- B. Suppression définitive des doublons HTML ---
                document.querySelectorAll('#swup aside, #swup .bcso-bottom-bar, #swup .bcso-sidebar').forEach(el => el.remove());

                // --- C. Relance l'event DOM pour réveiller les scripts internes des pages EJS ---
                window.document.dispatchEvent(new Event('DOMContentLoaded'));
            });

            /* ========================================================
               🔌 WEB-SOCKET MAINTENANCE
               ======================================================== */
            try {
                const socket = io();
                socket.on('maintenance-toggled', (isMaintenance) => {
                    if (window.location.pathname !== '/chadoxx') window.location.reload(); 
                });
            } catch (e) { console.warn("Socket.io non initialisé", e); }
        });
    </script>
</body>
</html>