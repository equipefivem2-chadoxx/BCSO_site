<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* BASE RESET */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body, html {
            height: 100vh;
            background-color: #05070b;
            color: #f3f4f6;
            font-family: 'Segoe UI', system-ui, sans-serif;
            overflow: hidden;
        }

        .app-layout {
            display: flex;
            height: calc(100vh - 50px); /* Laisse exactement 50px pour le header/barre du bas */
            width: 100vw;
        }

        .main-content {
            flex: 1;
            background-color: #0b0f19;
            overflow-y: auto;
            position: relative;
        }

        .page-wrapper {
            padding: 40px;
            max-width: 1600px; /* Centrage optimal pour éviter que les tableaux s'étirent trop */
            margin: 0 auto;
            width: 100%;
        }
    </style>
</head>
<body>

    <div class="app-layout">
        <%- include('../partials/sidebar') %>
        
        <div class="main-content">
            <div class="page-wrapper">
                <%- body %>
            </div>
        </div>
    </div>

    <%- include('../partials/header') %>

</body>
</html>