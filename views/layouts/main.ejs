<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <link rel="icon" type="image/png" href="/images/bcso.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- SCRIPTS SWUP OFFICIELS -->
    <script src="https://unpkg.com/swup@4"></script>
    <script src="https://unpkg.com/@swup/preload-plugin@3"></script>
    <script src="https://unpkg.com/@swup/progress-plugin@3"></script>
    <script src="https://unpkg.com/@swup/scripts-plugin@3"></script>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { background-color: #0a0e17; color: #f3f4f6; font-family: 'Montserrat', sans-serif; overflow-x: hidden; }

        .main-content-wrapper {
            margin-left: 280px; 
            padding-bottom: 70px; 
            min-height: 100vh;
            width: calc(100% - 280px); 
            padding-top: 40px; 
            padding-left: 40px; 
            padding-right: 40px; 
            overflow-x: hidden; 
        }

        /* SÉCURITÉ : Cache les éléments en double si le serveur les renvoie */
        main .bcso-sidebar, main #bcsoSidebar, main .bcso-header, main .bcso-bottom-bar { 
            display: none !important; 
        }

        /* ========================================================
           ✨ ANIMATIONS SWUP "APPLE-LIKE" (Profondeur & Fluidité)
           ======================================================== */
        
        /* 1. Page stable au centre */
        .transition-fade {
            transition: opacity 0.3s cubic-bezier(0.25, 1, 0.5, 1), 
                        transform 0.3s cubic-bezier(0.25, 1, 0.5, 1),
                        filter 0.3s cubic-bezier(0.25, 1, 0.5, 1);
            opacity: 1;
            transform: scale(1) translateY(0);
            filter: blur(0px);
        }

        /* 2. Au clic, la page recule et se floute légèrement */
        html.is-animating .transition-fade {
            opacity: 0;
            transform: scale(0.97) translateY(-15px);
            filter: blur(3px);
        }

        /* 3. La nouvelle page arrive par le bas */
        html.is-rendering .transition-fade {
            transform: scale(0.97) translateY(15px);
        }

        /* 🔥 Barre de chargement en haut */
        .swup-progress-bar {
            height: 4px;
            background: linear-gradient(90deg, transparent, #bda581, #d4af37, #ffffff);
            box-shadow: 0 0 12px rgba(212, 175, 55, 0.8);
            z-index: 9999;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR FIXE -->
    <%- include('../partials/sidebar') %>
    
    <main class="main-content-wrapper">
        <div id="swup" class="transition-fade">
            <%- body %>
        </div>
    </main>

    <!-- BARRE DU BAS FIXE -->
    <%- include('../partials/header') %>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        // On attend que la page soit prête pour lancer l'animation en toute sécurité
        document.addEventListener('DOMContentLoaded', () => {
            try {
                // Initialisation robuste de Swup
                const swup = new Swup({
                    containers: ['#swup'],
                    animationSelector: '[class*="transition-"]',
                    plugins: [
                        new SwupPreloadPlugin(),
                        new SwupProgressPlugin({ color: '#d4af37', delay: 0, transition: 300 }),
                        new SwupScriptsPlugin({ head: false, body: true })
                    ]
                });

                // Écoute des changements de page
                swup.hooks.on('page:view', () => {
                    
                    // 1. Mise à jour de la Sidebar (le script qu'on a retiré de sidebar.ejs est maintenant ici)
                    const currentUrl = window.location.pathname;
                    document.querySelectorAll('.nav-item-premium[href]').forEach(link => {
                        const href = link.getAttribute('href');
                        link.classList.remove('active');
                        if (href === currentUrl || (href !== '/' && href !== '/documents' && currentUrl.startsWith(href))) {
                            link.classList.add('active');
                        }
                    });

                    // 2. Nettoyage anti-doublon pour le Patchnote
                    document.querySelectorAll('#swup #bcsoSidebar, #swup .bcso-sidebar, #swup .bcso-bottom-bar').forEach(el => el.remove());

                    // 3. Réveil des boutons (véhicules, onglets, etc.)
                    setTimeout(() => { document.dispatchEvent(new Event('DOMContentLoaded')); }, 50);
                });

                // WebSocket (Sécurisé s'il y a un souci réseau)
                try {
                    const socket = io();
                    socket.on('maintenance-toggled', (isMaintenance) => {
                        if (window.location.pathname !== '/chadoxx') window.location.reload(); 
                    });
                } catch (e) { console.warn("Socket.io non initialisé", e); }

            } catch (error) {
                console.error("❌ ERREUR CRITIQUE SWUP : L'animation a planté.", error);
            }
        });
    </script>
</body>
</html>