<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'BCSO MDT System' %></title>
    
    <!-- 🚀 AJOUT : Importation globale de la police Montserrat pour tout le site -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* BASE RESET */
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
        }
        
        body {
            background-color: #0a0e17; /* Fond raccord avec ta barre du bas */
            color: #f3f4f6;
            /* 🚀 AJOUT : On force la police premium partout par défaut */
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden; /* Empêche tout défilement horizontal */
        }

        /* LE CONTENEUR MAGIQUE QUI RÈGLE TON PROBLÈME DE DÉCALAGE */
        .main-content-wrapper {
            margin-left: 280px; /* ⚠️ CORRECTION : J'ai mis 280px ici pour correspondre à ton --sidebar-width: 280px de ta sidebar */
            padding-bottom: 50px; 
            min-height: 100vh;
            width: calc(100% - 280px); /* ⚠️ CORRECTION : Idem, 280px au lieu de 260px */
            padding-top: 40px; 
            padding-left: 40px; 
            padding-right: 40px; 
        }
    </style>
</head>
<body>

    <!-- 1. TA SIDEBAR GAUCHE -->
    <%- include('../partials/sidebar') %>
    
    <!-- 2. TON CONTENU CENTRAL (qui va charger dashboard, admin, etc.) -->
    <main class="main-content-wrapper">
        <%- body %>
    </main>

    <!-- 3. TA BARRE DU BAS -->
    <%- include('../partials/header') %>

</body>
</html>