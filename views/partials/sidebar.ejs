<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --primary-glow-strong: rgba(189, 165, 129, 0.4);
        --bg-dark: #07090e;
        --sidebar-width: 280px;
    }

    .bcso-sidebar {
        width: var(--sidebar-width);
        background-color: var(--bg-dark);
        border-right: 1px solid rgba(189, 165, 129, 0.15);
        display: flex;
        flex-direction: column;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        z-index: 1000;
        box-shadow: 5px 0 25px rgba(0, 0, 0, 0.7);
        padding-top: 40px;
        font-family: 'Montserrat', sans-serif;
        transition: all 0.3s ease;
    }

    .sidebar-logo-container {
        text-align: center;
        margin-bottom: 30px;
        position: relative;
    }

    .sidebar-logo-container::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        background: var(--primary);
        filter: blur(50px);
        opacity: 0.06;
        z-index: -1;
    }

    .sidebar-logo {
        width: 120px;
        filter: drop-shadow(0px 6px 10px rgba(0,0,0,0.7));
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .sidebar-logo:hover {
        transform: scale(1.04) rotate(-1deg);
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 0 20px 30px 20px;
        flex-grow: 1;
        overflow-y: auto;
    }

    .sidebar-nav::-webkit-scrollbar { width: 0px; }

    .sidebar-category {
        color: #475569;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 18px 15px 6px 15px;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .sidebar-category::after {
        content: '';
        height: 1px;
        flex-grow: 1;
        background: rgba(189, 165, 129, 0.15);
    }

    .nav-item-premium {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 18px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 10px;
        border: 1px solid transparent;
        transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
    }

    .nav-item-content {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .nav-item-premium i {
        width: 20px;
        text-align: center;
        font-size: 14px;
        transition: transform 0.3s ease;
    }

    .nav-item-premium:hover {
        color: #ffffff;
        background: rgba(189, 165, 129, 0.04);
        border-color: rgba(189, 165, 129, 0.12);
        transform: translateX(5px);
    }

    .nav-item-premium:hover i {
        color: var(--primary);
        transform: scale(1.15);
    }

    /* 🚀 RETOUR TACTILE AU CLIC */
    .nav-item-premium:active {
        transform: scale(0.97) translateX(2px);
        background: rgba(189, 165, 129, 0.08);
    }

    .nav-item-premium.active {
        background: rgba(189, 165, 129, 0.08);
        color: #ffffff;
        border: 1px solid rgba(189, 165, 129, 0.25);
        border-left: 3px solid var(--primary);
        box-shadow: inset 0 0 15px rgba(189, 165, 129, 0.03);
    }

    .nav-item-premium.active i {
        color: var(--primary);
        text-shadow: 0 0 10px var(--primary-glow-strong);
    }

    .admin-link:hover {
        background: rgba(220, 38, 38, 0.04);
        border-color: rgba(220, 38, 38, 0.2);
        color: #fca5a5;
    }

    .admin-link:hover i {
        color: #ef4444 !important;
    }

    .sidebar-user-profile {
        margin-top: auto;
        padding: 20px;
        background: rgba(0, 0, 0, 0.25);
        border-top: 1px solid rgba(189, 165, 129, 0.1);
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .profile-icon {
        width: 40px;
        height: 40px;
        background: rgba(189, 165, 129, 0.15);
        border: 1px solid var(--primary);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 16px;
    }
    
    .profile-details {
        display: flex;
        flex-direction: column;
    }
    
    .profile-name {
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
    }
    
    .profile-grade {
        color: var(--primary);
        font-size: 11px;
        font-weight: 600;
    }
</style>

<aside class="bcso-sidebar" id="bcsoSidebar">
    <div class="sidebar-logo-container">
        <img src="/images/bcso.png" alt="BCSO Logo" class="sidebar-logo">
    </div>
    
    <div class="sidebar-nav">
        <a href="/dashboard" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-home"></i> Vue d'ensemble</div></a>
        <a href="/archives" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-folder-open"></i> Base de Données</div></a>
        <a href="/reglement" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-gavel"></i> Règlement</div></a>
        <a href="/lois" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-scale-balanced"></i> Livre des Lois</div></a>
        <a href="/effectifs" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-users"></i> Effectifs</div></a>
        <a href="/formations" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-graduation-cap"></i> Formations</div></a>
        <a href="/documents" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-file-signature"></i> Documents</div></a>
        
        <!-- 🚀 NOUVEAU LIEN PATCHNOTES -->
        <a href="/patchnotes" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-bullhorn"></i> Patchnotes</div></a>
        
        <a href="/documents/evaluer-junior" class="nav-item-premium">
            <div class="nav-item-content"><i class="fas fa-clipboard-check"></i> Évaluer Junior</div>
        </a>

        <% if (typeof user !== 'undefined' && user && user.grade !== 'Deputy Junior') { %>
            <a href="/fl/remplir" class="nav-item-premium">
                <div class="nav-item-content"><i class="fas fa-file-alt"></i> Remplir une FL</div>
            </a>
        <% } %>
        
        <% 
        const isSuperviseur = (typeof user !== 'undefined' && user && (
            user.isAdmin === true || 
            user.role === 'admin' || 
            user.id === '1247264549489610897' || 
            ['SLO', 'Sergeant I', 'Sergeant II', 'Sergeant Chef', 'Lieutenant', 'Sheriff'].includes(user.grade)
        ));
        %>
        <% if (isSuperviseur) { %>
            <div class="sidebar-category">Supervision</div>
            <a href="/superviseur" class="nav-item-premium">
                <div class="nav-item-content"><i class="fas fa-chart-line"></i> Dashboard Superviseur</div>
            </a>
        <% } %>

        <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.id === '1247264549489610897' || user.isAdmin === true)) { %>
            <div class="sidebar-category">Administration</div>
            <a href="/admin" class="nav-item-premium admin-link">
                <div class="nav-item-content"><i class="fas fa-cogs"></i> Haut Commandement</div>
            </a>
        <% } %>

        <% if (typeof user !== 'undefined' && user && user.id === '1247264549489610897') { %>
            <div class="sidebar-category" style="color: #bda581;">ChadoxX</div>
            <a href="/chadoxx" class="nav-item-premium" style="border-color: rgba(189, 165, 129, 0.3); background: rgba(189, 165, 129, 0.05);">
                <div class="nav-item-content">
                    <i class="fas fa-crown" style="color: #bda581; text-shadow: 0 0 10px rgba(189, 165, 129, 0.8);"></i> 
                    Dashboard ChadoxX
                </div>
            </a>
        <% } %>
    </div>

    <% if (typeof user !== 'undefined' && user) { %>
        <div class="sidebar-user-profile">
            <div class="profile-icon">
                <i class="fas fa-user-shield"></i>
            </div>
            <div class="profile-details">
                <span class="profile-name"><%= user.username || user.nom || 'Agent BCSO' %></span>
                <span class="profile-grade"><%= user.grade || 'Effectif' %></span>
            </div>
        </div>
    <% } %>
</aside>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const currentUrl = window.location.pathname;
        
        document.querySelectorAll('.nav-item-premium[href]').forEach(link => {
            const href = link.getAttribute('href');
            link.classList.remove('active');
            
            if (href === currentUrl || (href !== '/' && href !== '/documents' && currentUrl.startsWith(href))) {
                link.classList.add('active');
            }
        });
    });
</script>