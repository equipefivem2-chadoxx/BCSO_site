<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --primary-glow-strong: rgba(189, 165, 129, 0.4);
        --bg-dark: #07090e;
        --sidebar-width: 280px;
    }

    .bcso-sidebar {
        width: var(--sidebar-width);
        background-color: var(--bg-dark);
        border-right: 1px solid rgba(189, 165, 129, 0.15);
        display: flex;
        flex-direction: column;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        z-index: 1000;
        box-shadow: 5px 0 25px rgba(0, 0, 0, 0.7);
        padding-top: 40px;
        font-family: 'Montserrat', sans-serif;
        transition: all 0.3s ease;
    }

    .sidebar-logo-container {
        text-align: center;
        margin-bottom: 30px;
        position: relative;
    }

    .sidebar-logo-container::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        background: var(--primary);
        filter: blur(50px);
        opacity: 0.06;
        z-index: -1;
    }

    .sidebar-logo {
        width: 120px;
        filter: drop-shadow(0px 6px 10px rgba(0,0,0,0.7));
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .sidebar-logo:hover {
        transform: scale(1.03);
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 0 20px 30px 20px;
        flex-grow: 1;
        overflow-y: auto;
    }

    .sidebar-nav::-webkit-scrollbar { width: 0px; }

    .sidebar-category {
        color: #475569;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 18px 15px 6px 15px;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .sidebar-category::after {
        content: '';
        height: 1px;
        flex-grow: 1;
        background: rgba(189, 165, 129, 0.15);
    }

    .nav-item-premium {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 18px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 10px;
        border: 1px solid transparent;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        cursor: pointer;
        background: none;
        width: 100%;
        text-align: left;
        outline: none;
        font-family: inherit;
    }

    .nav-item-content {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-grow: 1;
    }

    .nav-item-premium i {
        width: 20px;
        text-align: center;
        font-size: 14px;
        transition: transform 0.3s ease;
    }

    .nav-item-premium:hover {
        color: #ffffff;
        background: rgba(189, 165, 129, 0.03);
        border-color: rgba(189, 165, 129, 0.08);
        transform: translateX(4px);
    }

    .nav-item-premium:hover i {
        color: var(--primary);
        transform: scale(1.1);
    }

    .nav-item-premium.active {
        background: rgba(189, 165, 129, 0.08);
        color: #ffffff;
        border: 1px solid rgba(189, 165, 129, 0.25);
        border-left: 3px solid var(--primary);
        box-shadow: inset 0 0 15px rgba(189, 165, 129, 0.03);
    }

    .nav-item-premium.active i {
        color: var(--primary);
        text-shadow: 0 0 10px var(--primary-glow-strong);
    }

    /* === NOUVEAU CSS POUR LE MENU DÉROULANT === */
    .nav-dropdown {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .dropdown-icon {
        font-size: 10px !important;
        transition: transform 0.3s ease !important;
        color: #64748b;
    }

    .nav-dropdown.open .dropdown-icon {
        transform: rotate(180deg) !important;
        color: var(--primary);
    }

    /* Style du parent quand le menu est ouvert */
    .nav-dropdown.open .nav-item-premium {
        background: rgba(189, 165, 129, 0.05);
        color: #ffffff;
        border-color: rgba(189, 165, 129, 0.1);
    }

    .nav-dropdown.open .nav-item-premium i:not(.dropdown-icon) {
        color: var(--primary);
    }

    .dropdown-menu {
        display: none; /* Caché par défaut */
        flex-direction: column;
        gap: 4px;
        padding-left: 45px; /* Indentation sous l'icône parente */
        margin-top: 2px;
        margin-bottom: 6px;
    }

    .nav-dropdown.open .dropdown-menu {
        display: flex; /* Affiché si parent a la classe .open */
    }

    .dropdown-item {
        color: #64748b;
        text-decoration: none;
        font-size: 12px;
        font-weight: 500;
        padding: 8px 12px;
        border-radius: 6px;
        transition: all 0.2s ease;
        display: block;
        position: relative;
    }

    .dropdown-item::before {
        content: '';
        position: absolute;
        left: -12px;
        top: 50%;
        transform: translateY(-50%);
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #475569;
        transition: all 0.2s ease;
    }

    .dropdown-item:hover {
        color: #cbd5e1;
        background: rgba(255, 255, 255, 0.03);
    }

    .dropdown-item:hover::before {
        background: var(--primary);
    }

    .dropdown-item.active {
        color: var(--primary);
        background: rgba(189, 165, 129, 0.08);
        font-weight: 600;
    }

    .dropdown-item.active::before {
        background: var(--primary);
        box-shadow: 0 0 8px var(--primary-glow-strong);
    }
    /* ======================================= */

    .admin-link:hover {
        background: rgba(220, 38, 38, 0.03);
        border-color: rgba(220, 38, 38, 0.15);
        color: #fca5a5;
    }

    .admin-link:hover i {
        color: #ef4444 !important;
    }

    .sidebar-user-profile {
        margin-top: auto;
        padding: 20px;
        background: rgba(0, 0, 0, 0.25);
        border-top: 1px solid rgba(189, 165, 129, 0.1);
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .profile-icon {
        width: 40px;
        height: 40px;
        background: rgba(189, 165, 129, 0.15);
        border: 1px solid var(--primary);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 16px;
    }
    
    .profile-details {
        display: flex;
        flex-direction: column;
    }
    
    .profile-name {
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
    }
    
    .profile-grade {
        color: var(--primary);
        font-size: 11px;
        font-weight: 600;
    }
</style>

<aside class="bcso-sidebar" id="bcsoSidebar">
    <div class="sidebar-logo-container">
        <img src="/images/bcso.png" alt="BCSO Logo" class="sidebar-logo">
    </div>
    
    <div class="sidebar-nav">
        <a href="/dashboard" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-home"></i> Vue d'ensemble</div></a>
        <a href="/archives" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-folder-open"></i> Base de Données</div></a>
        <a href="/reglement" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-gavel"></i> Règlement</div></a>
        <a href="/lois" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-scale-balanced"></i> Livre des Lois</div></a>
        <a href="/effectifs" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-users"></i> Effectifs</div></a>
        
        <!-- === MENU DÉROULANT : FORMATIONS === -->
        <div class="nav-dropdown">
            <button class="nav-item-premium dropdown-toggle">
                <div class="nav-item-content"><i class="fas fa-graduation-cap"></i> Formations</div>
                <i class="fas fa-chevron-down dropdown-icon"></i>
            </button>
            <div class="dropdown-menu">
                <a href="/formations" class="dropdown-item">Toutes les formations</a>
                <a href="/formation-convoi" class="dropdown-item">Convoi</a>
                <a href="/formation-negociation" class="dropdown-item">Négociation</a>
                <a href="/formation-police-scientifique" class="dropdown-item">Police Scientifique</a>
                <a href="/formation-premier-secours" class="dropdown-item">Premiers Secours</a>
            </div>
        </div>

        <!-- === MENU DÉROULANT : DOCUMENTS === -->
        <div class="nav-dropdown">
            <button class="nav-item-premium dropdown-toggle">
                <div class="nav-item-content"><i class="fas fa-file-signature"></i> Documents</div>
                <i class="fas fa-chevron-down dropdown-icon"></i>
            </button>
            <div class="dropdown-menu">
                <a href="/documents" class="dropdown-item">Tous les documents</a>
                <a href="/doc-armes" class="dropdown-item">Permis de Port d'Arme</a>
                <a href="/doc-arrestations" class="dropdown-item">Rapports d'Arrestation</a>
            </div>
        </div>
        
        <a href="/documents/evaluer-junior" class="nav-item-premium">
            <div class="nav-item-content"><i class="fas fa-clipboard-check"></i> Évaluer Junior</div>
        </a>
        
        <% 
        const isSuperviseur = (typeof user !== 'undefined' && user && (
            user.isAdmin === true || 
            user.role === 'admin' || 
            user.id === '1247264549489610897' || 
            ['SLO', 'Sergeant I', 'Sergeant II', 'Sergeant Chef', 'Lieutenant', 'Sheriff'].includes(user.grade)
        ));
        %>
        <% if (isSuperviseur) { %>
            <div class="sidebar-category">Supervision</div>
            <a href="/superviseur" class="nav-item-premium">
                <div class="nav-item-content"><i class="fas fa-chart-line"></i> Dashboard Superviseur</div>
            </a>
        <% } %>

        <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.id === '1247264549489610897' || user.isAdmin === true)) { %>
            <div class="sidebar-category">Administration</div>
            <a href="/admin" class="nav-item-premium admin-link">
                <div class="nav-item-content"><i class="fas fa-cogs"></i> Haut Commandement</div>
            </a>
        <% } %>

        <% if (typeof user !== 'undefined' && user && user.id === '1247264549489610897') { %>
            <div class="sidebar-category" style="color: #bda581;">ChadoxX</div>
            <a href="/chadoxx" class="nav-item-premium" style="border-color: rgba(189, 165, 129, 0.3); background: rgba(189, 165, 129, 0.05);">
                <div class="nav-item-content">
                    <i class="fas fa-crown" style="color: #bda581; text-shadow: 0 0 10px rgba(189, 165, 129, 0.8);"></i> 
                    Dashboard ChadoxX
                </div>
            </a>
        <% } %>
    </div>

    <% if (typeof user !== 'undefined' && user) { %>
        <div class="sidebar-user-profile">
            <div class="profile-icon">
                <i class="fas fa-user-shield"></i>
            </div>
            <div class="profile-details">
                <span class="profile-name"><%= user.username || user.nom || 'Agent BCSO' %></span>
                <span class="profile-grade"><%= user.grade || 'Effectif' %></span>
            </div>
        </div>
    <% } %>
</aside>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const currentUrl = window.location.pathname;
        
        // 1. Gérer les menus déroulants (ouverture/fermeture au clic)
        document.querySelectorAll('.dropdown-toggle').forEach(toggle => {
            toggle.addEventListener('click', (e) => {
                e.preventDefault();
                const parent = toggle.closest('.nav-dropdown');
                
                // Optionnel : Fermer les autres menus quand on en ouvre un nouveau
                document.querySelectorAll('.nav-dropdown').forEach(dropdown => {
                    if (dropdown !== parent) {
                        dropdown.classList.remove('open');
                    }
                });

                parent.classList.toggle('open');
            });
        });

        // 2. Gérer l'état actif en fonction de l'URL
        document.querySelectorAll('.nav-item-premium[href], .dropdown-item').forEach(link => {
            const href = link.getAttribute('href');
            
            // Si l'URL actuelle correspond au lien
            if (currentUrl === href) {
                link.classList.add('active');
                
                // Si ce lien se trouve dans un menu déroulant, on force l'ouverture du parent
                const parentDropdown = link.closest('.nav-dropdown');
                if (parentDropdown) {
                    parentDropdown.classList.add('open');
                }
            }
        });
    });
</script>