<style>
    :root {
        --primary: #bda581;
        --primary-glow: rgba(189, 165, 129, 0.15);
        --primary-glow-strong: rgba(189, 165, 129, 0.4);
        --bg-dark: #07090e;
        --sidebar-width: 280px;
    }

    .bcso-sidebar {
        width: var(--sidebar-width);
        background-color: var(--bg-dark);
        /* Subtile ligne de séparation reprenant le code couleur du thème */
        border-right: 1px solid rgba(189, 165, 129, 0.15);
        display: flex;
        flex-direction: column;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        z-index: 1000;
        box-shadow: 5px 0 25px rgba(0, 0, 0, 0.7);
        padding-top: 40px;
        font-family: 'Montserrat', sans-serif;
        transition: all 0.3s ease;
    }

    /* Halo lumineux derrière le logo calqué sur tes radial-gradients */
    .sidebar-logo-container {
        text-align: center;
        margin-bottom: 40px;
        position: relative;
    }

    .sidebar-logo-container::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        background: var(--primary);
        filter: blur(50px);
        opacity: 0.06;
        z-index: -1;
    }

    .sidebar-logo {
        width: 120px;
        filter: drop-shadow(0px 6px 10px rgba(0,0,0,0.7));
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .sidebar-logo:hover {
        transform: scale(1.03);
    }

    /* Menu de Navigation */
    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 0 20px;
        flex-grow: 1;
        overflow-y: auto;
    }

    .sidebar-nav::-webkit-scrollbar { 
        width: 0px; 
    }

    /* Liens - Typographie calquée sur les titres du roster (clairs, espacés, pro) */
    .nav-item-premium {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 13px 20px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 10px;
        border: 1px solid transparent;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    /* Force l'alignement strict des icônes */
    .nav-item-premium i {
        width: 20px;
        text-align: center;
        font-size: 14px;
        transition: transform 0.3s ease;
    }

    /* Effet Hover (Survol) - Glissement sobre + coloration de l'icône */
    .nav-item-premium:hover {
        color: #ffffff;
        background: rgba(189, 165, 129, 0.03);
        border-color: rgba(189, 165, 129, 0.08);
        transform: translateX(4px);
    }

    .nav-item-premium:hover i {
        color: var(--primary);
        transform: scale(1.1);
    }

    /* Effet Active (Page en cours) - Reprend le style de la "total-badge" et des "agent-card" */
    .nav-item-premium.active {
        background: rgba(189, 165, 129, 0.08);
        color: #ffffff;
        border: 1px solid rgba(189, 165, 129, 0.25);
        border-left: 3px solid var(--primary);
        box-shadow: inset 0 0 15px rgba(189, 165, 129, 0.03);
    }

    .nav-item-premium.active i {
        color: var(--primary);
        text-shadow: 0 0 10px var(--primary-glow-strong);
    }

    /* Séparateur Administration style "grade-title::after" */
    .admin-divider {
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(189, 165, 129, 0.3), transparent);
        margin: 20px 10px;
        opacity: 0.5;
    }

    /* Style Premium Spécifique Admin */
    .admin-link {
        border-bottom: 1px solid rgba(220, 38, 38, 0.05);
    }
    
    .admin-link:hover {
        background: rgba(220, 38, 38, 0.03);
        border-color: rgba(220, 38, 38, 0.15);
        color: #fca5a5;
    }

    .admin-link:hover i {
        color: #ef4444 !important;
    }
</style>

<aside class="bcso-sidebar">
    <div class="sidebar-logo-container">
        <img src="/images/bcso.png" alt="BCSO Logo" class="sidebar-logo">
    </div>
    
    <div class="sidebar-nav">
        <a href="/dashboard" class="nav-item-premium"><i class="fas fa-home"></i> Vue d'ensemble</a>
        <a href="/archives" class="nav-item-premium"><i class="fas fa-folder-open"></i> Base de Données</a>
        <a href="/reglement" class="nav-item-premium"><i class="fas fa-gavel"></i> Règlement</a>
        <a href="/lois" class="nav-item-premium"><i class="fas fa-scale-balanced"></i> Livre des Lois</a>
        <a href="/effectifs" class="nav-item-premium"><i class="fas fa-users"></i> Effectifs</a>
        <a href="/formations" class="nav-item-premium"><i class="fas fa-graduation-cap"></i> Formations</a>
        <a href="/documents" class="nav-item-premium"><i class="fas fa-file-signature"></i> Documents</a>
        
        <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.id === '1247264549489610897' || user.isAdmin === true)) { %>
            <div class="admin-divider"></div>
            <a href="/admin" class="nav-item-premium admin-link">
                <i class="fas fa-cogs"></i> Administration
            </a>
        <% } %>
    </div>
</aside>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const currentUrl = window.location.pathname;
        const navLinks = document.querySelectorAll('.nav-item-premium');
        
        navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === currentUrl) {
                link.classList.add('active');
            }
        });
    });
</script>