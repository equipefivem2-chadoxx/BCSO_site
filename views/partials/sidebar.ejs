<style>
    :root {
        --bcso-gold: #eab308;
        --bcso-gold-glow: rgba(234, 179, 8, 0.4);
        --sidebar-width: 280px; /* Légèrement plus large pour respirer */
    }

    .bcso-sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.95) 0%, rgba(5, 7, 11, 1) 100%);
        backdrop-filter: blur(15px);
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        flex-direction: column;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        z-index: 1000;
        box-shadow: 10px 0 30px rgba(0, 0, 0, 0.6);
        padding-top: 30px;
        transition: all 0.3s ease;
    }

    /* Conteneur du logo avec effet de lumière */
    .sidebar-logo-container {
        text-align: center;
        margin-bottom: 30px;
        position: relative;
    }

    .sidebar-logo-container::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100px;
        height: 100px;
        background: var(--bcso-gold);
        filter: blur(60px);
        opacity: 0.15;
        z-index: -1;
    }

    .sidebar-logo {
        width: 130px;
        filter: drop-shadow(0px 8px 12px rgba(0,0,0,0.8));
        transition: transform 0.4s ease;
    }

    .sidebar-logo:hover {
        transform: scale(1.05);
    }

    /* Navigation */
    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 0 15px;
        flex-grow: 1;
        overflow-y: auto; /* Permet de scroller si trop de liens sur petit écran */
    }

    /* Scrollbar invisible pour la nav */
    .sidebar-nav::-webkit-scrollbar { width: 0px; }

    /* Liens normaux */
    .nav-item-premium {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 14px 20px;
        color: #94a3b8; /* Gris bleuté doux */
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        border-radius: 12px;
        border: 1px solid transparent;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    /* Icônes centrées */
    .nav-item-premium i {
        width: 24px;
        text-align: center;
        font-size: 1.1rem;
        transition: all 0.3s ease;
    }

    /* Effet au survol */
    .nav-item-premium:hover {
        color: #f8fafc;
        background: rgba(255, 255, 255, 0.03);
        transform: translateX(6px);
    }

    .nav-item-premium:hover i {
        color: var(--bcso-gold);
        transform: scale(1.15);
    }

    /* Effet page active */
    .nav-item-premium.active {
        background: linear-gradient(90deg, rgba(234, 179, 8, 0.12) 0%, rgba(234, 179, 8, 0.02) 100%);
        color: #ffffff;
        border: 1px solid rgba(234, 179, 8, 0.15);
        border-left: 4px solid var(--bcso-gold);
        box-shadow: inset 0 0 20px rgba(234, 179, 8, 0.05);
        font-weight: 600;
    }

    .nav-item-premium.active i {
        color: var(--bcso-gold);
        text-shadow: 0 0 12px var(--bcso-gold-glow);
    }

    /* Séparateur pour l'administration */
    .admin-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        margin: 15px 0;
    }

    /* Style spécifique Admin */
    .admin-link {
        color: #fbbf24;
    }
    
    .admin-link:hover i {
        color: #f87171 !important; /* L'icône admin devient rouge au survol */
    }
</style>

<aside class="bcso-sidebar">
    <div class="sidebar-logo-container">
        <img src="/images/bcso.png" alt="BCSO Logo" class="sidebar-logo">
    </div>
    
    <div class="sidebar-nav">
        <a href="/dashboard" class="nav-item-premium"><i class="fas fa-home"></i> Vue d'ensemble</a>
        <a href="/archives" class="nav-item-premium"><i class="fas fa-folder-open"></i> Base de Données</a>
        <a href="/reglement" class="nav-item-premium"><i class="fas fa-gavel"></i> Règlement</a>
        <a href="/lois" class="nav-item-premium"><i class="fas fa-scale-balanced"></i> Livre des Lois</a>
        <a href="/effectifs" class="nav-item-premium"><i class="fas fa-users"></i> Effectifs</a>
        <a href="/formations" class="nav-item-premium"><i class="fas fa-graduation-cap"></i> Formations</a>
        <a href="/documents" class="nav-item-premium"><i class="fas fa-file-signature"></i> Documents</a>
        
        <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.id === '1247264549489610897' || user.isAdmin === true)) { %>
            <div class="admin-divider"></div>
            <a href="/admin" class="nav-item-premium admin-link">
                <i class="fas fa-cogs"></i> Administration
            </a>
        <% } %>
    </div>
</aside>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const currentUrl = window.location.pathname;
        const navLinks = document.querySelectorAll('.nav-item-premium');
        
        navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === currentUrl) {
                link.classList.add('active');
            }
        });
    });
</script>