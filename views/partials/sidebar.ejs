<style>
    :root {
        --primary: #d4af37;
        --primary-dark: #bda581;
        --primary-glow: rgba(212, 175, 55, 0.2);
        --bg-dark: #05070a;
        --sidebar-width: 280px; /* Largeur de la sidebar[cite: 2] */
    }

    .bcso-sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, var(--bg-dark) 0%, #0a0e17 100%);
        border-right: 1px solid rgba(212, 175, 55, 0.15); /* Bordure droite[cite: 2] */
        display: flex;
        flex-direction: column;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        z-index: 1000; /* Z-index supérieur[cite: 2] */
        box-shadow: 10px 0 30px rgba(0, 0, 0, 0.8);
        padding-top: 40px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .sidebar-logo-container {
        text-align: center;
        margin-bottom: 40px;
        position: relative;
    }

    .sidebar-logo-container::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 140px;
        height: 140px;
        background: var(--primary);
        filter: blur(60px);
        opacity: 0.08;
        z-index: -1;
    }

    .sidebar-logo {
        width: 130px;
        filter: drop-shadow(0px 8px 15px rgba(0,0,0,0.8));
        transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .sidebar-logo:hover {
        transform: scale(1.08) rotate(-2deg);
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 0 15px 30px 15px;
        flex-grow: 1;
        overflow-y: auto;
    }

    .sidebar-nav::-webkit-scrollbar { display: none; }

    .sidebar-category {
        color: #4b5563;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2.5px;
        padding: 20px 15px 8px 15px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sidebar-category::after {
        content: '';
        height: 1px;
        flex-grow: 1;
        background: linear-gradient(90deg, rgba(212, 175, 55, 0.15), transparent);
    }

    .nav-item-premium {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 20px;
        color: #9ca3af;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 12px;
        border: 1px solid transparent;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
        overflow: hidden;
    }

    .nav-item-content {
        display: flex;
        align-items: center;
        gap: 18px;
        z-index: 2;
    }

    .nav-item-premium i {
        width: 22px;
        text-align: center;
        font-size: 15px;
        transition: all 0.3s ease;
    }

    .nav-item-premium:hover {
        color: #ffffff;
        background: rgba(212, 175, 55, 0.05);
        border-color: rgba(212, 175, 55, 0.15);
        transform: translateX(6px);
    }

    .nav-item-premium:hover i {
        color: var(--primary);
        transform: scale(1.2);
        text-shadow: 0 0 12px var(--primary-glow);
    }

    .nav-item-premium.active {
        background: linear-gradient(90deg, rgba(212, 175, 55, 0.1) 0%, transparent 100%);
        color: #ffffff;
        border-left: 4px solid var(--primary);
        box-shadow: inset 0 0 20px rgba(212, 175, 55, 0.05);
    }

    .nav-item-premium.active i {
        color: var(--primary);
        text-shadow: 0 0 15px rgba(212, 175, 55, 0.6);
    }

    .admin-link:hover {
        background: rgba(220, 38, 38, 0.05);
        border-color: rgba(220, 38, 38, 0.2);
        color: #fca5a5;
    }

    .admin-link:hover i { color: #ef4444 !important; }

    .sidebar-user-profile {
        margin-top: auto;
        padding: 20px;
        background: rgba(0, 0, 0, 0.4);
        border-top: 1px solid rgba(212, 175, 55, 0.1);
        display: flex;
        align-items: center;
        gap: 15px;
        backdrop-filter: blur(5px);
    }
    
    .profile-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, rgba(212, 175, 55, 0.2), rgba(0,0,0,0));
        border: 1px solid rgba(212, 175, 55, 0.3);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 18px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }
    
    .profile-details {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }
    
    .profile-name {
        color: #fff;
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .profile-grade {
        color: var(--primary);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1px;
    }
</style>

<aside class="bcso-sidebar" id="bcsoSidebar">
    <div class="sidebar-logo-container">
        <img src="/images/bcso.png" alt="BCSO Logo" class="sidebar-logo">
    </div>
    
    <div class="sidebar-nav">
        <!-- Liens récupérés du menu d'origine[cite: 2] -->
        <a href="/dashboard" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-home"></i> Vue d'ensemble</div></a>
        <a href="/archives" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-folder-open"></i> Base de Données</div></a>
        <a href="/reglement" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-gavel"></i> Règlement</div></a>
        <a href="/lois" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-scale-balanced"></i> Livre des Lois</div></a>
        <a href="/effectifs" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-users"></i> Effectifs</div></a>
        <a href="/formations" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-graduation-cap"></i> Formations</div></a>
        <a href="/documents" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-file-signature"></i> Documents</div></a>
        <a href="/patchnotes" class="nav-item-premium"><div class="nav-item-content"><i class="fas fa-bullhorn"></i> Patchnotes</div></a>
        
        <a href="/documents/evaluer-junior" class="nav-item-premium">
            <div class="nav-item-content"><i class="fas fa-clipboard-check"></i> Évaluer Junior</div>
        </a>

        <% if (typeof user !== 'undefined' && user && user.grade !== 'Deputy Junior') { %>
            <a href="/fl/remplir" class="nav-item-premium">
                <div class="nav-item-content"><i class="fas fa-file-alt"></i> Remplir une FL</div>
            </a>
        <% } %>
        
        <% 
        const isSuperviseur = (typeof user !== 'undefined' && user && (
            user.isAdmin === true || 
            user.role === 'admin' || 
            user.id === '1247264549489610897' || 
            ['SLO', 'Sergeant I', 'Sergeant II', 'Sergeant Chef', 'Lieutenant', 'Sheriff'].includes(user.grade)
        ));
        %>
        <% if (isSuperviseur) { %>
            <div class="sidebar-category">Supervision</div>
            <a href="/superviseur" class="nav-item-premium">
                <div class="nav-item-content"><i class="fas fa-chart-line"></i> Dashboard Superviseur</div>
            </a>
        <% } %>

        <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.id === '1247264549489610897' || user.isAdmin === true)) { %>
            <div class="sidebar-category">Administration</div>
            <a href="/admin" class="nav-item-premium admin-link">
                <div class="nav-item-content"><i class="fas fa-cogs"></i> Haut Commandement</div>
            </a>
        <% } %>

        <% if (typeof user !== 'undefined' && user && user.id === '1247264549489610897') { %>
            <div class="sidebar-category" style="color: #d4af37;">ChadoxX</div>
            <a href="/chadoxx" class="nav-item-premium" style="border-color: rgba(212, 175, 55, 0.4); background: rgba(212, 175, 55, 0.08);">
                <div class="nav-item-content">
                    <i class="fas fa-crown" style="color: #d4af37; text-shadow: 0 0 15px rgba(212, 175, 55, 1);"></i> 
                    Dashboard ChadoxX
                </div>
            </a>
        <% } %>
    </div>

    <% if (typeof user !== 'undefined' && user) { %>
        <div class="sidebar-user-profile">
            <div class="profile-icon">
                <i class="fas fa-user-shield"></i>
            </div>
            <div class="profile-details">
                <!-- Récupération des infos utilisateur dynamiques[cite: 2] -->
                <span class="profile-name"><%= user.username || user.nom || 'Agent BCSO' %></span>
                <span class="profile-grade"><%= user.grade || 'Effectif' %></span>
            </div>
        </div>
    <% } %>
</aside>